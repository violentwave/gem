#!/bin/bash
#
# gemma-security-dashboard-build
# Local security dashboard generator for the Bazzite security stack
# Usage: gemma-security-dashboard-build [--open|--watch|--interval SECONDS|--help]
# Output: ~/.local/share/bazzite-security/security-dashboard/index.html
# Report: ~/offload/security-reports/manual/security-dashboard-YYYYMMDD-HHMMSS.md
# Log:    ~/.local/state/bazzite-security/logs/security-dashboard-YYYYMMDD-HHMMSS.log

set -euo pipefail

PROG="gemma-security-dashboard-build"
OPEN_BROWSER=false
WATCH_MODE=false
INTERVAL=60

show_help() {
    cat << EOF
${PROG} — Local security dashboard generator for the Bazzite security stack

USAGE:
    ${PROG} [OPTIONS]

OPTIONS:
    --open              Open the generated dashboard in the default browser.
    --watch             Run in foreground watch mode (regenerates every interval).
    --interval SECONDS  Set refresh interval for watch mode (default: 60, min: 15).
    --help, -h          Show this help message and exit.

DEFAULT BEHAVIOR:
    Generates the security dashboard HTML, a Markdown report, and a log file.
    No browser is opened. No daemon is started. No system state is changed.

WATCH MODE:
    When --watch is used, the script loops in the foreground, regenerating
    the dashboard every --interval seconds. Press Ctrl+C to stop.
    The generated HTML includes a <meta refresh> tag matching the interval.
    Watch mode is NOT a daemon — it stops when the terminal command stops.

OUTPUT PATHS:
    HTML dashboard : ~/.local/share/bazzite-security/security-dashboard/index.html
    Markdown report: ~/offload/security-reports/manual/security-dashboard-YYYYMMDD-HHMMSS.md
    Build log      : ~/.local/state/bazzite-security/logs/security-dashboard-YYYYMMDD-HHMMSS.log

PANELS:
    1. Security Summary     6. Security Timers
    2. Firewall             7. Recent Security Reports
    3. USBGuard             8. Gemma Advisory Status
    4. ClamAV / Freshclam   9. Guardrails / No-Go Items
    5. Lynis               10. Next Safe Actions

SAFETY:
    - Read-only inspection only.
    - No system state changes.
    - No secrets exposed.
    - No daemon or server started.
    - No ClamAV scans launched.
    - No Lynis audits launched.
    - No firewall or USBGuard changes.
    - Graceful degradation if optional tools are missing.

EXAMPLES:
    ${PROG}                         # Generate dashboard once
    ${PROG} --open                  # Generate and open in browser
    ${PROG} --watch                 # Watch mode, 60s interval
    ${PROG} --watch --interval 30   # Watch mode, 30s interval
    ${PROG} --help                  # Show this help
EOF
}

# Parse arguments
while [ $# -gt 0 ]; do
    case "${1}" in
        --open)
            OPEN_BROWSER=true
            shift
            ;;
        --watch)
            WATCH_MODE=true
            shift
            ;;
        --interval)
            if [ -z "${2:-}" ]; then
                echo "Error: --interval requires a value" >&2
                exit 1
            fi
            INTERVAL="${2}"
            if ! [[ "${INTERVAL}" =~ ^[0-9]+$ ]] || [ "${INTERVAL}" -lt 15 ]; then
                echo "Error: --interval must be an integer >= 15" >&2
                exit 1
            fi
            shift 2
            ;;
        --help|-h)
            show_help
            exit 0
            ;;
        *)
            echo "Error: unknown option '${1}'" >&2
            echo "Run '${PROG} --help' for usage." >&2
            exit 1
            ;;
    esac
done

# Paths
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
DATE_HUMAN=$(date '+%Y-%m-%d %H:%M:%S %Z')
HOSTNAME=$(hostname)
OS_NAME=$(grep '^NAME=' /etc/os-release 2>/dev/null | sed 's/^NAME=//; s/"//g' || echo "Unknown")

DASHBOARD_DIR="${HOME}/.local/share/bazzite-security/security-dashboard"
REPORT_DIR="${HOME}/offload/security-reports/manual"
LOG_DIR="${HOME}/.local/state/bazzite-security/logs"
DAILY_DIR="${HOME}/offload/security-reports/daily"
WEEKLY_DIR="${HOME}/offload/security-reports/weekly"
AUDIT_DIR="${HOME}/offload/security-reports/audit"

HTML_OUT="${DASHBOARD_DIR}/index.html"
REPORT_OUT="${REPORT_DIR}/security-dashboard-${TIMESTAMP}.md"
LOG_OUT="${LOG_DIR}/security-dashboard-${TIMESTAMP}.log"

mkdir -p "${DASHBOARD_DIR}" "${REPORT_DIR}" "${LOG_DIR}"

# Helper functions
html_escape() {
    sed 's/&/\&amp;/g; s/</\&lt;/g; s/>/\&gt;/g; s/"/\&quot;/g'
}

check_pass() {
    if [ "$1" -eq 0 ]; then
        echo '<span class="pass">PASS</span>'
    else
        echo '<span class="fail">FAIL</span>'
    fi
}

check_warn() {
    if [ "$1" -eq 0 ]; then
        echo '<span class="pass">PASS</span>'
    else
        echo '<span class="warn">WARN</span>'
    fi
}

check_unknown() {
    if [ "$1" -eq 0 ]; then
        echo '<span class="pass">PASS</span>'
    else
        echo '<span class="unknown">UNKNOWN</span>'
    fi
}

# Data collection functions
collect_data() {
    # 1. Firewall
    FIREWALL_STATE=1
    FIREWALL_ZONE=""
    FIREWALL_ACTIVE_ZONES=""
    if command -v firewall-cmd >/dev/null 2>&1; then
        if firewall-cmd --state >/dev/null 2>&1; then
            FIREWALL_STATE=0
            FIREWALL_ZONE=$(firewall-cmd --get-default-zone 2>/dev/null || echo "")
            FIREWALL_ACTIVE_ZONES=$(firewall-cmd --get-active-zones 2>/dev/null | grep -v '^\s' | tr '\n' ', ' | sed 's/, $//')
        fi
    fi

    # 2. USBGuard
    USBGUARD_STATUS=1
    if command -v systemctl >/dev/null 2>&1; then
        if systemctl is-active usbguard >/dev/null 2>&1; then
            USBGUARD_STATUS=0
        fi
    fi

    # 3. Freshclam
    FRESHCLAM_STATUS=1
    if command -v systemctl >/dev/null 2>&1; then
        if systemctl is-active clamav-freshclam >/dev/null 2>&1 || systemctl is-active freshclam >/dev/null 2>&1; then
            FRESHCLAM_STATUS=0
        fi
    fi

    # 4. ClamAV reports
    CLAMSCAN_AVAILABLE=1
    if command -v clamscan >/dev/null 2>&1; then
        CLAMSCAN_AVAILABLE=0
    fi
    LATEST_CLAM=""
    CLAM_INFECTED="N/A"
    CLAM_SCANNED="N/A"
    if [ -d "${DAILY_DIR}" ]; then
        LATEST_CLAM=$(find "${DAILY_DIR}" -maxdepth 1 -type f -name "clam-scan-*.txt" -printf '%T@ %p\n' 2>/dev/null | sort -rn | head -1 | cut -d' ' -f2-)
        if [ -n "${LATEST_CLAM}" ] && [ -f "${LATEST_CLAM}" ]; then
            CLAM_INFECTED=$(grep "Infected files:" "${LATEST_CLAM}" 2>/dev/null | awk -F': ' '{print $2}' || echo "N/A")
            CLAM_SCANNED=$(grep "Scanned files:" "${LATEST_CLAM}" 2>/dev/null | awk -F': ' '{print $2}' || echo "N/A")
        fi
    fi

    # 5. Lynis
    LYNIS_AVAILABLE=1
    if command -v lynis >/dev/null 2>&1; then
        LYNIS_AVAILABLE=0
    fi
    LATEST_LYNIS=""
    LYNIS_HARDENING="N/A"
    LYNIS_WARNINGS="N/A"
    LYNIS_SUGGESTIONS="N/A"
    if [ -d "${WEEKLY_DIR}" ]; then
        LATEST_LYNIS=$(find "${WEEKLY_DIR}" -maxdepth 1 -type f -name "lynis-summary-*.txt" -printf '%T@ %p\n' 2>/dev/null | sort -rn | head -1 | cut -d' ' -f2-)
        if [ -n "${LATEST_LYNIS}" ] && [ -f "${LATEST_LYNIS}" ]; then
            LYNIS_HARDENING=$(grep "Hardening index:" "${LATEST_LYNIS}" 2>/dev/null | awk -F': ' '{print $2}' || echo "N/A")
            LYNIS_WARNINGS=$(grep "Warnings count:" "${LATEST_LYNIS}" 2>/dev/null | awk -F': ' '{print $2}' || echo "N/A")
            LYNIS_SUGGESTIONS=$(grep "Suggestions count:" "${LATEST_LYNIS}" 2>/dev/null | awk -F': ' '{print $2}' || echo "N/A")
        fi
    fi

    # 6. Security timers
    USER_TIMER_SUMMARY=1
    SYSTEM_TIMER_SUMMARY=1
    if command -v systemctl >/dev/null 2>&1; then
        if systemctl --user list-timers 2>/dev/null | grep -q "bazzite-security-summary"; then
            USER_TIMER_SUMMARY=0
        fi
        if systemctl --user list-timers 2>/dev/null | grep -q "bazzite-clam-scan"; then
            USER_TIMER_CLAM=0
        fi
        if systemctl list-timers 2>/dev/null | grep -q "bazzite-lynis-audit"; then
            SYSTEM_TIMER_SUMMARY=0
        fi
    fi

    # 7. Recent reports counts
    DAILY_COUNT=0
    WEEKLY_COUNT=0
    AUDIT_COUNT=0
    MANUAL_COUNT=0
    [ -d "${DAILY_DIR}" ] && DAILY_COUNT=$(find "${DAILY_DIR}" -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')
    [ -d "${WEEKLY_DIR}" ] && WEEKLY_COUNT=$(find "${WEEKLY_DIR}" -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')
    [ -d "${AUDIT_DIR}" ] && AUDIT_COUNT=$(find "${AUDIT_DIR}" -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')
    [ -d "${REPORT_DIR}" ] && MANUAL_COUNT=$(find "${REPORT_DIR}" -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')

    # 8. Gemma / Ollama
    OLLAMA_API_OK=1
    if curl -s --max-time 5 http://127.0.0.1:11434/api/version >/dev/null 2>&1; then
        OLLAMA_API_OK=0
    fi
    GEMMA_MODEL_OK=1
    if command -v ollama >/dev/null 2>&1; then
        if ollama list 2>/dev/null | grep -q "gemma4-e4b-bazzite"; then
            GEMMA_MODEL_OK=0
        fi
    fi

    # Overall status
    OVERALL_STATUS="PASS"
    OVERALL_CLASS="pass"
    if [ ${FIREWALL_STATE} -ne 0 ] || [ ${USBGUARD_STATUS} -ne 0 ] || [ ${FRESHCLAM_STATUS} -ne 0 ]; then
        OVERALL_STATUS="WARN"
        OVERALL_CLASS="warn"
    fi
    if [ ${OLLAMA_API_OK} -ne 0 ] && [ ${GEMMA_MODEL_OK} -eq 0 ]; then
        : # Gemma model exists but API down is still WARN, not FAIL
    fi
}

generate_outputs() {
    local meta_refresh=""
    if [ "${WATCH_MODE}" = true ]; then
        meta_refresh="<meta http-equiv=\"refresh\" content=\"${INTERVAL}\">"
    fi

    local watch_banner=""
    if [ "${WATCH_MODE}" = true ]; then
        watch_banner="<div class=\"watch-banner\">WATCH MODE — Refreshing every ${INTERVAL}s — Press Ctrl+C in terminal to stop</div>"
    fi

    cat > "${HTML_OUT}" << HTMLHEAD
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
${meta_refresh}
<title>Bazzite Security Dashboard</title>
<style>
  *{box-sizing:border-box}
  body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;margin:0;padding:20px;background:#0d1117;color:#c9d1d9;line-height:1.5}
  h1{margin:0 0 10px;font-size:1.6rem;color:#f0f6fc}
  h2{margin:30px 0 10px;font-size:1.2rem;color:#58a6ff;border-bottom:1px solid #30363d;padding-bottom:6px}
  .meta{color:#8b949e;font-size:0.85rem;margin-bottom:20px}
  .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:16px}
  .card{background:#161b22;border:1px solid #30363d;border-radius:8px;padding:16px}
  .card h3{margin:0 0 10px;font-size:1rem;color:#f0f6fc}
  table{width:100%;border-collapse:collapse;font-size:0.9rem}
  td,th{padding:6px 8px;text-align:left;border-bottom:1px solid #21262d}
  th{color:#8b949e;font-weight:600}
  .pass{color:#3fb950;font-weight:600}
  .warn{color:#d29922;font-weight:600}
  .fail{color:#f85149;font-weight:600}
  .unknown{color:#8b949e;font-weight:600}
  .status-badge{display:inline-block;padding:4px 10px;border-radius:4px;font-weight:600;font-size:0.85rem}
  .status-pass{background:#238636;color:#fff}
  .status-warn{background:#9e6a03;color:#fff}
  .status-fail{background:#da3633;color:#fff}
  ul{margin:6px 0;padding-left:18px}
  li{margin:4px 0}
  .nogolist{background:#300;border:1px solid #822;padding:12px;border-radius:6px}
  .nogolist strong{color:#f85149}
  .next-actions{background:#0d2818;border:1px solid #2ea043;padding:12px;border-radius:6px}
  .next-actions strong{color:#3fb950}
  .muted{color:#8b949e}
  .small{font-size:0.8rem}
  .watch-banner{background:#1f6feb;color:#fff;padding:8px 16px;border-radius:4px;margin-bottom:16px;font-weight:600;text-align:center}
  a{color:#58a6ff;text-decoration:none}
  a:hover{text-decoration:underline}
</style>
</head>
<body>
<h1>Bazzite Security Dashboard</h1>
<div class="meta">${HOSTNAME} &middot; ${OS_NAME} &middot; ${DATE_HUMAN} &middot; Overall: <span class="status-badge status-${OVERALL_CLASS}">${OVERALL_STATUS}</span></div>
${watch_banner}

<div class="grid">

<div class="card">
<h3>1. Security Summary</h3>
<table>
<tr><th>Item</th><th>Value</th></tr>
<tr><td>Overall Status</td><td><span class="${OVERALL_CLASS}">${OVERALL_STATUS}</span></td></tr>
<tr><td>Host</td><td>${HOSTNAME}</td></tr>
<tr><td>Timestamp</td><td>${DATE_HUMAN}</td></tr>
</table>
<p class="small muted">Read-only status. No autonomous remediation.</p>
</div>

<div class="card">
<h3>2. Firewall</h3>
<table>
<tr><th>Item</th><th>Value</th></tr>
<tr><td>firewalld State</td><td>$(check_pass ${FIREWALL_STATE})</td></tr>
<tr><td>Default Zone</td><td>${FIREWALL_ZONE:-N/A}</td></tr>
<tr><td>Active Zones</td><td>${FIREWALL_ACTIVE_ZONES:-N/A}</td></tr>
</table>
</div>

<div class="card">
<h3>3. USBGuard</h3>
<table>
<tr><th>Item</th><th>Value</th></tr>
<tr><td>Service Status</td><td>$(check_pass ${USBGUARD_STATUS})</td></tr>
</table>
<p class="small muted">No policy changes performed. Read-only check.</p>
</div>

<div class="card">
<h3>4. ClamAV / Freshclam</h3>
<table>
<tr><th>Item</th><th>Value</th></tr>
<tr><td>freshclam Service</td><td>$(check_pass ${FRESHCLAM_STATUS})</td></tr>
<tr><td>clamscan Binary</td><td>$(check_pass ${CLAMSCAN_AVAILABLE})</td></tr>
<tr><td>Latest Scan</td><td>$(basename "${LATEST_CLAM}" 2>/dev/null || echo "None")</td></tr>
<tr><td>Infected Files</td><td>${CLAM_INFECTED}</td></tr>
<tr><td>Scanned Files</td><td>${CLAM_SCANNED}</td></tr>
</table>
<p class="small muted">Reports from: ~/offload/security-reports/daily/</p>
</div>

<div class="card">
<h3>5. Lynis</h3>
<table>
<tr><th>Item</th><th>Value</th></tr>
<tr><td>lynis Binary</td><td>$(check_pass ${LYNIS_AVAILABLE})</td></tr>
<tr><td>Latest Report</td><td>$(basename "${LATEST_LYNIS}" 2>/dev/null || echo "None")</td></tr>
<tr><td>Hardening Index</td><td>${LYNIS_HARDENING}</td></tr>
<tr><td>Warnings</td><td>${LYNIS_WARNINGS}</td></tr>
<tr><td>Suggestions</td><td>${LYNIS_SUGGESTIONS}</td></tr>
</table>
<p class="small muted">Reports from: ~/offload/security-reports/weekly/</p>
</div>

<div class="card">
<h3>6. Security Timers</h3>
<table>
<tr><th>Timer</th><th>Status</th></tr>
<tr><td>bazzite-security-summary (user)</td><td>$(check_pass ${USER_TIMER_SUMMARY})</td></tr>
<tr><td>bazzite-clam-scan (user)</td><td>$(check_pass ${USER_TIMER_CLAM:-1})</td></tr>
<tr><td>bazzite-lynis-audit (system)</td><td>$(check_pass ${SYSTEM_TIMER_SUMMARY})</td></tr>
</table>
<p class="small muted">Read-only status. No enable/disable/start/stop.</p>
</div>

<div class="card">
<h3>7. Recent Security Reports</h3>
<table>
<tr><th>Category</th><th>Count</th></tr>
<tr><td>Daily</td><td>${DAILY_COUNT}</td></tr>
<tr><td>Weekly</td><td>${WEEKLY_COUNT}</td></tr>
<tr><td>Audit</td><td>${AUDIT_COUNT}</td></tr>
<tr><td>Manual</td><td>${MANUAL_COUNT}</td></tr>
</table>
<p class="small muted">Paths: ~/offload/security-reports/</p>
</div>

<div class="card">
<h3>8. Gemma Advisory Status</h3>
<table>
<tr><th>Item</th><th>Value</th></tr>
<tr><td>Ollama API</td><td>$(check_pass ${OLLAMA_API_OK})</td></tr>
<tr><td>Gemma Model</td><td>$(check_pass ${GEMMA_MODEL_OK})</td></tr>
<tr><td>Latest Security Summary</td><td>$(ls -1t "${DAILY_DIR}"/security-summary-*.txt 2>/dev/null | head -1 | xargs basename 2>/dev/null || echo "None")</td></tr>
<tr><td>Latest Dashboard</td><td>$(ls -1t "${REPORT_DIR}"/gemma-dashboard-*.md 2>/dev/null | head -1 | xargs basename 2>/dev/null || echo "None")</td></tr>
</table>
<p class="small muted">Gemma is advisory only. No autonomous security actions.</p>
</div>

<div class="card nogolist">
<h3>9. Guardrails / No-Go Items</h3>
<ul>
<li><strong>No sudo</strong> — Dashboard runs without elevated privileges.</li>
<li><strong>No remediation</strong> — Read-only status, no fixes applied.</li>
<li><strong>No firewall changes</strong> — firewalld state is inspected only.</li>
<li><strong>No USBGuard changes</strong> — Policy is inspected only.</li>
<li><strong>No ClamAV scans launched</strong> — Only reads existing reports.</li>
<li><strong>No Lynis audits launched</strong> — Only reads existing reports.</li>
<li><strong>Agent Zero local Gemma tool-loop: NO-GO</strong> — Protocol mismatch.</li>
<li><strong>No secrets</strong> — API keys, tokens, and credentials are redacted.</li>
</ul>
</div>

<div class="card next-actions">
<h3>10. Next Safe Actions</h3>
<ul>
$( [ ${FRESHCLAM_STATUS} -ne 0 ] && echo '<li><strong>freshclam inactive.</strong> Review: systemctl status clamav-freshclam</li>' || true )
$( [ -z "${LATEST_CLAM}" ] && echo '<li><strong>No clam scan reports found.</strong> Run existing scan helper manually if needed.</li>' || true )
$( [ -z "${LATEST_LYNIS}" ] && echo '<li><strong>No Lynis reports found.</strong> Review timer: systemctl status bazzite-lynis-audit.timer</li>' || true )
$( [ ${FIREWALL_STATE} -ne 0 ] && echo '<li><strong>firewalld not running.</strong> Review: sudo systemctl status firewalld</li>' || true )
$( [ ${USBGUARD_STATUS} -ne 0 ] && echo '<li><strong>USBGuard not active.</strong> Review: sudo systemctl status usbguard</li>' || true )
$( [ ${FIREWALL_STATE} -eq 0 ] && [ ${USBGUARD_STATUS} -eq 0 ] && [ ${FRESHCLAM_STATUS} -eq 0 ] && [ -n "${LATEST_CLAM}" ] && [ -n "${LATEST_LYNIS}" ] && echo '<li><strong>All clear.</strong> No immediate action required.</li>' || true )
</ul>
</div>

</div>

<p class="meta small" style="margin-top:30px">Generated by ${PROG} &middot; ${TIMESTAMP} &middot; <a href="https://github.com/violentwave/gem">gem repo</a></p>
</body>
</html>
HTMLHEAD

    # Markdown report
    cat > "${REPORT_OUT}" << MDHEAD
# Bazzite Security Dashboard Report

**Host:** ${HOSTNAME}  
**OS:** ${OS_NAME}  
**Generated:** ${DATE_HUMAN}  
**Overall Status:** ${OVERALL_STATUS}

---

## 1. Security Summary

| Item | Value |
|------|-------|
| Overall Status | ${OVERALL_STATUS} |
| Host | ${HOSTNAME} |
| Timestamp | ${DATE_HUMAN} |

*Read-only status. No autonomous remediation.*

## 2. Firewall

| Item | Value |
|------|-------|
| firewalld State | $( [ ${FIREWALL_STATE} -eq 0 ] && echo 'PASS (running)' || echo 'FAIL (not running)' ) |
| Default Zone | ${FIREWALL_ZONE:-N/A} |
| Active Zones | ${FIREWALL_ACTIVE_ZONES:-N/A} |

## 3. USBGuard

| Item | Value |
|------|-------|
| Service Status | $( [ ${USBGUARD_STATUS} -eq 0 ] && echo 'PASS (active)' || echo 'FAIL (inactive)' ) |

*No policy changes performed. Read-only check.*

## 4. ClamAV / Freshclam

| Item | Value |
|------|-------|
| freshclam Service | $( [ ${FRESHCLAM_STATUS} -eq 0 ] && echo 'PASS (active)' || echo 'FAIL (inactive)' ) |
| clamscan Binary | $( [ ${CLAMSCAN_AVAILABLE} -eq 0 ] && echo 'Available' || echo 'Missing' ) |
| Latest Scan | $(basename "${LATEST_CLAM}" 2>/dev/null || echo "None") |
| Infected Files | ${CLAM_INFECTED} |
| Scanned Files | ${CLAM_SCANNED} |

*Reports from: ~/offload/security-reports/daily/*

## 5. Lynis

| Item | Value |
|------|-------|
| lynis Binary | $( [ ${LYNIS_AVAILABLE} -eq 0 ] && echo 'Available' || echo 'Missing' ) |
| Latest Report | $(basename "${LATEST_LYNIS}" 2>/dev/null || echo "None") |
| Hardening Index | ${LYNIS_HARDENING} |
| Warnings | ${LYNIS_WARNINGS} |
| Suggestions | ${LYNIS_SUGGESTIONS} |

*Reports from: ~/offload/security-reports/weekly/*

## 6. Security Timers

| Timer | Status |
|-------|--------|
| bazzite-security-summary (user) | $( [ ${USER_TIMER_SUMMARY} -eq 0 ] && echo 'PASS (scheduled)' || echo 'FAIL (not found)' ) |
| bazzite-clam-scan (user) | $( [ ${USER_TIMER_CLAM:-1} -eq 0 ] && echo 'PASS (scheduled)' || echo 'FAIL (not found)' ) |
| bazzite-lynis-audit (system) | $( [ ${SYSTEM_TIMER_SUMMARY} -eq 0 ] && echo 'PASS (scheduled)' || echo 'FAIL (not found)' ) |

*Read-only status. No enable/disable/start/stop.*

## 7. Recent Security Reports

| Category | Count |
|----------|-------|
| Daily | ${DAILY_COUNT} |
| Weekly | ${WEEKLY_COUNT} |
| Audit | ${AUDIT_COUNT} |
| Manual | ${MANUAL_COUNT} |

*Paths: ~/offload/security-reports/*

## 8. Gemma Advisory Status

| Item | Value |
|------|-------|
| Ollama API | $( [ ${OLLAMA_API_OK} -eq 0 ] && echo 'PASS' || echo 'FAIL' ) |
| Gemma Model | $( [ ${GEMMA_MODEL_OK} -eq 0 ] && echo 'PASS' || echo 'FAIL' ) |
| Latest Security Summary | $(ls -1t "${DAILY_DIR}"/security-summary-*.txt 2>/dev/null | head -1 | xargs basename 2>/dev/null || echo "None") |
| Latest Dashboard | $(ls -1t "${REPORT_DIR}"/gemma-dashboard-*.md 2>/dev/null | head -1 | xargs basename 2>/dev/null || echo "None") |

*Gemma is advisory only. No autonomous security actions.*

## 9. Guardrails / No-Go Items

- **No sudo** — Dashboard runs without elevated privileges.
- **No remediation** — Read-only status, no fixes applied.
- **No firewall changes** — firewalld state is inspected only.
- **No USBGuard changes** — Policy is inspected only.
- **No ClamAV scans launched** — Only reads existing reports.
- **No Lynis audits launched** — Only reads existing reports.
- **Agent Zero local Gemma tool-loop: NO-GO** — Protocol mismatch.
- **No secrets** — API keys, tokens, and credentials are redacted.

## 10. Next Safe Actions

$( [ ${FRESHCLAM_STATUS} -ne 0 ] && echo '- **freshclam inactive.** Review: systemctl status clamav-freshclam' || true )
$( [ -z "${LATEST_CLAM}" ] && echo '- **No clam scan reports found.** Run existing scan helper manually if needed.' || true )
$( [ -z "${LATEST_LYNIS}" ] && echo '- **No Lynis reports found.** Review timer: systemctl status bazzite-lynis-audit.timer' || true )
$( [ ${FIREWALL_STATE} -ne 0 ] && echo '- **firewalld not running.** Review: sudo systemctl status firewalld' || true )
$( [ ${USBGUARD_STATUS} -ne 0 ] && echo '- **USBGuard not active.** Review: sudo systemctl status usbguard' || true )
$( [ ${FIREWALL_STATE} -eq 0 ] && [ ${USBGUARD_STATUS} -eq 0 ] && [ ${FRESHCLAM_STATUS} -eq 0 ] && [ -n "${LATEST_CLAM}" ] && [ -n "${LATEST_LYNIS}" ] && echo '- **All clear.** No immediate action required.' || true )

---

*Report generated by ${PROG} at ${TIMESTAMP}*
MDHEAD
}

# Main execution
if [ "${WATCH_MODE}" = true ]; then
    echo "=== ${PROG} WATCH MODE ==="
    echo "Interval: ${INTERVAL} seconds"
    echo "Press Ctrl+C to stop"
    echo ""
    while true; do
        TIMESTAMP=$(date +%Y%m%d-%H%M%S)
        DATE_HUMAN=$(date '+%Y-%m-%d %H:%M:%S %Z')
        REPORT_OUT="${REPORT_DIR}/security-dashboard-${TIMESTAMP}.md"
        LOG_OUT="${LOG_DIR}/security-dashboard-${TIMESTAMP}.log"
        exec > >(tee -a "${LOG_OUT}") 2>&1
        collect_data
        generate_outputs
        echo "[${DATE_HUMAN}] Dashboard refreshed. HTML: ${HTML_OUT}"
        if [ "${OPEN_BROWSER}" = true ]; then
            if command -v xdg-open >/dev/null 2>&1; then
                xdg-open "${HTML_OUT}" >/dev/null 2>&1
                OPEN_BROWSER=false
            fi
        fi
        sleep "${INTERVAL}"
    done
else
    exec > >(tee -a "${LOG_OUT}") 2>&1
    echo "=== ${PROG} ${TIMESTAMP} ==="
    echo "Starting security dashboard generation..."
    collect_data
    generate_outputs
    echo "Security dashboard generated successfully."
    echo "HTML: ${HTML_OUT}"
    echo "Report: ${REPORT_OUT}"
    echo "Log: ${LOG_OUT}"

    if [ "${OPEN_BROWSER}" = true ]; then
        if command -v xdg-open >/dev/null 2>&1; then
            xdg-open "${HTML_OUT}"
            echo "Opened dashboard in browser."
        elif command -v open >/dev/null 2>&1; then
            open "${HTML_OUT}"
            echo "Opened dashboard in browser."
        else
            echo "No browser opener found. Open manually: ${HTML_OUT}"
        fi
    fi

    echo "=== Done ==="
fi
