#!/usr/bin/env bash
set -Eeuo pipefail

# gemma-file-brief - Advisory local file summary through Gemma
# Advisory only, no sudo, no system changes

TIMESTAMP=$(date +%Y%m%d-%H%M%S)
readonly TIMESTAMP
readonly REPORT_FILE="${HOME}/offload/security-reports/manual/gemma-file-brief-${TIMESTAMP}.md"
readonly LOG_FILE="${HOME}/.local/state/bazzite-security/logs/gemma-file-brief-${TIMESTAMP}.log"
readonly MODEL="${GEMMA_MODEL:-gemma4-e4b-bazzite}"
readonly MAX_BYTES=204800

usage() {
    cat <<'USAGE'
Usage: gemma-file-brief [--force] /path/to/file

Summarize one local file with Gemma for advisory review.
Refuses missing files, directories, and files over 200KB unless --force is used.
USAGE
}

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') $*" | tee -a "$LOG_FILE"
}

error_exit() {
    log "ERROR: $*"
    exit 1
}

strip_ansi() {
    sed \
        -e 's/\x1b\[[0-9;]*[a-zA-Z]//g' \
        -e 's/\x1b][^\x07]*\x07//g' \
        -e 's/\x1b][^\x1b]*\x1b\\//g' \
        -e 's/\x1b[()][0-9A-Za-z]//g' \
        -e 's/\x1b[78]//g' \
        -e 's/\x1b\[[\?0-9]*[hl]//g' \
        -e 's/\x0e//g' \
        -e 's/\x0f//g' \
        -e 's/\r//g'
}

redact_stream() {
    sed -E \
        -e 's/(api[_-]?key|token|secret|password|passwd|bearer|authorization)[[:space:]]*[:=][[:space:]]*[^[:space:]]+/\1=[REDACTED]/Ig' \
        -e 's/(AKIA[0-9A-Z]{16})/[REDACTED_AWS_KEY]/g' \
        -e 's/(sk-[A-Za-z0-9_-]{20,})/[REDACTED_OPENAI_KEY]/g' \
        -e 's/(ghp_[A-Za-z0-9_]{20,})/[REDACTED_GITHUB_TOKEN]/g' \
        -e 's/(github_pat_[A-Za-z0-9_]{20,})/[REDACTED_GITHUB_TOKEN]/g' \
        -e 's/-----BEGIN [A-Z ]*PRIVATE KEY-----/[REDACTED_PRIVATE_KEY_BEGIN]/g' \
        -e 's/-----END [A-Z ]*PRIVATE KEY-----/[REDACTED_PRIVATE_KEY_END]/g'
}

main() {
    mkdir -p "$(dirname "$LOG_FILE")" "$(dirname "$REPORT_FILE")" "${HOME}/.cache/bazzite-security/ollama"

    local force=false
    local target=""

    while (($# > 0)); do
        case "$1" in
            --force)
                force=true
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            --)
                shift
                break
                ;;
            -* )
                usage
                error_exit "Unknown option: $1"
                ;;
            *)
                if [[ -n "$target" ]]; then
                    usage
                    error_exit "Only one file path is supported"
                fi
                target="$1"
                ;;
        esac
        shift
    done

    if (($# > 0)); then
        if [[ -n "$target" || $# -ne 1 ]]; then
            usage
            error_exit "Only one file path is supported"
        fi
        target="$1"
    fi

    [[ -n "$target" ]] || { usage; error_exit "Missing file path"; }
    [[ -e "$target" ]] || error_exit "File does not exist: $target"
    [[ ! -d "$target" ]] || error_exit "Refusing directory: $target"
    [[ -f "$target" ]] || error_exit "Refusing non-regular file: $target"

    local size
    size=$(stat -c%s "$target")
    if ((size > MAX_BYTES)) && [[ "$force" != true ]]; then
        error_exit "File is ${size} bytes; refusing over 200KB without --force"
    fi

    log "=== Gemma File Brief ==="
    log "Timestamp: ${TIMESTAMP}"
    log "Model: ${MODEL}"
    log "Input: ${target}"
    log "Size: ${size} bytes"
    log "Report: ${REPORT_FILE}"

    local temp_prompt temp_output
    temp_prompt=$(mktemp "${HOME}/.cache/bazzite-security/ollama/gemma-file-brief-prompt-${TIMESTAMP}.XXXXXX")
    temp_output=$(mktemp "${HOME}/.cache/bazzite-security/ollama/gemma-file-brief-output-${TIMESTAMP}.XXXXXX")

    {
        cat <<PROMPT
You are Gemma running locally through Ollama on a Bazzite/Fedora Atomic desktop.

Task: summarize the supplied file excerpt for local advisory use.

Rules:
- Use only the supplied excerpt.
- Do not claim to have changed files or the system.
- Do not recommend sudo, package changes, firewall changes, USBGuard changes, rpm-ostree changes, or systemd timer changes.
- If the evidence is missing, say so.
- Return concise Markdown with these exact headings:
  - Purpose
  - Important facts
  - Risks/security notes
  - Suggested next actions
  - Uncertainty

File path: ${target}
File size bytes: ${size}

----- REDACTED FILE EXCERPT BEGIN -----
PROMPT
        redact_stream < "$target"
        cat <<'PROMPT'
----- REDACTED FILE EXCERPT END -----
PROMPT
    } > "$temp_prompt"

    if ollama run "$MODEL" --hidethinking < "$temp_prompt" > "$temp_output" 2>> "$LOG_FILE"; then
        {
            echo "# Gemma File Brief"
            echo
            echo "Generated: $(date -Iseconds)"
            echo "Model: ${MODEL}"
            echo "Input: ${target}"
            echo "Input size: ${size} bytes"
            echo
            echo "## Purpose"
            echo "Gemma was asked to identify the file purpose from the redacted excerpt. See advisory details below."
            echo
            echo "## Important facts"
            echo "Gemma was asked to extract important facts from the redacted excerpt. See advisory details below."
            echo
            echo "## Risks/security notes"
            echo "Gemma was asked to identify risks and security notes without recommending system changes. See advisory details below."
            echo
            echo "## Suggested next actions"
            echo "Gemma was asked for advisory next actions only. See advisory details below."
            echo
            echo "## Uncertainty"
            echo "Gemma was asked to state uncertainty when evidence is missing. See advisory details below."
            echo
            echo "## Gemma advisory details"
            strip_ansi < "$temp_output" | redact_stream
            echo
            echo "---"
            echo "Log: ${LOG_FILE}"
        } > "$REPORT_FILE"
        log "Report written to: ${REPORT_FILE}"
    else
        strip_ansi < "$temp_output" | redact_stream | tee -a "$LOG_FILE" >/dev/null || true
        rm -f "$temp_prompt" "$temp_output"
        error_exit "Gemma file brief failed"
    fi

    rm -f "$temp_prompt" "$temp_output"
    log "Log written to: ${LOG_FILE}"
    printf 'Report: %s\nLog: %s\n' "$REPORT_FILE" "$LOG_FILE"
}

main "$@"
