#!/usr/bin/env bash
set -Eeuo pipefail

# gemma-command-review - Advisory command review through Gemma
# Does not execute reviewed commands. Advisory only, no sudo, no system changes.

TIMESTAMP=$(date +%Y%m%d-%H%M%S)
readonly TIMESTAMP
readonly REPORT_FILE="${HOME}/offload/security-reports/manual/gemma-command-review-${TIMESTAMP}.md"
readonly LOG_FILE="${HOME}/.local/state/bazzite-security/logs/gemma-command-review-${TIMESTAMP}.log"
readonly MODEL="${GEMMA_MODEL:-gemma4-e4b-bazzite}"

usage() {
    cat <<'USAGE'
Usage: gemma-command-review 'command here'

Reviews command text with Gemma. The command is never executed.
USAGE
}

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') $*" | tee -a "$LOG_FILE"
}

error_exit() {
    log "ERROR: $*"
    exit 1
}

strip_ansi() {
    sed \
        -e 's/\x1b\[[0-9;]*[a-zA-Z]//g' \
        -e 's/\x1b][^\x07]*\x07//g' \
        -e 's/\x1b][^\x1b]*\x1b\\//g' \
        -e 's/\x1b[()][0-9A-Za-z]//g' \
        -e 's/\x1b[78]//g' \
        -e 's/\x1b\[[\?0-9]*[hl]//g' \
        -e 's/\x0e//g' \
        -e 's/\x0f//g' \
        -e 's/\r//g'
}

redact_text() {
    sed -E \
        -e 's/(api[_-]?key|token|secret|password|passwd|bearer|authorization)[[:space:]]*[:=][[:space:]]*[^[:space:]]+/\1=[REDACTED]/Ig' \
        -e 's/(sk-[A-Za-z0-9_-]{20,})/[REDACTED_OPENAI_KEY]/g' \
        -e 's/(ghp_[A-Za-z0-9_]{20,})/[REDACTED_GITHUB_TOKEN]/g' \
        -e 's/(github_pat_[A-Za-z0-9_]{20,})/[REDACTED_GITHUB_TOKEN]/g'
}

flag_patterns() {
    local command_text="$1"
    local found=false

    [[ "$command_text" =~ (^|[[:space:];|&])sudo([[:space:]]|$) ]] && { echo "- sudo"; found=true; }
    [[ "$command_text" =~ (^|[[:space:];|&])rm([[:space:]]|$) ]] && { echo "- rm"; found=true; }
    [[ "$command_text" =~ (^|[[:space:];|&])rpm-ostree([[:space:]]|$) ]] && { echo "- rpm-ostree"; found=true; }
    [[ "$command_text" =~ (^|[[:space:];|&])firewall-cmd([[:space:]]|$) ]] && { echo "- firewall-cmd"; found=true; }
    [[ "$command_text" =~ (^|[[:space:];|&])usbguard([[:space:]]|$) ]] && { echo "- usbguard"; found=true; }
    [[ "$command_text" =~ (^|[[:space:];|&])systemctl([[:space:]]|$) ]] && { echo "- systemctl"; found=true; }
    [[ "$command_text" =~ (^|[[:space:];|&])(chmod|chown)[[:space:]].*(/etc|/usr|/var|/boot|/opt|/sys|/proc|/dev)(/|[[:space:]]|$) ]] && { echo "- chmod/chown on system paths"; found=true; }
    if [[ "$command_text" == *"curl"* && "$command_text" =~ \|[[:space:]]*(sh|bash) ]]; then
        echo "- curl | sh"
        found=true
    fi

    [[ "$found" == true ]] || echo "- No explicit high-risk pattern matched by wrapper precheck."
}

main() {
    mkdir -p "$(dirname "$LOG_FILE")" "$(dirname "$REPORT_FILE")" "${HOME}/.cache/bazzite-security/ollama"

    if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        usage
        exit 0
    fi
    (($# == 1)) || { usage; error_exit "Provide exactly one quoted command string"; }

    local command_text redacted_command
    command_text="$1"
    [[ -n "$command_text" ]] || error_exit "Command text is empty"
    redacted_command=$(printf '%s\n' "$command_text" | redact_text)

    log "=== Gemma Command Review ==="
    log "Timestamp: ${TIMESTAMP}"
    log "Model: ${MODEL}"
    log "Command text is reviewed only; it is not executed."
    log "Report: ${REPORT_FILE}"

    local flags
    flags=$(flag_patterns "$command_text")

    local temp_prompt temp_output
    temp_prompt=$(mktemp "${HOME}/.cache/bazzite-security/ollama/gemma-command-review-prompt-${TIMESTAMP}.XXXXXX")
    temp_output=$(mktemp "${HOME}/.cache/bazzite-security/ollama/gemma-command-review-output-${TIMESTAMP}.XXXXXX")

    cat > "$temp_prompt" <<PROMPT
You are Gemma running locally through Ollama on a Bazzite/Fedora Atomic desktop.

Task: review this command text for safety. Do not execute it.

Classify the command as exactly one of:
- Safe to run now
- Optional later
- Risky / requires manual review

Explicitly flag these if present or implied:
- sudo
- rm
- rpm-ostree
- firewall-cmd
- usbguard
- systemctl
- chmod/chown on system paths
- curl | sh

Rules:
- Advisory only; do not claim to have run the command.
- Prefer least-invasive user-local actions on Bazzite/Fedora Atomic.
- Be concise.
- Include safer alternatives only if obvious.

Wrapper precheck flags:
${flags}

Command text:
${redacted_command}
PROMPT

    if ollama run "$MODEL" --hidethinking < "$temp_prompt" > "$temp_output" 2>> "$LOG_FILE"; then
        {
            echo "# Gemma Command Review"
            echo
            echo "Generated: $(date -Iseconds)"
            echo "Model: ${MODEL}"
            echo
            echo "## Command"
            echo '```bash'
            printf '%s\n' "$redacted_command"
            echo '```'
            echo
            echo "## Wrapper precheck flags"
            printf '%s\n' "$flags"
            echo
            echo "## Gemma advisory review"
            strip_ansi < "$temp_output" | redact_text
            echo
            echo "---"
            echo "Log: ${LOG_FILE}"
        } > "$REPORT_FILE"
        log "Report written to: ${REPORT_FILE}"
    else
        strip_ansi < "$temp_output" | redact_text | tee -a "$LOG_FILE" >/dev/null || true
        rm -f "$temp_prompt" "$temp_output"
        error_exit "Gemma command review failed"
    fi

    rm -f "$temp_prompt" "$temp_output"
    log "Log written to: ${LOG_FILE}"
    printf 'Report: %s\nLog: %s\n' "$REPORT_FILE" "$LOG_FILE"
}

main "$@"
