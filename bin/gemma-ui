def _render_demo_footer(width: int) -> Text:
    """Render a contextual help footer."""
    hints = [
        ("?", "Help"),
        ("/", "Command"),
        ("Tab", "Switch"),
        ("Esc", "Back"),
    ]
    
    text = Text()
    text.append("└─ ", style="bright_black")
    for i, (key, label) in enumerate(hints):
        if i > 0:
            text.append("  ", style="bright_black")
        text.append(f"[{key}]", style="bright_cyan")
        text.append(f" {label}", style="dim")
    
    # Pad to width
    current_len = len(text.plain)
