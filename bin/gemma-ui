def _deep_merge(base: dict, overlay: dict) -> dict:
    """Deep merge overlay into base, preserving base structure."""
    result = base.copy()
    for key, value in overlay.items():
        if key in result and isinstance(result[key], dict) and isinstance(value, dict):
            result[key] = _deep_merge(result[key], value)
        else:
            result[key] = value
    return result


def load_config() -> dict:
    """Load gemma-ui config with backfill of missing keys.

    Preserves user-set values. Adds missing keys from DEFAULT_CONFIG.
    If file is missing or invalid, returns full defaults.
    """
    if not CONFIG_FILE.is_file():
        merged = DEFAULT_CONFIG.copy()
    else:
        try:
            with open(CONFIG_FILE) as f:
                stored = json.load(f)
            # Deep merge: defaults as base, user values overlay on top
            merged = _deep_merge(DEFAULT_CONFIG, stored)
        except (json.JSONDecodeError, IOError):
            console.print("[yellow]Warning: config file unreadable, using defaults.[/]")
            merged = DEFAULT_CONFIG.copy()
            
    if _FORCE_CLASSIC:
        if "ui" not in merged:
            merged["ui"] = {}
        merged["ui"]["layout"] = "classic"
        
    return merged


def validate_config(config: dict) -> List[str]:
    """Validate config and return list of warning strings."""
    warnings = []

    # Check for disabled unsafe features
    features = config.get("features", {})
    if features.get("web_ui"):
        warnings.append("features.web_ui is enabled but not supported in this version")
    if features.get("livekit"):
        warnings.append("features.livekit is enabled but not supported in this version")

    # Check voice settings
    voice = config.get("voice", {})
    duration = voice.get("duration_seconds", 6)
    if not isinstance(duration, int) or duration < 1 or duration > 30:
        warnings.append(f"voice.duration_seconds ({duration}) out of range 1-30, using 6")
        voice["duration_seconds"] = 6

    # Check types
    for key, expected in (
        ("show_icons", bool),
        ("show_timestamps", bool),
        ("compact_mode", bool),
        ("confirm_tools", bool),
        ("confirm_sudo_tools", bool),
    ):
        if key in config and not isinstance(config[key], expected):
            warnings.append(f"{key} should be {expected.__name__}, got {type(config[key]).__name__}")

    return warnings


def save_config(config: dict):
    """Save gemma-ui config."""
    CONFIG_FILE.parent.mkdir(parents=True, exist_ok=True)
    try:
        with open(CONFIG_FILE, "w") as f:
            json.dump(config, f, indent=2)
    except IOError:
        console.print(f"[red]Error: could not write config to {CONFIG_FILE}[/]")


def load_integrations() -> dict:
    """Load integration metadata config if present.

    Returns empty dict if file missing or unreadable.
    This is display-only — no enforcement occurs from this file.
    """
    if not INTEGRATIONS_FILE.is_file():
        return {}
    try:
        with open(INTEGRATIONS_FILE) as f:
            return json.load(f)
    except (json.JSONDecodeError, IOError):
        return {}


def print_config():
    """Print current config in a readable format."""
    config = load_config()
    console.print("[bright_yellow bold]gemma-ui Configuration[/]")
    console.print()
    console.print(json.dumps(config, indent=2))
    console.print()


def check_config():
    """Validate config and print results."""
    config = load_config()
    warnings = validate_config(config)

    console.print("[bright_yellow bold]Config Check[/]")
    console.print()

    if warnings:
        for w in warnings:
            console.print(f"[yellow]⚠ {w}[/]")
    else:
        console.print("[green]✓ Config is valid[/]")

    console.print()
    console.print(f"[dim]Config file:[/] {CONFIG_FILE}")
    console.print(f"[dim]Version:[/]    {config.get('version', 'unknown')}")
    console.print()

    # Show feature flags
    features = config.get("features", {})
    console.print("[bright_cyan]Feature Flags:[/]")
    for name, enabled in sorted(features.items()):
        status = "[green]✓[/]" if enabled else "[red]✗[/]"
        console.print(f"  {status} {name}")
    console.print()

    # Show voice settings
    voice = config.get("voice", {})
    console.print("[bright_cyan]Voice Settings:[/]")
    for name, value in sorted(voice.items()):
        console.print(f"  {name}: {value}")
    console.print()


def print_integration_status():
    """Print integration metadata status — display-only, no enforcement."""
    integrations = load_integrations()

    console.print("[bright_yellow bold]🔗 Integration Metadata[/]")
    console.print()

    if not integrations:
        console.print("  [dim]Integration metadata not configured.[/]")
        console.print("  [dim]File:[/] {0}".format(INTEGRATIONS_FILE))
        console.print()
        console.print("[dim]Integration metadata is display-only. No enforcement occurs.[/]")
        return

    # Overall status
    status = integrations.get("status", "unknown")
    console.print("  [bright_cyan]Status:[/]       {0}".format(status))
    console.print("  [bright_cyan]Version:[/]      {0}".format(integrations.get("version", "unknown")))
    console.print()

    # bazzite-laptop section
    bl = integrations.get("bazzite_laptop", {})
    if bl:
        console.print("  [bright_cyan bold]bazzite-laptop[/]")
        console.print("  [bright_cyan]  Role:[/]         {0}".format(bl.get("role", "unknown")))
        console.print("  [bright_cyan]  Import status:[/] {0}".format(bl.get("config_import_status", "unknown")))
        console.print("  [bright_cyan]  Display-only:[/]  {0}".format("yes" if bl.get("display_only") else "no"))
        console.print("  [bright_cyan]  MCP routing:[/]   {0}".format("enabled" if bl.get("mcp_routing_enabled") else "disabled"))
        console.print()

        # Allowed display files
        allowed = bl.get("allowed_display_files", {})
        if allowed:
            console.print("  [bright_cyan]  Allowed display files:[/]")
            for name, path_tpl in allowed.items():
                path = Path(path_tpl.replace("~", str(HOME))).expanduser()
                exists = "[green]present[/]" if path.is_file() else "[yellow]missing[/]"
                console.print("    {0}: {1} ({2})".format(name, path_tpl, exists))
            console.print()

        # Forbidden list
        forbidden = bl.get("forbidden", [])
        if forbidden:
            console.print("  [bright_cyan]  Forbidden imports:[/]")
            for item in forbidden:
                console.print("    [red]✗[/] {0}".format(item))
            console.print()

    console.print("[dim]Integration metadata is display-only.[/]")
    console.print("[dim]bazzite-laptop remains legacy/reference only.[/]")
    console.print("[dim]No config import has been performed.[/]")
    console.print("[dim]MCP routing remains disabled.[/]")
    console.print()


# ── System Status ────────────────────────────────────────────────────────────

def get_ollama_status() -> tuple:
    """Return (status_str, color, detail) for Ollama."""
    try:
        req = urllib.request.Request(f"{OLLAMA_HOST}/api/tags", method="GET")
        with urllib.request.urlopen(req, timeout=3) as resp:
            data = json.loads(resp.read())
            models = data.get("models", [])
            count = len(models)
            return ("online", "bright_green", f"{count} models")
    except Exception:
        return ("offline", "bright_red", "unreachable")


def get_tool_summary(detected: Dict[str, bool]) -> str:
    """Return brief tool availability summary."""
    available = sum(1 for v in detected.values() if v)
    total = len(HELPERS)
    return f"{available}/{total}"


def get_voice_status(detected: Dict[str, bool]) -> tuple:
    """Return (status_str, color)."""
    if detected.get("gemma-voice-chat"):
        return ("ready", "bright_green")
    return ("not configured", "dim")


def get_memory_status(detected: Dict[str, bool]) -> tuple:
    """Return (status_str, color)."""
    if detected.get("gemma-memory-search"):
        return ("RuVector ready", "bright_green")
    elif detected.get("gemma-knowledge-search"):
        return ("Stage 3A only", "bright_yellow")
    return ("not configured", "dim")


# ── Welcome Screen ───────────────────────────────────────────────────────────

def print_welcome_screen(detected: Dict[str, bool]):
    """Print polished welcome screen."""
    config = load_config()
    
    if config.get("ui", {}).get("layout", "classic") == "app_shell":
        render_app_shell(detected, config, "welcome")
        return
        
    ollama_status, ollama_color, ollama_detail = get_ollama_status()
    voice_status, voice_color = get_voice_status(detected)
    mem_status, mem_color = get_memory_status(detected)
    tool_summary = get_tool_summary(detected)

    # Build status lines
    status_lines = [
        f"[bright_cyan]Model:[/]     [bright_white]{MODEL}[/]",
        f"[bright_cyan]Ollama:[/]    [{ollama_color}]{ollama_status}[/{ollama_color}]  [dim]({ollama_detail})[/]",
        f"[bright_cyan]Tools:[/]      [bright_white]{tool_summary}[/] available",
        f"[bright_cyan]Memory:[/]    [{mem_color}]{mem_status}[/{mem_color}]",
        f"[bright_cyan]Voice:[/]     [{voice_color}]{voice_status}[/{voice_color}]",
        "",
        "[dim]Local  ·  Advisory  ·  Human-confirmed tools[/]",
    ]

    # Compact welcome panel
    welcome_text = "\n".join([
        "[bright_yellow bold]Gem[/][bright_white bold]ma[/] [bright_yellow bold]Local Agent[/]",
        "[dim]Bazzite assistant — terminal UI[/]",
        "",
    ] + status_lines)

    console.print(Panel(
        welcome_text,
        border_style="bright_cyan",
        padding=(1, 2),
        title="[bright_black]Bazzite Local AI Operations Stack[/]",
        title_align="left",
    ))
    console.print()


# ── Status Bar ───────────────────────────────────────────────────────────────

def print_status_bar(detected: Dict[str, bool], current_mode: str = "welcome"):
    """Print compact top status bar."""
    ollama_status, ollama_color, _ = get_ollama_status()
    voice_status, voice_color = get_voice_status(detected)
    mem_status, mem_color = get_memory_status(detected)
    tool_summary = get_tool_summary(detected)

    parts = [
        f"[dim]mode[/] [bright_cyan]{current_mode}[/]",
        f"[dim]ollama[/] [{ollama_color}]{ollama_status}[/]",
        f"[dim]tools[/] [bright_white]{tool_summary}[/]",
        f"[dim]mem[/] [{mem_color}]{mem_status.split()[0]}[/]",
        f"[dim]voice[/] [{voice_color}]{voice_status}[/]",
    ]
    bar = "  [bright_black]|[/]  ".join(parts)
    console.print(f"[bright_black]─[/] {bar} [bright_black]─[/]")
    console.print()


# ── Mode Selector ────────────────────────────────────────────────────────────

def print_mode_selector(detected: Dict[str, bool]):
    """Print numbered mode selector."""
    modes = [
        ("1", "general",  "💬", "General Chat",              "gemma-bazzite",       "Chat with local Gemma"),
        ("2", "security", "🛡️", "Security Console",          "gemma-security-chat", "Run security tools & analysis"),
        ("3", "memory",   "🧠", "Memory / RuVector",         "gemma-memory-search", "Semantic search & RAG"),
        ("4", "repo",     "📁", "Repo Mode",                 "gemma-repo-brief",    "Repo summaries"),
        ("5", "voice",    "🎙️", "Voice",                     "gemma-voice-chat",    "Voice chat (type r to record)"),
        ("6", "reports",  "📊", "Reports",                   None,                  "Browse generated reports"),
        ("7", "health",   "🏥", "Health Check",              "gemma-bazzite-health", "Safe status checks"),
    ]

    table = Table(
        show_header=True,
        header_style="bright_magenta bold",
        border_style="bright_black",
        expand=False,
        box=None,
        padding=(0, 1),
    )
    table.add_column("", style="bright_black", width=3, justify="right")
    table.add_column("Mode", style="bright_cyan bold", width=18)
    table.add_column("", style="", width=3)
    table.add_column("Description", style="dim")
    table.add_column("Status", style="", width=14, justify="right")

    for num, key, icon, name, helper_name, desc in modes:
        if helper_name:
            if helper_name in HELPERS and detected.get(helper_name):
                status = "[green]ready[/]"
            elif helper_name in HELPERS:
                status = "[dim]not configured[/]"
            else:
                status = "[dim]built-in[/]"
        else:
            status = "[dim]built-in[/]"
        table.add_row(f"[{num}]", name, icon, desc, status)

    console.print(table)
    console.print()


# ── Footer ───────────────────────────────────────────────────────────────────

def print_footer():
    """Print consistent footer hint."""
    console.print("[bright_black]─[/] [dim]/help[/]  [dim]/mode[/]  [dim]/back[/]  [dim]/quit[/] [bright_black]─[/]")
    console.print()


# ── Transcript Output ────────────────────────────────────────────────────────

def print_user_message(text: str, config: dict = None):
    """Print a user message in transcript style."""
    if config is None:
        config = load_config()
    ts = ""
    if config.get("show_timestamps", True):
        ts = f"[dim]{datetime.now().strftime('%H:%M:%S')}[/] "
    console.print(Panel(
        f"{ts}[bright_cyan bold]You[/]\n{text}",
        border_style="bright_cyan",
        padding=(0, 1),
    ))


def print_gemma_message(text: str, config: dict = None):
    """Print a Gemma message in transcript style."""
    if config is None:
        config = load_config()
    ts = ""
    if config.get("show_timestamps", True):
        ts = f"[dim]{datetime.now().strftime('%H:%M:%S')}[/] "
    console.print(Panel(
        f"{ts}[bright_green bold]Gemma[/]\n{text}",
        border_style="bright_green",
        padding=(0, 1),
    ))


def print_tool_suggestion(tool_name: str, description: str, risk: str = RISK_SAFE):
    """Print a tool suggestion with risk label."""
    risk_style = "dim green"
    if risk == RISK_CONFIRM:
        risk_style = "dim yellow"
    elif risk == RISK_SUDO:
        risk_style = "dim bright_red"
    console.print(Panel(
        f"[bright_yellow bold]Tool Suggestion:[/] [cyan]{tool_name}[/]\n"
        f"[dim]{description}[/]\n"
        f"[{risk_style}]Risk: {risk}[/{risk_style}]",
        border_style="bright_yellow",
        padding=(0, 1),
    ))


def print_tool_result(tool_name: str, output: str, success: bool = True):
    """Print a tool result in transcript style."""
    status_color = "bright_green" if success else "bright_red"
    status_text = "success" if success else "failed"
    console.print(Panel(
        f"[bright_yellow bold]{tool_name}[/]  [{status_color}]{status_text}[/{status_color}]\n"
        f"[dim]{output[:500]}{'...' if len(output) > 500 else ''}[/]",
        border_style="bright_yellow",
        padding=(0, 1),
    ))


def print_error_panel(message: str):
    """Print a clear error panel."""
    console.print(Panel(
        f"[bright_red bold]Error[/]\n{message}",
        border_style="bright_red",
        padding=(0, 1),
    ))


def print_info_panel(message: str):
    """Print an info panel."""
    console.print(Panel(
        f"[bright_blue bold]Info[/]\n{message}",
        border_style="bright_blue",
        padding=(0, 1),
    ))


# ── App Shell Layout ─────────────────────────────────────────────────────────

def render_top_bar(detected: Dict[str, bool], config: dict):
    """Render compact single-line status bar."""
    ollama_status, ollama_color, _ = get_ollama_status()
    voice_status, voice_color = get_voice_status(detected)
    mem_status, mem_color = get_memory_status(detected)
    tool_summary = get_tool_summary(detected)
    
    model_name = config.get("ollama", {}).get("model", MODEL)
    
    parts = [
        f"[bright_cyan bold]Gemma[/]",
        f"[dim]model[/] [bright_white]{model_name}[/]",
        f"[dim]ollama[/] [{ollama_color}]{ollama_status}[/]",
        f"[dim]mem[/] [{mem_color}]{mem_status.split()[0]}[/]",
        f"[dim]voice[/] [{voice_color}]{voice_status}[/]",
        f"[dim]tools[/] [bright_white]{tool_summary}[/]",
    ]
    
    console.print("  [bright_black]│[/]  ".join(parts))
    console.print(Rule(style="bright_black"))


def render_mode_rail(detected: Dict[str, bool], config: dict, current_mode: str):
    """Render horizontal mode list with selected marker."""
    modes = [
        ("general", "General", "Chat with local Gemma"),
        ("security", "Security", "Human-confirmed security tools"),
        ("memory", "Memory", "RuVector + Stage 3A"),
        ("repo", "Repo", "Repo/file briefings"),
        ("reports", "Reports", "Local report browser"),
        ("voice", "Voice", "Push-to-talk voice"),
        ("health", "Health", "Safe status checks"),
    ]
    
    rail_parts = []
    for mode_id, name, desc in modes:
        if mode_id == current_mode:
            rail_parts.append(f"[bright_cyan]◉ {name}[/]")
        else:
            rail_parts.append(f"[dim]◯ {name}[/]")
            
    console.print("  ".join(rail_parts))
    console.print(Rule(style="bright_black"))


def render_main_panel(content_lines: list[str]):
    """Render the main session/transcript area."""
    if not content_lines:
        return
        
    text = "\n".join(content_lines)
    console.print(Panel(
        text,
        border_style="bright_black",
        padding=(1, 2),
    ))


def render_footer(config: dict):
    """Render command hints line."""
    console.print("[dim]/help  /mode  /clear  /save  /quit[/]")
    console.print()


def render_app_shell(detected: Dict[str, bool], config: dict, current_mode: str = "welcome", show_footer: bool = True):
    """Render the full app shell layout."""
    console.clear()
    render_top_bar(detected, config)
    render_mode_rail(detected, config, current_mode)
    
    if current_mode == "welcome":
        content = [
            "[bright_white bold]Welcome to Gemma Local Agent[/]",
            "",
            "[dim]Select a mode from the rail above or type a command.[/]",
            "[dim]Type /help for a full list of commands.[/]"
        ]
        render_main_panel(content)
    
    if show_footer:
        render_footer(config)


# ── Polished App Shell Layout (Demo) ─────────────────────────────────────────

def _render_demo_top_bar(width: int, detected: Dict[str, bool]) -> Text:
    """Build a compact top status bar as Rich Text."""
    ollama_status, ollama_color, ollama_detail = get_ollama_status()
    voice_status, voice_color = get_voice_status(detected)
    mem_status, mem_color = get_memory_status(detected)
    tool_summary = get_tool_summary(detected)
    
    # Build chip-style status elements
    chips = []
    
    # App name chip
    chips.append(("Gemma", "bright_cyan bold"))
    
    # Model chip
    model_short = MODEL
    if len(model_short) > 12:
        model_short = model_short[:9] + "..."
    chips.append((f"model:{model_short}", "bright_white"))
    
    # Ollama chip with color
    chips.append((f"ollama:{ollama_status}", ollama_color))
    
    # Memory chip
    mem_short = mem_status.split()[0] if mem_status else "?"
    chips.append((f"mem:{mem_short}", mem_color))
    
    # Voice chip
    voice_short = voice_status if len(voice_status) <= 10 else voice_status[:7] + "..."
    chips.append((f"voice:{voice_short}", voice_color))
    
    # Tools chip
    chips.append((f"tools:{tool_summary}", "bright_white"))
    
    # Assemble into a single line with separators
    text = Text()
    text.append("┌─ ", style="bright_black")
    for i, (label, style) in enumerate(chips):
        if i > 0:
            text.append(" ─ ", style="bright_black")
        text.append(label, style=style)
    
    # Pad/truncate to width
    current_len = len(text.plain)
    if current_len < width - 2:
        text.append(" " * (width - 2 - current_len), style="bright_black")
    text.append("─┐", style="bright_black")
    
    return text


def _render_demo_mode_rail_vertical(current_mode: str, width: int) -> list[Text]:
    """Render a vertical left mode rail for wide terminals."""
    modes = [
        ("general", "General", "G"),
        ("security", "Security", "S"),
        ("memory", "Memory", "M"),
        ("repo", "Repo", "O"),
        ("reports", "Reports", "R"),
        ("voice", "Voice", "V"),
        ("health", "Health", "H"),
        ("settings", "Settings", "T"),
    ]
    
    lines = []
    # Header
    header = Text()
    header.append("│ ", style="bright_black")
    header.append("Modes", style="bright_cyan bold")
    lines.append(header)
    header2 = Text()
    header2.append("│ ", style="bright_black")
    header2.append("─────", style="bright_black")
    lines.append(header2)
    
    for mode_id, name, hotkey in modes:
        line = Text()
        line.append("│ ", style="bright_black")
        if mode_id == current_mode:
            line.append("> ", style="bright_cyan bold")
            line.append(f"[{hotkey}] {name}", style="bright_cyan bold")
        else:
            line.append("  ", style="bright_black")
            line.append(f"[{hotkey}] ", style="dim")
            line.append(name, style="dim")
        lines.append(line)
    
    # Quit hint
    quit_line = Text()
    quit_line.append("│ ", style="bright_black")
    quit_line.append("─────", style="bright_black")
    lines.append(quit_line)
    quit_line2 = Text()
    quit_line2.append("│ ", style="bright_black")
    quit_line2.append("[Q] Quit", style="dim")
    lines.append(quit_line2)
    
    return lines


def _render_demo_mode_rail_horizontal(current_mode: str) -> Text:
    """Render a compact horizontal mode rail for narrow terminals."""
    modes = [
        ("general", "G"),
        ("security", "S"),
        ("memory", "M"),
        ("repo", "O"),
        ("reports", "R"),
        ("voice", "V"),
        ("health", "H"),
    ]
    
    text = Text()
    text.append("│ ", style="bright_black")
    for i, (mode_id, hotkey) in enumerate(modes):
        if i > 0:
            text.append("  ", style="bright_black")
        if mode_id == current_mode:
            text.append(f"[{hotkey}]", style="bright_cyan bold")
            text.append(f"●", style="bright_cyan")
        else:
            text.append(f"[{hotkey}]", style="dim")
            text.append(f"○", style="dim")
    
    text.append("  [Q]", style="dim")
    return text


def _render_demo_main_panel(width: int) -> list[Text]:
    """Render a realistic demo transcript in the main panel."""
    lines = []
    
    # Session start marker
    start = Text()
    start.append("│ ", style="bright_black")
    start.append("[Session Start]", style="dim")
    lines.append(start)
    lines.append(Text("│", style="bright_black"))
    
    # Bot welcome
    bot1 = Text()
    bot1.append("│ ", style="bright_black")
    bot1.append("Bot: ", style="bright_green bold")
    bot1.append("Welcome back. How can I assist you today?", style="bright_white")
    lines.append(bot1)
    lines.append(Text("│", style="bright_black"))
    
    # User message
    user1 = Text()
    user1.append("│ ", style="bright_black")
    user1.append("You: ", style="bright_cyan bold")
    user1.append("Show me my system status.", style="bright_white")
    lines.append(user1)
    lines.append(Text("│", style="bright_black"))
    
    # Bot response (wrapped to fit)
    bot2 = Text()
    bot2.append("│ ", style="bright_black")
    bot2.append("Bot: ", style="bright_green bold")
    bot2.append("CPU: 15% | RAM: 62% | Disk: 34% | GPU: idle", style="bright_white")
    lines.append(bot2)
    lines.append(Text("│", style="bright_black"))
    
    # Tool suggestion
    tool = Text()
    tool.append("│ ", style="bright_black")
    tool.append("[Tool] ", style="bright_yellow")
    tool.append("gemma-bazzite-health", style="bright_yellow bold")
    tool.append(" — SAFE READ-ONLY", style="dim green")
    lines.append(tool)
    lines.append(Text("│", style="bright_black"))
    
    # Input prompt
    prompt = Text()
    prompt.append("│ ", style="bright_black")
    prompt.append("> ", style="bright_cyan bold")
    prompt.append("Type a message or /command...", style="dim")
    lines.append(prompt)
    
    return lines


def _render_demo_footer(width: int) -> Text:
    """Render a contextual help footer."""
    hints = [
        ("?", "Help"),
        ("/", "Command"),
        ("Tab", "Switch"),
        ("Esc", "Back"),
    ]
    
    text = Text()
    text.append("└─ ", style="bright_black")
    for i, (key, label) in enumerate(hints):
        if i > 0:
            text.append("  ", style="bright_black")
        text.append(f"[{key}]", style="bright_cyan")
        text.append(f" {label}", style="dim")
    
    # Pad to width
    current_len = len(text.plain)
    if current_len < width - 1:
        text.append(" " * (width - 1 - current_len), style="bright_black")
    text.append("┘", style="bright_black")
    
    return text


def render_demo_app_shell(detected: Dict[str, bool], current_mode: str = "general"):
    """Render a polished non-interactive app-shell mockup.

    This is a static preview that shows the layout design without
    calling Ollama or running any tools. It adapts to terminal width:
    - Wide (>=100): vertical left rail + main panel side by side
    - Narrow (<100): horizontal rail stacked above main panel
    """
    console.clear()
    
    try:
        term_width = console.size.width
        term_height = console.size.height
    except Exception:
        term_width = 80
        term_height = 24
    
    # Ensure minimum dimensions
    width = max(term_width, 40)
    
    # ── Top Bar ──────────────────────────────────────────────────────────────
    top_bar = _render_demo_top_bar(width, detected)
    console.print(top_bar)
    
    # ── Mode Rail ────────────────────────────────────────────────────────────
    if width >= 100:
        # Wide layout: vertical rail on left, main panel to the right
        rail_lines = _render_demo_mode_rail_vertical(current_mode, width)
        main_lines = _render_demo_main_panel(width - 20)
        
        # Combine rail and main side by side
        max_lines = max(len(rail_lines), len(main_lines))
        for i in range(max_lines):
            combined = Text()
            
            # Left rail
            if i < len(rail_lines):
                combined.append(rail_lines[i])
                # Pad rail to consistent width (18 chars)
                rail_plain = rail_lines[i].plain
                if len(rail_plain) < 18:
                    combined.append(" " * (18 - len(rail_plain)), style="bright_black")
            else:
                combined.append(" " * 18, style="bright_black")
            
            # Divider
            combined.append("│ ", style="bright_black")
            
            # Main panel
            if i < len(main_lines):
                combined.append(main_lines[i])
                # Pad main to fill remaining width
                main_plain = main_lines[i].plain
                remaining = width - 18 - 2 - len(main_plain)
                if remaining > 0:
                    combined.append(" " * remaining, style="bright_black")
            else:
                remaining = width - 18 - 2
                if remaining > 0:
                    combined.append(" " * remaining, style="bright_black")
            
            combined.append("│", style="bright_black")
            console.print(combined)
    else:
        # Narrow layout: horizontal rail, then main panel
        console.print(_render_demo_mode_rail_horizontal(current_mode))
        console.print(Text("├" + "─" * (width - 2) + "┤", style="bright_black"))
        
        main_lines = _render_demo_main_panel(width)
        for line in main_lines:
            # Pad each line to width
            combined = Text()
            combined.append(line)
            line_plain = line.plain
            if len(line_plain) < width - 1:
                combined.append(" " * (width - 1 - len(line_plain)), style="bright_black")
            combined.append("│", style="bright_black")
            console.print(combined)
    
    # ── Footer ───────────────────────────────────────────────────────────────
    console.print(_render_demo_footer(width))
    console.print()


def demo_layout():
    """Render the polished layout mockup without running any tools."""
    detected = detect_helpers()
    render_demo_app_shell(detected, current_mode="general")


# ── Intent Router ────────────────────────────────────────────────────────────

ROUTE_KEYWORDS = {
    "security": [
        "firewall", "security", "usb", "rootkit", "audit", "clamav", "lynis",
        "scan", "threat", "intrusion", "malware", "check firewall",
        "check security", "security tools", "usbguard", "selinux",
    ],
    "memory": [
        "memory ask", "search memory", "memory search", "compare memory",
        "deterministic memory", "stage 3a", "stage three a",
        "memory", "remember", "what did we decide", "recall", "past decision",
    ],
    "reports": [
        "show reports", "recent reports", "open report", "list reports",
    ],
    "repo": [
        "repo ", "repository", "git status", "codebase", "project brief",
        "repo gem", "repo bazzite", "repo status",
    ],
    "health": [
        "health", "system health", "status check", "check system",
        "system status", "health check",
    ],
}


def route_intent(text: str) -> Tuple[str, str, str]:
    """Route voice/text transcript to the appropriate gemma-ui mode.

    Returns (mode, subcmd, reason) where mode is one of:
    general, security, memory, repo, reports, health.

    subcmd is the extracted subcommand for memory routing
    (e.g. "ask what did we decide about RuVector").

    Deterministic keyword matching — no model inference.
    Security routing does NOT execute tools; it hands off to the
    existing confirmation flow in gemma-security-chat.
    """
    lowered = text.lower().strip()

    for mode, keywords in ROUTE_KEYWORDS.items():
        for kw in keywords:
            if kw in lowered:
                # Extract subcommand for memory mode
                subcmd = ""
                if mode == "memory":
                    idx = lowered.find(kw)
                    subcmd = text[idx + len(kw):].strip()
                    # Normalize subcommand prefix
                    prefix_map = {
                        "memory ask": "ask",
                        "search memory": "search",
                        "memory search": "search",
                        "compare memory": "compare",
                        "deterministic memory": "stage3a",
                        "stage 3a": "stage3a",
                        "stage three a": "stage3a",
                    }
                    if kw in prefix_map:
                        prefix = prefix_map[kw]
                        subcmd = prefix + (" " + subcmd if subcmd else "")
                return mode, subcmd, f"matched keyword '{kw}'"

    return "general", "", "no keyword matched (fallback)"


