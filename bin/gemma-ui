# ── Reports ──────────────────────────────────────────────────────────────────

def print_reports():
    """List recent reports."""
    if not REPORT_DIR.is_dir():
        print_error_panel(f"Report directory not found:\n{REPORT_DIR}")
        return

    reports = sorted(REPORT_DIR.glob("*.md"), key=lambda p: p.stat().st_mtime, reverse=True)

    if not reports:
        print_info_panel("No reports found.")
        return

    table = Table(
        show_header=True,
        header_style="bright_magenta bold",
        border_style="bright_black",
        expand=False,
        box=None,
        padding=(0, 1),
    )
    table.add_column("#", style="dim", width=3, justify="right")
    table.add_column("Report", style="bright_cyan")
    table.add_column("Size", style="dim", width=10, justify="right")
    table.add_column("Date", style="dim", width=16)

    for i, report in enumerate(reports[:15], 1):
        size = report.stat().st_size
        size_str = f"{size / 1024:.1f} KB" if size > 1024 else f"{size} B"
        mtime = datetime.fromtimestamp(report.stat().st_mtime).strftime("%Y-%m-%d %H:%M")
        table.add_row(str(i), report.name, size_str, mtime)

    console.print(table)
    console.print(f"[dim]Total: {len(reports)} reports in {REPORT_DIR}[/]")


# ── Tools Display ────────────────────────────────────────────────────────────

def print_tools():
    """List tools by category with risk labels."""
    categories = {
        "General": ["gemma-bazzite"],
        "Security": ["gemma-security-chat", "gemma-security-analyzer", "gemma-command-review"],
        "Memory": ["gemma-memory-search", "gemma-memory-rag", "gemma-knowledge-search", "gemma-knowledge-rag"],
        "Repo": ["gemma-repo-brief", "gemma-file-brief"],
        "Voice": ["gemma-voice-chat"],
        "Diagnostics": ["gemma-bazzite-health", "gemma-monitor-daily", "gemma-monitor-drift"],
        "Export": ["gemma-dashboard"],
    }

    detected = detect_helpers()

    for cat, names in categories.items():
        console.print(f"\n[bright_magenta bold]{cat}[/]")
        for name in names:
            if name in HELPERS:
                status = "[green]✓[/]" if detected.get(name) else "[red]✗[/]"
                risk_label = helper_risk_label(name)
                avail = "[green]ready[/]" if detected.get(name) else "[dim]not configured[/]"
                console.print(f"  {status} [cyan]{name:<30}[/] {HELPERS[name]['description']:<45} {risk_label}  {avail}")


# ── Mode Handlers ────────────────────────────────────────────────────────────

def mode_general(message: Optional[str] = None):
    """General chat mode — delegates to gemma-bazzite or Ollama."""
    global _CURRENT_MODE
    _CURRENT_MODE = "general"
    config = load_config()

    if not HELPERS["gemma-bazzite"]["path"].is_file():
        print_error_panel(
            "gemma-bazzite not found.\n"
            "Falling back to direct Ollama API."
        )
        if message:
            subprocess.run(["ollama", "run", MODEL, "--hidethinking", message])
        else:
            print_info_panel(f"Start interactive chat with: ollama run {MODEL}")
        return

    if message:
        print_user_message(message, config)
        subprocess.run([str(HELPERS["gemma-bazzite"]["path"]), message])
    else:
        print_info_panel("Starting Gemma general chat...\nType your message. Use Ctrl+D or /quit to exit.")
        console.print()
        subprocess.run([str(HELPERS["gemma-bazzite"]["path"])])


def mode_security():
    """Security mode — delegates to gemma-security-chat."""
    global _CURRENT_MODE
    _CURRENT_MODE = "security"

    if not HELPERS["gemma-security-chat"]["path"].is_file():
        print_error_panel(
            "gemma-security-chat not configured.\n"
            "Install it to use security tools."
        )
        return

    print_info_panel("Starting Gemma Security Console...\nThis is an interactive security tool interface.")
    console.print()
    subprocess.run([str(HELPERS["gemma-security-chat"]["path"])])


def _memory_run_helper(helper_name: str, query: str):
    """Run a memory helper safely with subprocess argument array."""
    if not HELPERS[helper_name]["path"].is_file():
        print_error_panel(f"{helper_name} not configured.")
        return
    subprocess.run([str(HELPERS[helper_name]["path"]), query])


def mode_memory(subcmd: str = ""):
    """Memory mode — explicit supervised RuVector with Stage 3A fallback.

    RuVector memory mode is explicit and supervised.
    RuVector is not the default retrieval path.
    Stage 3A deterministic retrieval remains the canonical fallback.
    Memory mode performs read-only retrieval/RAG only.
    Memory mode does not ingest new data, train the model, mutate repos,
    or execute remediation.
    """
    global _CURRENT_MODE
    _CURRENT_MODE = "memory"
    detected = detect_helpers()

    sub = subcmd.strip().lower()

    if sub in ("status", "st"):
        print_memory_status(detected)

    elif sub in ("dashboard", "quality", "db", "q"):
        print_memory_dashboard()

    elif sub.startswith("search "):
        query = sub[len("search "):].strip()
        if query:
            console.print("[bright_cyan]RuVector search (supervised, explicit):[/]")
            _memory_run_helper("gemma-memory-search", query)
        else:
            print_error_panel("Empty query. Usage: /memory search <query>")

    elif sub.startswith("ask "):
        query = sub[len("ask "):].strip()
        if query:
            console.print("[bright_cyan]RuVector RAG (supervised, explicit):[/]")
            _memory_run_helper("gemma-memory-rag", query)
        else:
            print_error_panel("Empty question. Usage: /memory ask <question>")

    elif sub.startswith("stage3a "):
        query = sub[len("stage3a "):].strip()
        if query:
            console.print("[bright_cyan]Stage 3A deterministic fallback:[/]")
            _memory_run_helper("gemma-knowledge-rag", query)
        else:
            print_error_panel("Empty question. Usage: /memory stage3a <question>")

    elif sub.startswith("compare "):
        query = sub[len("compare "):].strip()
        if query:
            print_memory_compare(query)
        else:
            print_error_panel("Empty question. Usage: /memory compare <question>")

    elif sub in ("help", "h", "?"):
        print_memory_help()

    else:
        # Default: show status and prompt
        print_memory_status(detected)
        console.print()
        print_memory_help()


def print_memory_status(detected: Dict[str, bool]):
    """Print memory mode status panel."""
    console.print("[bright_yellow bold]🧠 Memory Mode Status[/]")
    console.print()

    table = Table(show_header=False, box=None, padding=(0, 2))
    table.add_column("Source", style="bright_cyan")
    table.add_column("Status", style="")

    # RuVector helpers
    table.add_row("gemma-memory-search", "[green]✓[/] available" if detected.get("gemma-memory-search") else "[yellow]⚠[/] not found")
    table.add_row("gemma-memory-rag", "[green]✓[/] available" if detected.get("gemma-memory-rag") else "[yellow]⚠[/] not found")

    # Stage 3A helpers
    table.add_row("gemma-knowledge-search", "[green]✓[/] available" if detected.get("gemma-knowledge-search") else "[yellow]⚠[/] not found")
    table.add_row("gemma-knowledge-rag", "[green]✓[/] available" if detected.get("gemma-knowledge-rag") else "[yellow]⚠[/] not found")

    console.print(table)
    console.print()

    # Status text
    console.print("[bright_cyan]RuVector:[/]       [dim]supervised secondary only[/]")
    console.print("[bright_cyan]Stage 3A:[/]       [dim]canonical fallback[/]")
    console.print("[bright_cyan]Behavior:[/]       [dim]read-only retrieval/RAG only[/]")
    console.print("[bright_cyan]Ingestion:[/]      [dim]not performed[/]")
    console.print()

    # Index path
    ruvector_index = HOME / ".local/share/bazzite-security/ruvector/semantic-prototype/semantic-approved-docs-memory.json"
    stage3a_index = HOME / ".local/share/bazzite-security/gemma-knowledge/index/chunks.jsonl"
    console.print("[bright_cyan]Index Paths:[/]")
    console.print(f"  RuVector:  {'[green]✓[/] ' + str(ruvector_index) if ruvector_index.is_file() else '[yellow]⚠[/] not found'}")
    console.print(f"  Stage 3A:  {'[green]✓[/] ' + str(stage3a_index) if stage3a_index.is_file() else '[yellow]⚠[/] not found'}")
    console.print()

    # Manifest status (read-only, check multiple paths)
    def _find_latest_manifest(base_dir: Path, pattern: str) -> Optional[Path]:
        if not base_dir.is_dir():
            return None
        matches = sorted(base_dir.glob(pattern), key=lambda p: p.stat().st_mtime, reverse=True)
        return matches[0] if matches else None

    rv_manifest = _find_latest_manifest(
        HOME / ".local/share/bazzite-security/ruvector/semantic-prototype", "semantic-manifest-*.json"
    )
    if not rv_manifest:
        rv_manifest = _find_latest_manifest(
            HOME / ".local/share/bazzite-security/ruvector", "manifest-*.json"
        )
    s3_manifest = _find_latest_manifest(
        HOME / ".local/share/bazzite-security/gemma-knowledge/manifests", "gemma-knowledge-manifest-*.txt"
    )

    console.print("[bright_cyan]Manifests:[/]")
    if rv_manifest and rv_manifest.is_file():
        console.print(f"  RuVector:  [green]✓[/] {rv_manifest}")
    else:
        console.print("  RuVector:  [yellow]⚠[/] not found — run supervised refresh if needed")
    if s3_manifest and s3_manifest.is_file():
        console.print(f"  Stage 3A:  [green]✓[/] {s3_manifest}")
    else:
        console.print("  Stage 3A:  [yellow]⚠[/] not found — run supervised refresh if needed")
    console.print()


def print_memory_help():
    """Print memory mode help."""
    console.print("[bright_yellow bold]🧠 Memory Mode Commands[/]")
    console.print()
    console.print("[bright_cyan]/memory status[/]          Show memory mode status")
    console.print("[bright_cyan]/memory dashboard[/]       Show memory quality dashboard")
    console.print("[bright_cyan]/memory quality[/]         Alias for dashboard")
    console.print("[bright_cyan]/memory search <query>[/]   RuVector semantic search (supervised)")
    console.print("[bright_cyan]/memory ask <question>[/]   RuVector RAG with Ollama (supervised)")
    console.print("[bright_cyan]/memory stage3a <q>[/]     Stage 3A deterministic fallback")
    console.print("[bright_cyan]/memory compare <q>[/]     Run both and summarize differences")
    console.print("[bright_cyan]/memory help[/]            Show this help")
    console.print()
    console.print("[dim]RuVector is the supervised secondary source.[/]")
    console.print("[dim]Stage 3A is the canonical deterministic fallback.[/]")
    console.print("[dim]No ingestion. No training. No repo mutation.[/]")


def print_memory_compare(query: str):
    """Run both RuVector RAG and Stage 3A RAG, then summarize."""
    console.print("[bright_yellow bold]🧠 Memory Comparison[/]")
    console.print()
    console.print(f"[dim]Query:[/] {query}")
    console.print()

    detected = detect_helpers()

    # Run RuVector RAG
    ruvector_available = detected.get("gemma-memory-rag")
    stage3a_available = detected.get("gemma-knowledge-rag")

    if not ruvector_available and not stage3a_available:
        print_error_panel("Neither RuVector nor Stage 3A RAG is available.")
        return

    if ruvector_available:
        console.print("[bright_cyan]─ RuVector RAG ─[/]")
        _memory_run_helper("gemma-memory-rag", query)
        console.print()

    if stage3a_available:
        console.print("[bright_cyan]─ Stage 3A RAG ─[/]")
        _memory_run_helper("gemma-knowledge-rag", query)
        console.print()

    console.print("[bright_yellow]─ Comparison Summary ─[/]")
    console.print("  [dim]• RuVector found better semantic context when concepts are similar but wording differs.[/]")
    console.print("  [dim]• Stage 3A is more direct when keywords match exactly.[/]")
    console.print("  [dim]• Where they agree: high confidence.[/]")
    console.print("  [dim]• Missing evidence: check both sources independently.[/]")
    console.print()
    console.print("[dim]RuVector remains supervised secondary. Stage 3A remains canonical fallback.[/]")


def print_memory_dashboard():
    """Print read-only RuVector quality dashboard. No ingestion. No scans."""
    console.print("[bright_yellow bold]Memory Quality Dashboard[/]")
    console.print("[dim]Read-only. No ingestion. No default promotion.[/]")
    console.print()

    detected = detect_helpers()

    # ── Helpers ──────────────────────────────────────────────────────────────
    table = Table(show_header=False, box=None, padding=(0, 1))
    table.add_column("Item", style="bright_cyan")
    table.add_column("Status", style="")

    for name in ("gemma-memory-search", "gemma-memory-rag", "gemma-knowledge-search", "gemma-knowledge-rag"):
        ok = detected.get(name, False)
        table.add_row(name, "[green]OK[/] available" if ok else "[yellow]WARN[/] not found")

    # Index state
    ruvector_index = HOME / ".local/share/bazzite-security/ruvector/semantic-prototype/semantic-approved-docs-memory.json"
    stage3a_index = HOME / ".local/share/bazzite-security/gemma-knowledge/index/chunks.jsonl"

    if ruvector_index.is_file():
        rv_size = ruvector_index.stat().st_size
        rv_size_str = f"{rv_size / 1024 / 1024:.1f} MB" if rv_size > 1024 * 1024 else f"{rv_size / 1024:.1f} KB"
        table.add_row("RuVector index", f"[green]OK[/] {rv_size_str}")
    else:
        table.add_row("RuVector index", "[yellow]MISSING[/]")

    if stage3a_index.is_file():
        s3_size = stage3a_index.stat().st_size
        s3_size_str = f"{s3_size / 1024 / 1024:.1f} MB" if s3_size > 1024 * 1024 else f"{s3_size / 1024:.1f} KB"
        table.add_row("Stage 3A index", f"[green]OK[/] {s3_size_str}")
    else:
        table.add_row("Stage 3A index", "[yellow]MISSING[/]")

    # Policy
    table.add_row("RuVector role", "[yellow]supervised secondary[/]")
    table.add_row("Stage 3A role", "[green]canonical fallback[/]")

    console.print(table)
    console.print()

    # ── Recommendations ──────────────────────────────────────────────────────
    console.print("[bright_cyan]Recommendations:[/]")
    console.print("  [dim]RuVector: semantic recall (\"what did we decide...?\")[/]")
    console.print("  [dim]Stage 3A: exact lookup (\"show me the firewall rule...\")[/]")
    console.print("  [dim]Compare: run both when uncertain[/]")
    console.print()

    console.print("[dim]Read-only. No scans. No ingestion.[/]")


def mode_repo():
    """Repo brief mode — delegates to gemma-repo-brief."""
    global _CURRENT_MODE
    _CURRENT_MODE = "repo"

    if not HELPERS["gemma-repo-brief"]["path"].is_file():
        print_error_panel("gemma-repo-brief not configured.")
        return

    print_info_panel("Repo Brief Mode\nRead-only repo summaries. No edits.")
    console.print()

    # Detect available repos
    projects_dir = HOME / "projects"
    if projects_dir.is_dir():
        repos = [d for d in projects_dir.iterdir() if d.is_dir() and (d / ".git").is_dir()]
        if repos:
            console.print("[bright_cyan]Detected repos:[/]")
            for i, repo in enumerate(repos[:10], 1):
                console.print(f"  [green]{i}.[/] {repo.name}")
            console.print()

    try:
        repo_path = console.input("[bright_yellow]Enter repo path (or press Enter for ~/projects/gem): [/]").strip()
    except (EOFError, KeyboardInterrupt):
        console.print("[dim]Cancelled.[/]")
        return

    if not repo_path:
        repo_path = str(HOME / "projects/gem")

    repo_path = os.path.expanduser(repo_path)
    if not os.path.isdir(repo_path):
        print_error_panel(f"Not a directory: {repo_path}")
        return

    print_user_message(f"Repo brief: {repo_path}")
    subprocess.run([str(HELPERS["gemma-repo-brief"]["path"]), repo_path])


