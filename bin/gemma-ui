# ── Helper Detection ─────────────────────────────────────────────────────────

def detect_helpers() -> Dict[str, bool]:
    """Return dict of helper_name -> is_available."""
    return {name: info["path"].is_file() for name, info in HELPERS.items()}


def helper_status(name: str, use_unicode: bool = True) -> str:
    """Return colored status string for a helper."""
    info = HELPERS.get(name, {})
    if not info:
        return "[dim]unknown[/]"
    if info["path"].is_file():
        return "[bright_green]OK[/]" if not use_unicode else "[bright_green]✓[/]"
    return "[bright_red]MISSING[/]" if not use_unicode else "[bright_red]✗[/]"


def helper_risk_label(name: str) -> str:
    """Return styled risk label for a helper."""
    info = HELPERS.get(name, {})
    risk = info.get("risk", RISK_SAFE)
    if risk == RISK_SAFE:
        return "[dim green]SAFE[/]"
    elif risk == RISK_CONFIRM:
        return "[dim yellow]CONFIRM[/]"
    elif risk == RISK_SUDO:
        return "[dim bright_red]SUDO[/]"
    else:
        return "[dim]N/A[/]"


