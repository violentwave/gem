    console.print("[bright_cyan]/memory help[/]            Show this help")
    console.print()
    console.print("[dim]RuVector is the supervised secondary source.[/]")
    console.print("[dim]Stage 3A is the canonical deterministic fallback.[/]")
    console.print("[dim]No ingestion. No training. No repo mutation.[/]")


def print_memory_compare(query: str):
    """Run both RuVector RAG and Stage 3A RAG, then summarize."""
    console.print("[bright_yellow bold]🧠 Memory Comparison[/]")
    console.print()
    console.print(f"[dim]Query:[/] {query}")
    console.print()

    detected = detect_helpers()

    # Run RuVector RAG
    ruvector_available = detected.get("gemma-memory-rag")
    stage3a_available = detected.get("gemma-knowledge-rag")

    if not ruvector_available and not stage3a_available:
        print_error_panel("Neither RuVector nor Stage 3A RAG is available.")
        return

    if ruvector_available:
        console.print("[bright_cyan]─ RuVector RAG ─[/]")
        _memory_run_helper("gemma-memory-rag", query)
        console.print()

    if stage3a_available:
        console.print("[bright_cyan]─ Stage 3A RAG ─[/]")
        _memory_run_helper("gemma-knowledge-rag", query)
        console.print()

    console.print("[bright_yellow]─ Comparison Summary ─[/]")
    console.print("  [dim]• RuVector found better semantic context when concepts are similar but wording differs.[/]")
    console.print("  [dim]• Stage 3A is more direct when keywords match exactly.[/]")
    console.print("  [dim]• Where they agree: high confidence.[/]")
    console.print("  [dim]• Missing evidence: check both sources independently.[/]")
    console.print()
    console.print("[dim]RuVector remains supervised secondary. Stage 3A remains canonical fallback.[/]")


def print_memory_dashboard():
    """Print read-only RuVector quality dashboard. No ingestion. No scans."""
    console.print("[bright_yellow bold]🧠 Memory Quality Dashboard[/]")
    console.print("[dim]Read-only. No ingestion. No default promotion.[/]")
    console.print()

    detected = detect_helpers()

    # ── 1. Helper Availability ───────────────────────────────────────────────
    console.print("[bright_cyan bold]1. Helper Availability[/]")
    avail_table = Table(show_header=False, box=None, padding=(0, 2))
    avail_table.add_column("Helper", style="bright_cyan")
    avail_table.add_column("Status", style="")
    avail_table.add_column("Role", style="dim")

    helpers = [
        ("gemma-memory-search", "RuVector semantic search"),
        ("gemma-memory-rag", "RuVector RAG"),
        ("gemma-knowledge-search", "Stage 3A keyword search"),
        ("gemma-knowledge-rag", "Stage 3A RAG fallback"),
    ]
    for name, role in helpers:
        ok = detected.get(name, False)
        avail_table.add_row(
            name,
            "[green]✓[/] available" if ok else "[yellow]⚠[/] not found",
            role,
        )
    console.print(avail_table)
    console.print()

    # ── 2. Known Policy Status ───────────────────────────────────────────────
    console.print("[bright_cyan bold]2. Known Policy Status[/]")
    policy_table = Table(show_header=False, box=None, padding=(0, 2))
    policy_table.add_column("Source", style="bright_cyan")
    policy_table.add_column("Status", style="")
    policy_table.add_column("Note", style="dim")

    policy_table.add_row(
        "RuVector",
        "[yellow]supervised secondary[/]",
        "Explicit mode only. Not default.",
    )
    policy_table.add_row(
        "Stage 3A",
        "[green]canonical fallback[/]",
        "Deterministic retrieval. No embeddings.",
    )
    policy_table.add_row(
        "Promotion",
        "[red]denied / not default[/]",
        "RuVector remains supervised prototype.",
    )
    console.print(policy_table)
    console.print()

    # ── 3. Current Index State ───────────────────────────────────────────────
    console.print("[bright_cyan bold]3. Current Index State[/]")
    idx_table = Table(show_header=False, box=None, padding=(0, 2))
    idx_table.add_column("Index", style="bright_cyan")
    idx_table.add_column("Path", style="")
    idx_table.add_column("Size", style="")

    ruvector_index = HOME / ".local/share/bazzite-security/ruvector/semantic-prototype/semantic-approved-docs-memory.json"
    stage3a_index = HOME / ".local/share/bazzite-security/gemma-knowledge/index/chunks.jsonl"

    # RuVector index
    if ruvector_index.is_file():
        rv_size = ruvector_index.stat().st_size
        rv_size_str = f"{rv_size / 1024 / 1024:.1f} MB" if rv_size > 1024 * 1024 else f"{rv_size / 1024:.1f} KB"
        rv_mtime = datetime.fromtimestamp(ruvector_index.stat().st_mtime).strftime("%Y-%m-%d %H:%M")
        idx_table.add_row("RuVector", str(ruvector_index), f"[green]✓[/] {rv_size_str} (modified {rv_mtime})")
    else:
        idx_table.add_row("RuVector", str(ruvector_index), "[yellow]⚠[/] not found")

    # Stage 3A index
    if stage3a_index.is_file():
        s3_size = stage3a_index.stat().st_size
        s3_size_str = f"{s3_size / 1024 / 1024:.1f} MB" if s3_size > 1024 * 1024 else f"{s3_size / 1024:.1f} KB"
        line_count = 0
        try:
            with open(stage3a_index, "r", encoding="utf-8") as f:
                for _ in f:
                    line_count += 1
        except Exception:
            pass
        s3_mtime = datetime.fromtimestamp(stage3a_index.stat().st_mtime).strftime("%Y-%m-%d %H:%M")
        idx_table.add_row("Stage 3A", str(stage3a_index), f"[green]✓[/] {s3_size_str} ({line_count} chunks, modified {s3_mtime})")
    else:
        idx_table.add_row("Stage 3A", str(stage3a_index), "[yellow]⚠[/] not found")

    # Manifests — check multiple likely paths read-only
    def _find_latest_manifest(base_dir: Path, pattern: str) -> Optional[Path]:
        if not base_dir.is_dir():
            return None
        matches = sorted(base_dir.glob(pattern), key=lambda p: p.stat().st_mtime, reverse=True)
        return matches[0] if matches else None

    # RuVector manifest candidates
    rv_manifest = _find_latest_manifest(
        HOME / ".local/share/bazzite-security/ruvector/semantic-prototype", "semantic-manifest-*.json"
    )
    if not rv_manifest:
        rv_manifest = _find_latest_manifest(
            HOME / ".local/share/bazzite-security/ruvector", "manifest-*.json"
        )

    # Stage 3A manifest candidates
    s3_manifest = _find_latest_manifest(
        HOME / ".local/share/bazzite-security/gemma-knowledge/manifests", "gemma-knowledge-manifest-*.txt"
    )

    console.print(idx_table)
    console.print()

    # Manifest status table
    manifest_table = Table(show_header=False, box=None, padding=(0, 2))
    manifest_table.add_column("Manifest", style="bright_cyan")
    manifest_table.add_column("Path", style="")
    manifest_table.add_column("Status", style="")

    if rv_manifest and rv_manifest.is_file():
        rv_msize = rv_manifest.stat().st_size
        rv_msize_str = f"{rv_msize / 1024:.1f} KB"
        rv_mmtime = datetime.fromtimestamp(rv_manifest.stat().st_mtime).strftime("%Y-%m-%d %H:%M")
        manifest_table.add_row("RuVector", str(rv_manifest), f"[green]✓[/] {rv_msize_str} (modified {rv_mmtime})")
    else:
        note = "not found — index exists; run a supervised manifest refresh only if needed"
        manifest_table.add_row("RuVector", "—", f"[yellow]⚠[/] {note}")

    if s3_manifest and s3_manifest.is_file():
        s3_msize = s3_manifest.stat().st_size
        s3_msize_str = f"{s3_msize / 1024:.1f} KB"
        s3_mmtime = datetime.fromtimestamp(s3_manifest.stat().st_mtime).strftime("%Y-%m-%d %H:%M")
        manifest_table.add_row("Stage 3A", str(s3_manifest), f"[green]✓[/] {s3_msize_str} (modified {s3_mmtime})")
    else:
        note = "not found — index exists; run a supervised manifest refresh only if needed"
        manifest_table.add_row("Stage 3A", "—", f"[yellow]⚠[/] {note}")

    console.print(manifest_table)
    console.print()

    # ── 4. Recommended Use ───────────────────────────────────────────────────
    console.print("[bright_cyan bold]4. Recommended Use[/]")
    console.print("  [green]•[/] Use [bright_cyan]RuVector[/] for semantic recall questions.")
    console.print("    [dim]  Examples: \"what did we decide about...?\", \"how does X relate to Y?\"")
    console.print("  [green]•[/] Use [bright_cyan]Stage 3A[/] for exact path/policy/command questions.")
    console.print("    [dim]  Examples: \"what is the canonical path for...?\", \"show me the firewall rule...\"")
    console.print("  [green]•[/] Use [bright_cyan]compare mode[/] when uncertain.")
    console.print("    [dim]  Runs both and lets you evaluate side-by-side.")
    console.print()

    # ── 5. Warnings ──────────────────────────────────────────────────────────
    console.print("[bright_cyan bold]5. Warnings[/]")
    console.print("  [yellow]⚠[/] No ingestion in this mode.")
    console.print("  [yellow]⚠[/] No raw logs or transcripts displayed.")
    console.print("  [yellow]⚠[/] No default promotion. RuVector stays supervised.")
    console.print("  [yellow]⚠[/] Stage 3A fallback preserved.")
    console.print()

    console.print("[dim]Dashboard is read-only. No scans run. No system changes. No ingestion.[/]")


def mode_repo():
    """Repo brief mode — delegates to gemma-repo-brief."""
    global _CURRENT_MODE
    _CURRENT_MODE = "repo"

    if not HELPERS["gemma-repo-brief"]["path"].is_file():
        print_error_panel("gemma-repo-brief not configured.")
        return

    print_info_panel("Repo Brief Mode\nRead-only repo summaries. No edits.")
    console.print()

    # Detect available repos
    projects_dir = HOME / "projects"
    if projects_dir.is_dir():
        repos = [d for d in projects_dir.iterdir() if d.is_dir() and (d / ".git").is_dir()]
        if repos:
            console.print("[bright_cyan]Detected repos:[/]")
            for i, repo in enumerate(repos[:10], 1):
                console.print(f"  [green]{i}.[/] {repo.name}")
            console.print()

    try:
        repo_path = console.input("[bright_yellow]Enter repo path (or press Enter for ~/projects/gem): [/]").strip()
    except (EOFError, KeyboardInterrupt):
        console.print("[dim]Cancelled.[/]")
        return

    if not repo_path:
        repo_path = str(HOME / "projects/gem")

    repo_path = os.path.expanduser(repo_path)
    if not os.path.isdir(repo_path):
        print_error_panel(f"Not a directory: {repo_path}")
        return

    print_user_message(f"Repo brief: {repo_path}")
    subprocess.run([str(HELPERS["gemma-repo-brief"]["path"]), repo_path])


def print_voice_status():
    """Print voice component status panel."""
    detected = detect_helpers()

    if detected.get("gemma-voice-chat"):
        # Delegate to voice helper for detailed status
        subprocess.run([str(HELPERS["gemma-voice-chat"]["path"]), "--status"])
        return

    # Fallback status
    console.print("[bright_yellow bold]🎙️ Voice Mode Status[/]")
    console.print()
    console.print("  [red]✗[/] gemma-voice-chat not configured")
    console.print("  [dim]Run: gemma-voice-chat --setup[/]")


def mode_voice(subcmd: str = ""):
    """Voice mode — handle voice subcommands or launch session."""
    global _CURRENT_MODE
    _CURRENT_MODE = "voice"
    detected = detect_helpers()

    if not detected.get("gemma-voice-chat"):
        print_info_panel(
            "Voice mode is not configured.\n\n"
            "To enable voice control for Gemma, run:\n"
            "  gemma-voice-chat --setup\n\n"
            "This will download whisper.cpp (STT) and piper (TTS).\n"
            "No sudo required. No system changes."
        )
        return

    # Parse subcommand
    sub = subcmd.strip().lower()

    if sub in ("status", "st"):
        print_voice_status()

    elif sub in ("start", "go", "begin"):
        print_info_panel("Starting voice session...\nType 'r' and press Enter to record (6s). Type text to send directly. /quit to exit.")
        console.print()
        subprocess.run([str(HELPERS["gemma-voice-chat"]["path"])])

    elif sub in ("help", "h", "?"):
        console.print("[bright_yellow bold]🎙️ Voice Mode Help[/]")
        console.print()
        console.print("Voice mode wraps local STT and TTS for Gemma.")
        console.print()
        console.print("[bright_cyan]Commands:[/]")
        console.print("  /voice status       Show component status")
        console.print("  /voice start        Start voice session")
        console.print("  /voice test-output  Test TTS output")
        console.print("  /voice help         Show this help")
        console.print("  /voice stop         Stop voice session (alias for /quit)")
        console.print()
        console.print("[bright_cyan]Behavior:[/]")
        console.print("  - Type 'r' and press Enter to record 6 seconds")
        console.print("  - Or type text directly and press Enter to send")
        console.print("  - Audio is transcribed to text")
        console.print("  - Text is sent to Gemma via Ollama")
        console.print("  - Gemma's response is spoken via TTS")
        console.print("  - Raw audio is deleted after transcription")
        console.print()
        console.print("[dim]Gemma is text-only; voice mode wraps local STT and TTS.[/]")
        console.print("[dim]Voice mode does not bypass gemma-ui or gemma-security-chat gates.[/]")

    elif sub in ("test-output", "test", "tts"):
        console.print("[bright_yellow]Testing TTS output...[/]")
        subprocess.run([str(HELPERS["gemma-voice-chat"]["path"]), "--test-output"])

    elif sub in ("stop", "end", "quit"):
        console.print("[dim]Voice session stopped.[/]")

    else:
        # Default: show status and prompt to start
        print_voice_status()
        console.print()
        try:
            confirm = console.input("[bright_yellow]Start voice session? [y/N]: [/]").strip().lower()
        except (EOFError, KeyboardInterrupt):
            confirm = "n"

        if confirm in ("y", "yes"):
            subprocess.run([str(HELPERS["gemma-voice-chat"]["path"])])


def mode_health():
    """Health mode — run safe health checks."""
    global _CURRENT_MODE
    _CURRENT_MODE = "health"

    print_info_panel("Health Check Mode\nSafe read-only status checks. No system changes.")
    console.print()

    checks = []

    # Ollama
    try:
        req = urllib.request.Request(f"{OLLAMA_HOST}/api/tags", method="GET")
        with urllib.request.urlopen(req, timeout=5) as resp:
            models = json.loads(resp.read())
            model_count = len(models.get("models", []))
            checks.append(("Ollama API", "[green]✓[/]", f"{model_count} models loaded"))
    except Exception as e:
        checks.append(("Ollama API", "[red]✗[/]", str(e)))

    # Gemma model
    try:
        req = urllib.request.Request(f"{OLLAMA_HOST}/api/tags", method="GET")
        with urllib.request.urlopen(req, timeout=5) as resp:
            models = json.loads(resp.read())
            model_names = [m.get("name", "") for m in models.get("models", [])]
            if MODEL in model_names or any(MODEL in n for n in model_names):
                checks.append(("Gemma Model", "[green]✓[/]", MODEL))
            else:
                checks.append(("Gemma Model", "[yellow]⚠[/]", f"{MODEL} not found"))
    except Exception as e:
        checks.append(("Gemma Model", "[red]✗[/]", str(e)))

    # System services
    for svc_name in ["firewalld", "usbguard", "auditd", "clamd"]:
        try:
            result = subprocess.run(["systemctl", "is-active", svc_name], capture_output=True, text=True, timeout=5)
            active = result.returncode == 0
            checks.append((svc_name, "[green]✓[/]" if active else "[yellow]⚠[/]", result.stdout.strip()))
        except Exception as e:
            checks.append((svc_name, "[red]✗[/]", str(e)))

    # Helpers
    detected = detect_helpers()
    available = sum(1 for v in detected.values() if v)
    checks.append(("Helpers", "[green]✓[/]" if available > 5 else "[yellow]⚠[/]", f"{available}/{len(HELPERS)} available"))

    # Disk
    try:
        result = subprocess.run(["df", "-h", "/"], capture_output=True, text=True, timeout=5)
        line = result.stdout.strip().split("\n")[-1]
        checks.append(("Disk /", "[green]✓[/]", line))
    except Exception as e:
        checks.append(("Disk /", "[red]✗[/]", str(e)))

    # Memory
    try:
        result = subprocess.run(["free", "-h"], capture_output=True, text=True, timeout=5)
        mem_line = [l for l in result.stdout.split("\n") if l.startswith("Mem:")]
        if mem_line:
            checks.append(("Memory", "[green]✓[/]", " ".join(mem_line[0].split()[1:4])))
    except Exception as e:
        checks.append(("Memory", "[red]✗[/]", str(e)))

    # Display
    table = Table(
        show_header=True,
        header_style="bright_magenta bold",
        border_style="bright_black",
        expand=False,
        box=None,
        padding=(0, 1),
    )
    table.add_column("Component", style="bright_cyan")
    table.add_column("Status", style="", width=6, justify="center")
    table.add_column("Details", style="dim")

    for name, status, details in checks:
        table.add_row(name, status, str(details))

    console.print(table)

    # Run gemma-bazzite-health if available
    if detected.get("gemma-bazzite-health"):
        console.print()
        console.print("[bright_green]Running gemma-bazzite-health...[/]")
        subprocess.run([str(HELPERS["gemma-bazzite-health"]["path"])])


def mode_dashboard():
    """Dashboard mode — safe read-only status view. No scans, no sudo."""
    global _CURRENT_MODE
    _CURRENT_MODE = "dashboard"

    detected = detect_helpers()
    config = load_config()

    # Use app shell layout when configured
    is_app_shell = config.get("ui", {}).get("layout", "classic") == "app_shell"
    if is_app_shell:
        render_app_shell(detected, config, "dashboard", show_footer=False)
    else:
        console.print("[bright_yellow bold]📊 Status Dashboard[/]")
        console.print()

    # ── Core ─────────────────────────────────────────────────────────────────
    console.print("[bright_cyan bold]Core[/]")
    core_table = Table(show_header=False, box=None, padding=(0, 2))
    core_table.add_column("Item", style="bright_cyan")
    core_table.add_column("Status", style="")

    # Ollama
    try:
        req = urllib.request.Request(f"{OLLAMA_HOST}/api/tags", method="GET")
        with urllib.request.urlopen(req, timeout=3) as resp:
            data = json.loads(resp.read())
            models = data.get("models", [])
            core_table.add_row("Ollama API", "[green]✓ online[/] ({0} models)".format(len(models)))
    except Exception:
        core_table.add_row("Ollama API", "[red]✗ offline[/]")

    # Current model
    core_table.add_row("Model", config.get("ollama", {}).get("model", MODEL))

    # Config status
    cfg_valid = CONFIG_FILE.is_file()
    core_table.add_row("Config", "[green]✓[/] {0}".format(CONFIG_FILE) if cfg_valid else "[red]✗ missing[/]")

    # Helpers
    available = sum(1 for v in detected.values() if v)
    core_table.add_row("Helpers", "{0}/{1} available".format(available, len(HELPERS)))

    console.print(core_table)
    console.print()

    # ── Voice ────────────────────────────────────────────────────────────────
    console.print("[bright_cyan bold]Voice[/]")
    voice_table = Table(show_header=False, box=None, padding=(0, 2))
    voice_table.add_column("Item", style="bright_cyan")
    voice_table.add_column("Status", style="")

    voice_table.add_row("Recorder", "[green]✓[/] pw-record" if shutil.which("pw-record") else "[yellow]⚠[/] not found")
    voice_table.add_row("STT", "[green]✓[/] whisper-cli" if shutil.which("whisper-cli") else "[yellow]⚠[/] not found")
    voice_table.add_row("TTS", "[green]✓[/] piper" if detected.get("gemma-voice-chat") else "[yellow]⚠[/] not configured")
    voice_table.add_row("Mode", "[dim]push-to-talk only[/]")

    console.print(voice_table)
    console.print()

    # ── Memory ───────────────────────────────────────────────────────────────
    console.print("[bright_cyan bold]Memory[/]")
    mem_table = Table(show_header=False, box=None, padding=(0, 2))
    mem_table.add_column("Item", style="bright_cyan")
    mem_table.add_column("Status", style="")

    mem_table.add_row("gemma-memory-search", "[green]✓[/]" if detected.get("gemma-memory-search") else "[yellow]⚠[/] not found")
    mem_table.add_row("gemma-memory-rag", "[green]✓[/]" if detected.get("gemma-memory-rag") else "[yellow]⚠[/] not found")
    mem_table.add_row("gemma-knowledge-rag", "[green]✓[/]" if detected.get("gemma-knowledge-rag") else "[yellow]⚠[/] not found")
    mem_table.add_row("RuVector", "[dim]supervised secondary only[/]")
    mem_table.add_row("Stage 3A", "[dim]canonical fallback[/]")

    console.print(mem_table)
    console.print()

    # ── Repo ─────────────────────────────────────────────────────────────────
    console.print("[bright_cyan bold]Repo[/]")
    repo_table = Table(show_header=False, box=None, padding=(0, 2))
    repo_table.add_column("Item", style="bright_cyan")
    repo_table.add_column("Status", style="")

    gem_repo = Path.home() / "projects/gem"
    bazzite_repo = Path.home() / "projects/bazzite-laptop"
    repo_table.add_row("gem repo", "[green]✓[/] {0}".format(gem_repo) if gem_repo.is_dir() else "[yellow]⚠[/] not found")
    repo_table.add_row("bazzite-laptop repo", "[green]✓[/] {0}".format(bazzite_repo) if bazzite_repo.is_dir() else "[dim]optional / not present[/]")
    repo_table.add_row("Mode", "[dim]read-only[/]")

    console.print(repo_table)
    console.print()

    # ── Safety ───────────────────────────────────────────────────────────────
    console.print("[bright_cyan bold]Safety[/]")
    safety_table = Table(show_header=False, box=None, padding=(0, 2))
    safety_table.add_column("Boundary", style="bright_cyan")
    safety_table.add_column("Status", style="")

    safety_table.add_row("Advisory only", "[green]✓[/] enabled")
    safety_table.add_row("Human-confirmed tools", "[green]✓[/] enabled")
    safety_table.add_row("No always-listening daemon", "[green]✓[/] confirmed")
    safety_table.add_row("No LiveKit runtime", "[green]✓[/] confirmed")
    safety_table.add_row("No web server", "[green]✓[/] confirmed")

    console.print(safety_table)
    console.print()

    # ── Export ───────────────────────────────────────────────────────────────
    console.print("[bright_cyan bold]Export[/]")
    export_table = Table(show_header=False, box=None, padding=(0, 2))
    export_table.add_column("Item", style="bright_cyan")
    export_table.add_column("Status", style="")

    export_table.add_row("Static dashboard export", "[dim]optional[/]" if detected.get("gemma-dashboard") else "[dim]not installed[/]")

    console.print(export_table)
    console.print()

    # ── Feature Flags ────────────────────────────────────────────────────────
    console.print("[bright_cyan bold]Feature Flags[/]")
    features = config.get("features", {})
    feat_table = Table(show_header=False, box=None, padding=(0, 2))
    feat_table.add_column("Feature", style="bright_cyan")
    feat_table.add_column("Enabled", style="", width=8, justify="center")

    for name in ("general", "security", "memory", "repo", "voice", "reports", "health", "dashboard", "web_ui", "livekit"):
        enabled = features.get(name, False)
        feat_table.add_row(name, "[green]✓[/]" if enabled else "[red]✗[/]")

    console.print(feat_table)
    console.print()

    # ── Integration Metadata ─────────────────────────────────────────────────
    console.print("[bright_cyan bold]Integration Metadata[/]")
    integ_table = Table(show_header=False, box=None, padding=(0, 2))
    integ_table.add_column("Item", style="bright_cyan")
    integ_table.add_column("Status", style="")

    integrations = load_integrations()
    if integrations:
        bl = integrations.get("bazzite_laptop", {})
        integ_table.add_row("bazzite-laptop role", bl.get("role", "unknown"))
        integ_table.add_row("Config import status", bl.get("config_import_status", "unknown"))
        integ_table.add_row("Display-only", "yes" if bl.get("display_only") else "no")
        integ_table.add_row("MCP routing", "disabled" if not bl.get("mcp_routing_enabled") else "[red]enabled[/]")
        # Check file presence
        allowed = bl.get("allowed_display_files", {})
        for name, path_tpl in allowed.items():
            path = Path(path_tpl.replace("~", str(HOME))).expanduser()
            exists = "[green]present[/]" if path.is_file() else "[yellow]missing[/]"
            integ_table.add_row(f"  {name}", exists)
    else:
        integ_table.add_row("Status", "[dim]not configured[/]")

    console.print(integ_table)
    console.print()

    console.print("[dim]Dashboard is read-only. No scans run. No system changes.[/]")


# ── Demo UI ──────────────────────────────────────────────────────────────────

def demo_ui():
    """Render the UI without running any tools."""
    detected = detect_helpers()
    config = load_config()
    
    is_app_shell = config.get("ui", {}).get("layout", "classic") == "app_shell"

    print_welcome_screen(detected)
    if not is_app_shell:
        print_status_bar(detected, "welcome")
        print_mode_selector(detected)
        print_footer()

    console.print()
    console.print("[dim]─ Demo: General Chat ─[/]")
    print_user_message("Check my firewall status", config)
    print_gemma_message("firewalld is active. Default zone: public. Default target: DROP.", config)

    console.print()
    console.print("[dim]─ Demo: Tool Suggestion ─[/]")
    print_tool_suggestion("firewall_status", "Check firewall rules and status", RISK_SAFE)

    console.print()
    console.print("[dim]─ Demo: Security Tool ─[/]")
    print_tool_result("firewall_status", "firewalld: active\nzone: public\ntarget: DROP", success=True)

    console.print()
    console.print("[dim]─ Demo: Error Panel ─[/]")
    print_error_panel("gemma-voice-chat is not configured.\nInstall it to use voice mode.")

    console.print()
    console.print("[dim]─ Demo: Info Panel ─[/]")
    print_info_panel("Session state saved.")

    console.print()
    console.print("[dim]─ Demo: Tool Categories ─[/]")
    print_tools()

    console.print()
    console.print("[dim]─ Demo: Reports ─[/]")
    print_reports()


# ── Interactive Router ───────────────────────────────────────────────────────

def interactive_router():
    """Main interactive loop — mode selection."""
    global _CURRENT_MODE
    config = load_config()
    detected = detect_helpers()
    
    is_app_shell = config.get("ui", {}).get("layout", "classic") == "app_shell"

    print_welcome_screen(detected)
    if not is_app_shell:
        print_status_bar(detected, "welcome")
        print_mode_selector(detected)
        print_footer()

    while True:
        try:
            user_input = console.input("[bright_cyan bold]gemma-ui ❯ [/]").strip()
        except (EOFError, KeyboardInterrupt):
            console.print("\n[dim]Goodbye! 👋[/]")
            break

        if not user_input:
            continue

        # Normalize input
        cmd = user_input.lower()
        if not cmd.startswith("/"):
            cmd = "/" + cmd

        # Route to mode
        if cmd in ("/quit", "/exit", "/q"):
            console.print("[dim]Goodbye! 👋[/]")
            break

        elif cmd == "/general" or cmd == "/1":
            mode_general()
            if is_app_shell:
                render_app_shell(detected, config, "general")
            else:
                print_status_bar(detected, "general")
                print_footer()

        elif cmd == "/security" or cmd == "/2":
            mode_security()
            if is_app_shell:
                render_app_shell(detected, config, "security")
            else:
                print_status_bar(detected, "security")
                print_footer()

        elif cmd == "/memory" or cmd == "/3":
            mode_memory()
            if is_app_shell:
                render_app_shell(detected, config, "memory")
            else:
                print_status_bar(detected, "memory")
                print_footer()

        elif cmd.startswith("/memory "):
            subcmd = cmd[len("/memory "):].strip()
            mode_memory(subcmd)
            if is_app_shell:
                render_app_shell(detected, config, "memory")
            else:
                print_status_bar(detected, "memory")
                print_footer()

        elif cmd == "/repo" or cmd == "/4":
            mode_repo()
            if is_app_shell:
                render_app_shell(detected, config, "repo")
            else:
                print_status_bar(detected, "repo")
                print_footer()

        elif cmd == "/voice" or cmd == "/5":
            mode_voice()
            if is_app_shell:
                render_app_shell(detected, config, "voice")
            else:
                print_status_bar(detected, "voice")
                print_footer()

        elif cmd.startswith("/voice "):
            subcmd = cmd[len("/voice "):].strip()
            mode_voice(subcmd)
            if is_app_shell:
                render_app_shell(detected, config, "voice")
            else:
                print_status_bar(detected, "voice")
                print_footer()

        elif cmd == "/reports" or cmd == "/6":
            print_reports()
            console.print()
            if is_app_shell:
                render_app_shell(detected, config, "reports")
            else:
                print_footer()

        elif cmd == "/health" or cmd == "/7":
            mode_health()
            console.print()
            if is_app_shell:
                render_app_shell(detected, config, "health")
            else:
                print_footer()

        elif cmd in ("/dashboard", "/status", "/8"):
            mode_dashboard()
            console.print()
            if is_app_shell:
                render_app_shell(detected, config, "dashboard")
            else:
                print_footer()

        elif cmd == "/integration" or cmd == "/integrations":
            print_integration_status()
            console.print()
            if not is_app_shell:
                print_footer()

        elif cmd.startswith("/integration "):
            subcmd = cmd[len("/integration "):].strip()
            if subcmd in ("status", "st"):
                print_integration_status()
            else:
                console.print(f"[yellow]Unknown integration subcommand: {subcmd}[/]")
            console.print()
            if not is_app_shell:
                print_footer()

        elif cmd == "/clear":
            console.clear()
            print_welcome_screen(detected)
            if not is_app_shell:
                print_status_bar(detected, "welcome")
                print_mode_selector(detected)
                print_footer()

        elif cmd == "/save":
            config = load_config()
            config["last_run"] = datetime.now().isoformat()
            save_config(config)
            print_info_panel("Session state saved.")

        elif cmd == "/mode":
            if is_app_shell:
                render_app_shell(detected, config, "welcome")
            else:
                print_mode_selector(detected)
                print_footer()

        elif cmd in ("/help", "/h"):
            print_help()
            console.print()
            if not is_app_shell:
                print_footer()

        elif cmd == "/back":
            _CURRENT_MODE = "welcome"
            if is_app_shell:
                render_app_shell(detected, config, "welcome")
            else:
                print_status_bar(detected, "welcome")
                print_mode_selector(detected)
                print_footer()

        elif cmd.startswith("/"):
            # Try as a direct message to general chat
            console.print(f"[dim]Unknown mode '{user_input}'. Routing to general chat...[/]")
            mode_general(user_input)
            if is_app_shell:
                render_app_shell(detected, config, "general")
            else:
                print_status_bar(detected, "general")
                print_footer()

        else:
            # Direct message for general chat
            mode_general(user_input)
            if is_app_shell:
                render_app_shell(detected, config, "general")
            else:
                print_status_bar(detected, "general")
                print_footer()


# ── CLI Entry Point ──────────────────────────────────────────────────────────

def list_modes():
    """Print modes in machine-readable format."""
    detected = detect_helpers()

    modes = {
        "general": {"available": True, "helper": "gemma-bazzite", "installed": detected.get("gemma-bazzite", False)},
        "security": {"available": True, "helper": "gemma-security-chat", "installed": detected.get("gemma-security-chat", False)},
        "memory": {"available": detected.get("gemma-memory-search") or detected.get("gemma-knowledge-search"), "helpers": ["gemma-memory-search", "gemma-knowledge-search"]},
        "repo": {"available": detected.get("gemma-repo-brief"), "helper": "gemma-repo-brief"},
        "voice": {"available": detected.get("gemma-voice-chat"), "helper": "gemma-voice-chat"},
        "reports": {"available": True, "builtin": True},
        "tools": {"available": True, "builtin": True},
        "health": {"available": True, "builtin": True},
        "dashboard": {"available": True, "builtin": True},
    }

    table = Table(
        title="Available Modes",
        border_style="bright_black",
        expand=False,
        box=None,
        padding=(0, 1),
    )
    table.add_column("Mode", style="bright_cyan")
    table.add_column("Available", style="", width=12, justify="center")
    table.add_column("Helper", style="dim")
    table.add_column("Installed", style="", width=12, justify="center")

    for mode, info in modes.items():
        avail = "[green]✓[/]" if info["available"] else "[red]✗[/]"
        helper = info.get("helper", "built-in")
        installed = "[green]yes[/]" if info.get("installed", info["available"]) else "[red]no[/]"
        table.add_row(mode, avail, helper, installed)

    console.print(table)


def main():
    args = sys.argv[1:]

    # Handle --classic flag before anything else
    if "--classic" in args:
        args.remove("--classic")
        global _FORCE_CLASSIC
        _FORCE_CLASSIC = True

    if "--help" in args or "-h" in args:
        print_help()
        sys.exit(0)

    if "--list-modes" in args:
        list_modes()
        sys.exit(0)

    if "--version" in args:
        console.print("[bright_yellow]gemma-ui[/] 1.0.0 — Unified Terminal UI for Bazzite Local AI")
        sys.exit(0)

    if "--demo-ui" in args:
        demo_ui()
        sys.exit(0)

    if "--demo-layout" in args:
        demo_layout()
        sys.exit(0)

    if "--voice-status" in args:
        print_voice_status()
        sys.exit(0)

    if "--config" in args:
        print_config()
        sys.exit(0)

    if "--config-check" in args:
        check_config()
        sys.exit(0)

    if "--integration-status" in args:
        print_integration_status()
        sys.exit(0)

    # Memory CLI flags
    if "--memory-status" in args:
        detected = detect_helpers()
        print_memory_status(detected)
        sys.exit(0)

    if "--memory-dashboard" in args:
        print_memory_dashboard()
        sys.exit(0)

    if "--memory-search" in args:
        idx = args.index("--memory-search")
        if idx + 1 < len(args):
            query = args[idx + 1]
            console.print("[bright_cyan]RuVector search (supervised, explicit):[/]")
            _memory_run_helper("gemma-memory-search", query)
            sys.exit(0)
        else:
            console.print("[red]Usage:[/] gemma-ui --memory-search \"<query>\"")
            sys.exit(1)

    if "--memory-ask" in args:
        idx = args.index("--memory-ask")
        if idx + 1 < len(args):
            query = args[idx + 1]
            console.print("[bright_cyan]RuVector RAG (supervised, explicit):[/]")
            _memory_run_helper("gemma-memory-rag", query)
            sys.exit(0)
        else:
            console.print("[red]Usage:[/] gemma-ui --memory-ask \"<question>\"")
            sys.exit(1)

    if "--memory-stage3a" in args:
        idx = args.index("--memory-stage3a")
        if idx + 1 < len(args):
            query = args[idx + 1]
            console.print("[bright_cyan]Stage 3A deterministic fallback:[/]")
            _memory_run_helper("gemma-knowledge-rag", query)
            sys.exit(0)
        else:
            console.print("[red]Usage:[/] gemma-ui --memory-stage3a \"<question>\"")
            sys.exit(1)

    if "--memory-compare" in args:
        idx = args.index("--memory-compare")
        if idx + 1 < len(args):
            query = args[idx + 1]
            print_memory_compare(query)
            sys.exit(0)
        else:
            console.print("[red]Usage:[/] gemma-ui --memory-compare \"<question>\"")
            sys.exit(1)

    if "--route-intent" in args:
        idx = args.index("--route-intent")
        if idx + 1 < len(args):
            text = args[idx + 1]
            mode, subcmd, reason = route_intent(text)
            console.print(f"[bright_cyan]Input:[/]    {text}")
            console.print(f"[bright_cyan]Mode:[/]     {mode}")
            if subcmd:
                console.print(f"[bright_cyan]Subcmd:[/]   {subcmd}")
            console.print(f"[bright_cyan]Reason:[/]   {reason}")
            if mode == "security":
                console.print("[yellow]Action:[/]   Hand off to gemma-security-chat (confirmation gates remain)")
            elif mode == "memory" and subcmd:
                console.print(f"[green]Action:[/]   Route to gemma-ui --mode memory {subcmd}")
            else:
                console.print(f"[green]Action:[/]   Route to gemma-ui --mode {mode}")
            sys.exit(0)
        else:
            console.print("[red]Usage:[/] gemma-ui --route-intent \"<text>\"")
            sys.exit(1)

    if "--dashboard" in args or "--status" in args:
        mode_dashboard()
        sys.exit(0)

    # Check for --mode
    if "--mode" in args:
        idx = args.index("--mode")
        if idx + 1 < len(args):
            mode = args[idx + 1].lower()
            # Collect remaining args as subcommand (e.g. --mode voice status help)
            subcmd = " ".join(args[idx + 2:]) if idx + 2 < len(args) else ""

            if mode == "general":
                mode_general()
            elif mode == "security":
                mode_security()
            elif mode == "memory":
                mode_memory(subcmd)
            elif mode == "repo":
                mode_repo()
            elif mode == "voice":
                mode_voice(subcmd)
            elif mode == "reports":
                print_reports()
            elif mode == "tools":
                print_tools()
            elif mode == "health":
                mode_health()
            elif mode == "dashboard":
                mode_dashboard()
            else:
                console.print(f"[red]Unknown mode:[/] {mode}")
                sys.exit(1)
            sys.exit(0)
        else:
            console.print("[red]--mode requires an argument[/]")
            sys.exit(1)

    # Default: interactive router
    interactive_router()


if __name__ == "__main__":
    main()
