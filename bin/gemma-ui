    /settings ascii      Toggle Unicode/ASCII markers
    /settings compact    Toggle compact/comfortable density
    /settings layout     Toggle app-shell/classic layout
    /theme               Shortcut for /settings theme
    /ascii               Shortcut for /settings ascii
    /compact             Shortcut for /settings compact

[bright_cyan]UI COMMANDS[/]
    /help        Show this help
    /commands    Show grouped command palette
    /?           Alias for /commands
    /mode        Show mode selector
    /menu        Alias for /mode
    /dashboard   Show read-only status dashboard
    /status      Alias for /dashboard
    /integration Show integration metadata (display-only)
    /clear       Clear the screen
    /save        Save current session state
    /quit        Exit

[bright_cyan]SHORTCUTS[/]
    /g  = /general    /s  = /security    /m  = /memory
    /o  = /repo       /v  = /voice       /r  = /reports
    /h  = /health     /t  = /settings    /q  = /quit

[bright_cyan]RISK LABELS[/]
    [green]SAFE READ-ONLY[/]     No system changes, no sudo
    [yellow]CONFIRM REQUIRED[/]   May prompt before action
    [bright_red]SUDO / MANUAL[/]    Requires explicit sudo or manual review
    [dim]UNAVAILABLE[/]          Helper not configured
"""
    console.print(help_text)

    console.print("[bright_cyan]DETECTED HELPERS[/]")
    for name, info in HELPERS.items():
        status = "[green]✓[/]" if detected.get(name) else "[red]✗[/]"
        risk = info.get("risk", RISK_SAFE)
        risk_label = helper_risk_label(name)
        console.print(f"  {status} [cyan]{name:<30}[/] {info['description']:<45} {risk_label}")

    console.print()
    console.print("[dim]Helpers marked ✗ are not configured or not in ~/.local/bin/[/]")
    console.print("[dim]The UI will handle missing helpers gracefully.[/]")


