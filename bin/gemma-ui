# ── Reports ──────────────────────────────────────────────────────────────────

def print_reports():
    """List recent reports."""
    if not REPORT_DIR.is_dir():
        print_error_panel(f"Report directory not found:\n{REPORT_DIR}")
        return

    reports = sorted(REPORT_DIR.glob("*.md"), key=lambda p: p.stat().st_mtime, reverse=True)

    if not reports:
        print_info_panel("No reports found.")
        return

    table = Table(
        show_header=True,
        header_style="bright_magenta bold",
        border_style="bright_black",
        expand=False,
        box=None,
        padding=(0, 1),
    )
    table.add_column("#", style="dim", width=3, justify="right")
    table.add_column("Report", style="bright_cyan")
    table.add_column("Size", style="dim", width=10, justify="right")
    table.add_column("Date", style="dim", width=16)

    for i, report in enumerate(reports[:15], 1):
        size = report.stat().st_size
        size_str = f"{size / 1024:.1f} KB" if size > 1024 else f"{size} B"
        mtime = datetime.fromtimestamp(report.stat().st_mtime).strftime("%Y-%m-%d %H:%M")
        table.add_row(str(i), report.name, size_str, mtime)

    console.print(table)
    console.print(f"[dim]Total: {len(reports)} reports in {REPORT_DIR}[/]")


