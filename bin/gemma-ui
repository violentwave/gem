def _render_app_shell_footer(width: int) -> Text:
    """Render contextual help footer with command shortcuts."""
    hints = [
        ("/help", ""),
        ("/menu", ""),
        ("/dashboard", ""),
        ("/memory", ""),
        ("/voice", ""),
        ("/quit", ""),
    ]

    text = Text()
    text.append("└─ ", style="bright_black")
    for i, (key, label) in enumerate(hints):
        if i > 0:
            text.append("  ", style="bright_black")
        text.append(key, style="bright_cyan")

    current_len = len(text.plain)
    if current_len < width - 1:
        text.append(" " * (width - 1 - current_len), style="bright_black")
    text.append("┘", style="bright_black")

    return text


def render_app_shell(detected: Dict[str, bool], config: dict, current_mode: str = "welcome", show_footer: bool = True):
    """Render the polished app-shell layout.

    This is the default layout for gemma-ui. It shows:
    - Compact top status bar with chip-style badges
    - Horizontal mode rail with hotkey markers
    - Context-aware main panel
    - Contextual footer with keyboard hints

    Use --classic to force the old table-based layout.
    """
    try:
        term_width = console.size.width
    except Exception:
        term_width = 80

    width = max(term_width, 40)

    # ── Top Bar ──────────────────────────────────────────────────────────────
    console.print(_render_app_shell_top_bar(width, detected))

    # ── Mode Rail ────────────────────────────────────────────────────────────
    console.print(_render_app_shell_mode_rail_horizontal(current_mode))
    console.print(Text("├" + "─" * (width - 2) + "┤", style="bright_black"))

    # ── Main Panel ───────────────────────────────────────────────────────────
    main_lines = _render_app_shell_main_panel(width, current_mode)
    for line in main_lines:
        combined = Text()
        combined.append(line)
        line_plain = line.plain
        if len(line_plain) < width - 1:
            combined.append(" " * (width - 1 - len(line_plain)), style="bright_black")
        combined.append("│", style="bright_black")
        console.print(combined)

    # ── Footer ───────────────────────────────────────────────────────────────
    if show_footer:
        console.print(_render_app_shell_footer(width))
        console.print()


# ── Polished App Shell Layout (Demo) ─────────────────────────────────────────

def _render_demo_top_bar(width: int, detected: Dict[str, bool]) -> Text:
    """Build a compact top status bar as Rich Text."""
    ollama_status, ollama_color, ollama_detail = get_ollama_status()
    voice_status, voice_color = get_voice_status(detected)
    mem_status, mem_color = get_memory_status(detected)
    tool_summary = get_tool_summary(detected)
    
    # Build chip-style status elements
    chips = []
    
    # App name chip
    chips.append(("Gemma", "bright_cyan bold"))
    
    # Model chip
    model_short = MODEL
    if len(model_short) > 12:
        model_short = model_short[:9] + "..."
    chips.append((f"model:{model_short}", "bright_white"))
    
    # Ollama chip with color
    chips.append((f"ollama:{ollama_status}", ollama_color))
    
    # Memory chip
    mem_short = mem_status.split()[0] if mem_status else "?"
    chips.append((f"mem:{mem_short}", mem_color))
    
    # Voice chip
    voice_short = voice_status if len(voice_status) <= 10 else voice_status[:7] + "..."
    chips.append((f"voice:{voice_short}", voice_color))
    
    # Tools chip
    chips.append((f"tools:{tool_summary}", "bright_white"))
    
    # Assemble into a single line with separators
    text = Text()
    text.append("┌─ ", style="bright_black")
    for i, (label, style) in enumerate(chips):
        if i > 0:
            text.append(" ─ ", style="bright_black")
        text.append(label, style=style)
    
    # Pad/truncate to width
    current_len = len(text.plain)
    if current_len < width - 2:
        text.append(" " * (width - 2 - current_len), style="bright_black")
    text.append("─┐", style="bright_black")
    
    return text


def _render_demo_mode_rail_vertical(current_mode: str, width: int) -> list[Text]:
    """Render a vertical left mode rail for wide terminals."""
    modes = [
        ("general", "General", "G"),
        ("security", "Security", "S"),
        ("memory", "Memory", "M"),
        ("repo", "Repo", "O"),
        ("reports", "Reports", "R"),
        ("voice", "Voice", "V"),
        ("health", "Health", "H"),
        ("settings", "Settings", "T"),
    ]
    
    lines = []
    # Header
    header = Text()
    header.append("│ ", style="bright_black")
    header.append("Modes", style="bright_cyan bold")
    lines.append(header)
    header2 = Text()
    header2.append("│ ", style="bright_black")
    header2.append("─────", style="bright_black")
    lines.append(header2)
    
    for mode_id, name, hotkey in modes:
        line = Text()
        line.append("│ ", style="bright_black")
        if mode_id == current_mode:
            line.append("> ", style="bright_cyan bold")
            line.append(f"[{hotkey}] {name}", style="bright_cyan bold")
        else:
            line.append("  ", style="bright_black")
            line.append(f"[{hotkey}] ", style="dim")
            line.append(name, style="dim")
        lines.append(line)
    
    # Quit hint
    quit_line = Text()
    quit_line.append("│ ", style="bright_black")
    quit_line.append("─────", style="bright_black")
    lines.append(quit_line)
    quit_line2 = Text()
    quit_line2.append("│ ", style="bright_black")
    quit_line2.append("[Q] Quit", style="dim")
    lines.append(quit_line2)
    
    return lines


