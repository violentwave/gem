def print_tools():
    """List tools by category with risk labels."""
    categories = {
        "General": ["gemma-bazzite"],
        "Security": ["gemma-security-chat", "gemma-security-analyzer", "gemma-command-review"],
        "Memory": ["gemma-memory-search", "gemma-memory-rag", "gemma-knowledge-search", "gemma-knowledge-rag"],
        "Repo": ["gemma-repo-brief", "gemma-file-brief"],
        "Voice": ["gemma-voice-chat"],
        "Diagnostics": ["gemma-bazzite-health", "gemma-monitor-daily", "gemma-monitor-drift"],
        "Export": ["gemma-dashboard"],
    }

    detected = detect_helpers()

    for cat, names in categories.items():
        console.print(f"\n[bright_magenta bold]{cat}[/]")
        for name in names:
            if name in HELPERS:
                status = "[green]✓[/]" if detected.get(name) else "[red]✗[/]"
                risk_label = helper_risk_label(name)
                avail = "[green]ready[/]" if detected.get(name) else "[dim]not configured[/]"
                console.print(f"  {status} [cyan]{name:<30}[/] {HELPERS[name]['description']:<45} {risk_label}  {avail}")


# ── Mode Handlers ────────────────────────────────────────────────────────────

def mode_general(message: Optional[str] = None):
    """General chat mode — delegates to gemma-bazzite or Ollama."""
    global _CURRENT_MODE
    _CURRENT_MODE = "general"
    config = load_config()

    if not HELPERS["gemma-bazzite"]["path"].is_file():
        print_error_panel(
            "gemma-bazzite not found.\n"
            "Falling back to direct Ollama API."
        )
        if message:
            subprocess.run(["ollama", "run", MODEL, "--hidethinking", message])
        else:
            print_info_panel(f"Start interactive chat with: ollama run {MODEL}")
        return

    if message:
        print_user_message(message, config)
        subprocess.run([str(HELPERS["gemma-bazzite"]["path"]), message])
    else:
        print_info_panel("Starting Gemma general chat...\nType your message. Use Ctrl+D or /quit to exit.")
        console.print()
        subprocess.run([str(HELPERS["gemma-bazzite"]["path"])])


def mode_security():
    """Security mode — delegates to gemma-security-chat."""
    global _CURRENT_MODE
    _CURRENT_MODE = "security"

    if not HELPERS["gemma-security-chat"]["path"].is_file():
        print_error_panel(
            "gemma-security-chat not configured.\n"
            "Install it to use security tools."
        )
        return

    print_info_panel("Starting Gemma Security Console...\nThis is an interactive security tool interface.")
    console.print()
    subprocess.run([str(HELPERS["gemma-security-chat"]["path"])])


def _memory_run_helper(helper_name: str, query: str):
    """Run a memory helper safely with subprocess argument array."""
    if not HELPERS[helper_name]["path"].is_file():
        print_error_panel(f"{helper_name} not configured.")
        return
    subprocess.run([str(HELPERS[helper_name]["path"]), query])


def mode_memory(subcmd: str = ""):
    """Memory mode — explicit supervised RuVector with Stage 3A fallback.

    RuVector memory mode is explicit and supervised.
    RuVector is not the default retrieval path.
    Stage 3A deterministic retrieval remains the canonical fallback.
    Memory mode performs read-only retrieval/RAG only.
    Memory mode does not ingest new data, train the model, mutate repos,
    or execute remediation.
    """
    global _CURRENT_MODE
    _CURRENT_MODE = "memory"
    detected = detect_helpers()

    sub = subcmd.strip().lower()

    if sub in ("status", "st"):
        print_memory_status(detected)

    elif sub in ("dashboard", "quality", "db", "q"):
        print_memory_dashboard()

    elif sub.startswith("search "):
        query = sub[len("search "):].strip()
        if query:
            console.print("[bright_cyan]RuVector search (supervised, explicit):[/]")
            _memory_run_helper("gemma-memory-search", query)
        else:
            print_error_panel("Empty query. Usage: /memory search <query>")

    elif sub.startswith("ask "):
        query = sub[len("ask "):].strip()
        if query:
            console.print("[bright_cyan]RuVector RAG (supervised, explicit):[/]")
            _memory_run_helper("gemma-memory-rag", query)
        else:
            print_error_panel("Empty question. Usage: /memory ask <question>")

    elif sub.startswith("stage3a "):
        query = sub[len("stage3a "):].strip()
        if query:
            console.print("[bright_cyan]Stage 3A deterministic fallback:[/]")
            _memory_run_helper("gemma-knowledge-rag", query)
        else:
            print_error_panel("Empty question. Usage: /memory stage3a <question>")

    elif sub.startswith("compare "):
        query = sub[len("compare "):].strip()
        if query:
            print_memory_compare(query)
        else:
            print_error_panel("Empty question. Usage: /memory compare <question>")

    elif sub in ("help", "h", "?"):
        print_memory_help()

    else:
        # Default: show status and prompt
        print_memory_status(detected)
        console.print()
        print_memory_help()


def print_memory_status(detected: Dict[str, bool]):
    """Print memory mode status panel."""
    console.print("[bright_yellow bold]🧠 Memory Mode Status[/]")
    console.print()

    table = Table(show_header=False, box=None, padding=(0, 2))
    table.add_column("Source", style="bright_cyan")
    table.add_column("Status", style="")

    # RuVector helpers
    table.add_row("gemma-memory-search", "[green]✓[/] available" if detected.get("gemma-memory-search") else "[yellow]⚠[/] not found")
    table.add_row("gemma-memory-rag", "[green]✓[/] available" if detected.get("gemma-memory-rag") else "[yellow]⚠[/] not found")

    # Stage 3A helpers
    table.add_row("gemma-knowledge-search", "[green]✓[/] available" if detected.get("gemma-knowledge-search") else "[yellow]⚠[/] not found")
    table.add_row("gemma-knowledge-rag", "[green]✓[/] available" if detected.get("gemma-knowledge-rag") else "[yellow]⚠[/] not found")

    console.print(table)
    console.print()

    # Status text
    console.print("[bright_cyan]RuVector:[/]       [dim]supervised secondary only[/]")
    console.print("[bright_cyan]Stage 3A:[/]       [dim]canonical fallback[/]")
    console.print("[bright_cyan]Behavior:[/]       [dim]read-only retrieval/RAG only[/]")
    console.print("[bright_cyan]Ingestion:[/]      [dim]not performed[/]")
    console.print()

    # Index path
    ruvector_index = HOME / ".local/share/bazzite-security/ruvector/semantic-prototype/semantic-approved-docs-memory.json"
    stage3a_index = HOME / ".local/share/bazzite-security/gemma-knowledge/index/chunks.jsonl"
    console.print("[bright_cyan]Index Paths:[/]")
    console.print(f"  RuVector:  {'[green]✓[/] ' + str(ruvector_index) if ruvector_index.is_file() else '[yellow]⚠[/] not found'}")
    console.print(f"  Stage 3A:  {'[green]✓[/] ' + str(stage3a_index) if stage3a_index.is_file() else '[yellow]⚠[/] not found'}")
    console.print()

    # Manifest status (read-only, check multiple paths)
    def _find_latest_manifest(base_dir: Path, pattern: str) -> Optional[Path]:
        if not base_dir.is_dir():
            return None
        matches = sorted(base_dir.glob(pattern), key=lambda p: p.stat().st_mtime, reverse=True)
        return matches[0] if matches else None

    rv_manifest = _find_latest_manifest(
        HOME / ".local/share/bazzite-security/ruvector/semantic-prototype", "semantic-manifest-*.json"
    )
    if not rv_manifest:
        rv_manifest = _find_latest_manifest(
            HOME / ".local/share/bazzite-security/ruvector", "manifest-*.json"
        )
    s3_manifest = _find_latest_manifest(
        HOME / ".local/share/bazzite-security/gemma-knowledge/manifests", "gemma-knowledge-manifest-*.txt"
    )

    console.print("[bright_cyan]Manifests:[/]")
    if rv_manifest and rv_manifest.is_file():
        console.print(f"  RuVector:  [green]✓[/] {rv_manifest}")
    else:
        console.print("  RuVector:  [yellow]⚠[/] not found — run supervised refresh if needed")
    if s3_manifest and s3_manifest.is_file():
        console.print(f"  Stage 3A:  [green]✓[/] {s3_manifest}")
    else:
        console.print("  Stage 3A:  [yellow]⚠[/] not found — run supervised refresh if needed")
    console.print()


