    table.add_column("Status", style="")

    table.add_row("gemma-voice-chat", "[yellow]MISSING[/] not configured")
    table.add_row("Recorder", "[green]OK[/] pw-record" if shutil.which("pw-record") else "[yellow]MISSING[/] pw-record")
    table.add_row("STT", "[green]OK[/] whisper-cli" if shutil.which("whisper-cli") else "[yellow]MISSING[/] whisper-cli")
    table.add_row("Mode", "[dim]push-to-talk only[/]")

    console.print(table)
    console.print()
    console.print("[dim]Run: gemma-voice-chat --setup[/]")


def mode_voice(subcmd: str = ""):
    """Voice mode — handle voice subcommands or launch session."""
    global _CURRENT_MODE
    _CURRENT_MODE = "voice"
    detected = detect_helpers()

    if not detected.get("gemma-voice-chat"):
        print_info_panel(
            "Voice mode is not configured.\n\n"
            "To enable voice control for Gemma, run:\n"
            "  gemma-voice-chat --setup\n\n"
            "This will download whisper.cpp (STT) and piper (TTS).\n"
            "No sudo required. No system changes."
        )
        return

    # Parse subcommand
    sub = subcmd.strip().lower()

    if sub in ("status", "st"):
        print_voice_status()

    elif sub in ("start", "go", "begin"):
        print_info_panel("Starting voice session...\nType 'r' and press Enter to record (6s). Type text to send directly. /quit to exit.")
        console.print()
        subprocess.run([str(HELPERS["gemma-voice-chat"]["path"])])

    elif sub in ("help", "h", "?"):
        console.print("[bright_yellow bold]🎙️ Voice Mode Help[/]")
        console.print()
        console.print("Voice mode wraps local STT and TTS for Gemma.")
        console.print()
        console.print("[bright_cyan]Commands:[/]")
        console.print("  /voice status       Show component status")
        console.print("  /voice start        Start voice session")
        console.print("  /voice test-output  Test TTS output")
        console.print("  /voice help         Show this help")
        console.print("  /voice stop         Stop voice session (alias for /quit)")
        console.print()
        console.print("[bright_cyan]Behavior:[/]")
        console.print("  - Type 'r' and press Enter to record 6 seconds")
        console.print("  - Or type text directly and press Enter to send")
        console.print("  - Audio is transcribed to text")
        console.print("  - Text is sent to Gemma via Ollama")
        console.print("  - Gemma's response is spoken via TTS")
        console.print("  - Raw audio is deleted after transcription")
        console.print()
        console.print("[dim]Gemma is text-only; voice mode wraps local STT and TTS.[/]")
        console.print("[dim]Voice mode does not bypass gemma-ui or gemma-security-chat gates.[/]")

    elif sub in ("test-output", "test", "tts"):
        console.print("[bright_yellow]Testing TTS output...[/]")
        subprocess.run([str(HELPERS["gemma-voice-chat"]["path"]), "--test-output"])

    elif sub in ("stop", "end", "quit"):
        console.print("[dim]Voice session stopped.[/]")

    else:
        # Default: show status and prompt to start
        print_voice_status()
        console.print()
        try:
            confirm = console.input("[bright_yellow]Start voice session? [y/N]: [/]").strip().lower()
        except (EOFError, KeyboardInterrupt):
            confirm = "n"

        if confirm in ("y", "yes"):
            subprocess.run([str(HELPERS["gemma-voice-chat"]["path"])])


def mode_health():
    """Health mode — run safe health checks."""
    global _CURRENT_MODE
    _CURRENT_MODE = "health"

    print_info_panel("Health Check Mode\nSafe read-only status checks. No system changes.")
    console.print()

    checks = []

    # Ollama
    try:
        req = urllib.request.Request(f"{OLLAMA_HOST}/api/tags", method="GET")
        with urllib.request.urlopen(req, timeout=5) as resp:
            models = json.loads(resp.read())
            model_count = len(models.get("models", []))
            checks.append(("Ollama API", "[green]✓[/]", f"{model_count} models loaded"))
    except Exception as e:
        checks.append(("Ollama API", "[red]✗[/]", str(e)))

    # Gemma model
    try:
        req = urllib.request.Request(f"{OLLAMA_HOST}/api/tags", method="GET")
        with urllib.request.urlopen(req, timeout=5) as resp:
            models = json.loads(resp.read())
            model_names = [m.get("name", "") for m in models.get("models", [])]
            if MODEL in model_names or any(MODEL in n for n in model_names):
                checks.append(("Gemma Model", "[green]✓[/]", MODEL))
            else:
                checks.append(("Gemma Model", "[yellow]⚠[/]", f"{MODEL} not found"))
    except Exception as e:
        checks.append(("Gemma Model", "[red]✗[/]", str(e)))

    # System services
    for svc_name in ["firewalld", "usbguard", "auditd", "clamd"]:
        try:
            result = subprocess.run(["systemctl", "is-active", svc_name], capture_output=True, text=True, timeout=5)
            active = result.returncode == 0
            checks.append((svc_name, "[green]✓[/]" if active else "[yellow]⚠[/]", result.stdout.strip()))
        except Exception as e:
            checks.append((svc_name, "[red]✗[/]", str(e)))

    # Helpers
    detected = detect_helpers()
    available = sum(1 for v in detected.values() if v)
    checks.append(("Helpers", "[green]✓[/]" if available > 5 else "[yellow]⚠[/]", f"{available}/{len(HELPERS)} available"))

    # Disk
    try:
        result = subprocess.run(["df", "-h", "/"], capture_output=True, text=True, timeout=5)
        line = result.stdout.strip().split("\n")[-1]
        checks.append(("Disk /", "[green]✓[/]", line))
    except Exception as e:
        checks.append(("Disk /", "[red]✗[/]", str(e)))

    # Memory
    try:
        result = subprocess.run(["free", "-h"], capture_output=True, text=True, timeout=5)
        mem_line = [l for l in result.stdout.split("\n") if l.startswith("Mem:")]
        if mem_line:
            checks.append(("Memory", "[green]✓[/]", " ".join(mem_line[0].split()[1:4])))
    except Exception as e:
        checks.append(("Memory", "[red]✗[/]", str(e)))

    # Display
    table = Table(
        show_header=True,
        header_style="bright_magenta bold",
        border_style="bright_black",
        expand=False,
        box=None,
        padding=(0, 1),
    )
    table.add_column("Component", style="bright_cyan")
    table.add_column("Status", style="", width=6, justify="center")
    table.add_column("Details", style="dim")

    for name, status, details in checks:
        table.add_row(name, status, str(details))

    console.print(table)

    # Run gemma-bazzite-health if available
    if detected.get("gemma-bazzite-health"):
        console.print()
        console.print("[bright_green]Running gemma-bazzite-health...[/]")
        subprocess.run([str(HELPERS["gemma-bazzite-health"]["path"])])


def mode_dashboard():
    """Dashboard mode — safe read-only status view. No scans, no sudo."""
    global _CURRENT_MODE
    _CURRENT_MODE = "dashboard"

    detected = detect_helpers()
    config = load_config()

    # Use app shell layout when configured
    is_app_shell = config.get("ui", {}).get("layout", "classic") == "app_shell"
    if is_app_shell:
        render_app_shell(detected, config, "dashboard", show_footer=False)
    else:
        console.print("[bright_yellow bold]Status Dashboard[/]")
        console.print()

    # ── Core ─────────────────────────────────────────────────────────────────
    core_table = Table(show_header=False, box=None, padding=(0, 1))
    core_table.add_column("Component", style="bright_cyan")
    core_table.add_column("Status", style="")

    # Ollama
    try:
        req = urllib.request.Request(f"{OLLAMA_HOST}/api/tags", method="GET")
        with urllib.request.urlopen(req, timeout=3) as resp:
            data = json.loads(resp.read())
            models = data.get("models", [])
            core_table.add_row("Ollama", f"[green]online[/] ({len(models)} models)")
    except Exception:
        core_table.add_row("Ollama", "[red]offline[/]")

    core_table.add_row("Model", config.get("ollama", {}).get("model", MODEL))
    core_table.add_row("Config", "[green]OK[/]" if CONFIG_FILE.is_file() else "[yellow]missing[/]")
    core_table.add_row("Helpers", f"{sum(1 for v in detected.values() if v)}/{len(HELPERS)} available")

    # ── Voice ────────────────────────────────────────────────────────────────
    voice_ok = shutil.which("pw-record") and shutil.which("whisper-cli") and detected.get("gemma-voice-chat")
    core_table.add_row("Voice", "[green]ready[/]" if voice_ok else "[yellow]not configured[/]")

    # ── Memory ───────────────────────────────────────────────────────────────
    mem_ok = detected.get("gemma-memory-search") or detected.get("gemma-knowledge-search")
    core_table.add_row("Memory", "[green]ready[/]" if mem_ok else "[yellow]not configured[/]")

    # ── Repo ─────────────────────────────────────────────────────────────────
    gem_repo = Path.home() / "projects/gem"
    core_table.add_row("Repo", f"[green]OK[/] gem" if gem_repo.is_dir() else "[yellow]not found[/]")

    # ── Safety ───────────────────────────────────────────────────────────────
    core_table.add_row("Safety", "[green]advisory only[/]")

    console.print(core_table)
    console.print()

    # ── Feature Flags ────────────────────────────────────────────────────────
    features = config.get("features", {})
    feat_line = "  ".join(
        f"[green]{name}[/]" if features.get(name, False) else f"[dim]{name}[/]"
        for name in ("general", "security", "memory", "repo", "voice", "reports", "health")
    )
    console.print(f"[bright_cyan]Features:[/] {feat_line}")

    # ── Export ───────────────────────────────────────────────────────────────
    console.print()
    if detected.get("gemma-dashboard"):
        console.print("[dim]gemma-dashboard: Optional static export helper (not primary dashboard)[/]")
    else:
        console.print("[dim]gemma-dashboard: not installed[/]")

    # ── Integration ──────────────────────────────────────────────────────────
    integrations = load_integrations()
    if integrations:
        bl = integrations.get("bazzite_laptop", {})
        mcp = bl.get("mcp_routing_enabled", False)
        console.print(f"[dim]Integration: bazzite-laptop={bl.get('role', 'unknown')} MCP={'enabled' if mcp else 'disabled'}[/]")
    else:
        console.print("[dim]Integration: not configured[/]")

    console.print()
    console.print("[dim]Read-only. No scans. No system changes.[/]")


def mode_settings(subcmd: str = ""):
    """Settings mode — display/UI preferences only.

    This does not change security policy, helper behavior,
    or system configuration. Only UI display settings.
    """
    global _CURRENT_MODE
    _CURRENT_MODE = "settings"

    config = load_config()
    ui = config.setdefault("ui", {})

    sub = subcmd.strip().lower()

    if sub in ("theme", "th"):
        # Toggle between default and high_contrast
        current = ui.get("high_contrast", False)
        ui["high_contrast"] = not current
        save_config(config)
        state = "enabled" if ui["high_contrast"] else "disabled"
        console.print(f"[bright_cyan]High-contrast theme {state}.[/]")

    elif sub in ("ascii", "a"):
        # Toggle Unicode markers
        current = ui.get("use_unicode", True)
        ui["use_unicode"] = not current
        save_config(config)
        state = "Unicode" if ui["use_unicode"] else "ASCII"
        console.print(f"[bright_cyan]Display mode: {state}.[/]")

    elif sub in ("compact", "c"):
        # Toggle density
        current = ui.get("density", "normal")
        ui["density"] = "comfortable" if current == "compact" else "compact"
        save_config(config)
        console.print(f"[bright_cyan]Density set to {ui['density']}.[/]")

    elif sub in ("layout", "l"):
        # Toggle layout
        current = ui.get("layout", "app_shell")
        ui["layout"] = "classic" if current == "app_shell" else "app_shell"
        save_config(config)
        state = "app-shell" if ui["layout"] == "app_shell" else "classic"
        console.print(f"[bright_cyan]Layout set to {state}.[/]")
        console.print("[dim]Restart gemma-ui to see the change.[/]")

    elif sub in ("help", "h", "?", ""):
        # Show settings panel
        _print_settings_panel(config)

    else:
        console.print(f"[yellow]Unknown settings subcommand: {subcmd}[/]")
        console.print("[dim]Try: /settings theme, /settings ascii, /settings compact, /settings layout[/]")


def _print_settings_panel(config: dict):
    """Print the settings panel."""
    ui = config.get("ui", {})

    console.print("[bright_yellow bold]⚙ Settings[/]")
    console.print("[dim]Display/UI preferences only. No security or system changes.[/]")
    console.print()

    table = Table(show_header=False, box=None, padding=(0, 2))
    table.add_column("Setting", style="bright_cyan")
    table.add_column("Value", style="")
    table.add_column("Description", style="dim")

    table.add_row(
        "layout",
        ui.get("layout", "app_shell"),
        "app_shell or classic"
    )
    table.add_row(
        "density",
        ui.get("density", "normal"),
        "compact or comfortable"
    )
    table.add_row(
        "show_icons",
        "yes" if ui.get("show_icons", True) else "no",
        "Show icons in mode rail"
    )
    table.add_row(
        "use_unicode",
        "yes" if ui.get("use_unicode", True) else "no",
        "Unicode markers (✓/✗) or ASCII (OK/MISSING)"
    )
    table.add_row(
        "high_contrast",
        "yes" if ui.get("high_contrast", False) else "no",
        "High-contrast theme"
    )
    table.add_row(
        "show_timestamps",
        "yes" if ui.get("show_timestamps", True) else "no",
        "Show timestamps in chat"
    )

    console.print(table)
    console.print()

    console.print("[bright_cyan]Commands:[/]")
    console.print("  [bright_cyan]/settings theme[/]    Toggle high-contrast theme")
    console.print("  [bright_cyan]/settings ascii[/]    Toggle Unicode/ASCII markers")
    console.print("  [bright_cyan]/settings compact[/]  Toggle compact/comfortable density")
    console.print("  [bright_cyan]/settings layout[/]   Toggle app-shell/classic layout")
    console.print()
    console.print("[dim]Shortcuts: /theme, /ascii, /compact[/]")


