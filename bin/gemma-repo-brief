#!/usr/bin/env bash
set -Eeuo pipefail

# gemma-repo-brief - Bounded advisory repo summary through Gemma
# Reads only selected metadata/files. Does not edit or install.

TIMESTAMP=$(date +%Y%m%d-%H%M%S)
readonly TIMESTAMP
readonly REPORT_FILE="${HOME}/offload/security-reports/manual/gemma-repo-brief-${TIMESTAMP}.md"
readonly LOG_FILE="${HOME}/.local/state/bazzite-security/logs/gemma-repo-brief-${TIMESTAMP}.log"
readonly MODEL="${GEMMA_MODEL:-gemma4-e4b-bazzite}"
readonly PROJECTS_ROOT="${HOME}/projects"

usage() {
    cat <<'USAGE'
Usage: gemma-repo-brief /path/to/repo

Repo path must be inside ~/projects/. Reads bounded metadata and selected docs only.
USAGE
}

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') $*" | tee -a "$LOG_FILE"
}

error_exit() {
    log "ERROR: $*"
    exit 1
}

strip_ansi() {
    sed \
        -e 's/\x1b\[[0-9;]*[a-zA-Z]//g' \
        -e 's/\x1b][^\x07]*\x07//g' \
        -e 's/\x1b][^\x1b]*\x1b\\//g' \
        -e 's/\x1b[()][0-9A-Za-z]//g' \
        -e 's/\x1b[78]//g' \
        -e 's/\x1b\[[\?0-9]*[hl]//g' \
        -e 's/\x0e//g' \
        -e 's/\x0f//g' \
        -e 's/\r//g'
}

redact_stream() {
    sed -E \
        -e 's/(api[_-]?key|token|secret|password|passwd|bearer|authorization)[[:space:]]*[:=][[:space:]]*[^[:space:]]+/\1=[REDACTED]/Ig' \
        -e 's/(sk-[A-Za-z0-9_-]{20,})/[REDACTED_OPENAI_KEY]/g' \
        -e 's/(ghp_[A-Za-z0-9_]{20,})/[REDACTED_GITHUB_TOKEN]/g' \
        -e 's/(github_pat_[A-Za-z0-9_]{20,})/[REDACTED_GITHUB_TOKEN]/g'
}

append_file_excerpt() {
    local repo="$1"
    local relative="$2"
    local output="$3"
    local path="${repo}/${relative}"

    if [[ -f "$path" ]]; then
        {
            echo
            echo "===== ${relative} ====="
            sed -n '1,160p' "$path" | redact_stream
        } >> "$output"
    fi
}

main() {
    mkdir -p "$(dirname "$LOG_FILE")" "$(dirname "$REPORT_FILE")" "${HOME}/.cache/bazzite-security/ollama"

    if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        usage
        exit 0
    fi
    (($# == 1)) || { usage; error_exit "Provide exactly one repo path"; }

    local repo projects_real repo_real
    repo="$1"
    [[ -d "$repo" ]] || error_exit "Repo path is not a directory: $repo"
    [[ -d "$PROJECTS_ROOT" ]] || error_exit "Projects root does not exist: $PROJECTS_ROOT"

    projects_real=$(realpath "$PROJECTS_ROOT")
    repo_real=$(realpath "$repo")
    case "$repo_real" in
        "$projects_real"/*) ;;
        *) error_exit "Refusing repo outside ~/projects/: $repo_real" ;;
    esac

    log "=== Gemma Repo Brief ==="
    log "Timestamp: ${TIMESTAMP}"
    log "Model: ${MODEL}"
    log "Repo: ${repo_real}"
    log "Report: ${REPORT_FILE}"

    local temp_prompt temp_output
    temp_prompt=$(mktemp "${HOME}/.cache/bazzite-security/ollama/gemma-repo-brief-prompt-${TIMESTAMP}.XXXXXX")
    temp_output=$(mktemp "${HOME}/.cache/bazzite-security/ollama/gemma-repo-brief-output-${TIMESTAMP}.XXXXXX")

    {
        cat <<PROMPT
You are Gemma running locally through Ollama on a Bazzite/Fedora Atomic desktop.

Task: provide a bounded advisory repo brief from supplied excerpts only.

Rules:
- Do not edit files.
- Do not install dependencies.
- Do not recommend sudo, package changes, firewall changes, USBGuard changes, rpm-ostree changes, or systemd timer changes.
- Use only supplied excerpts.
- Return concise Markdown with these exact headings:
  - Current state
  - Likely project type
  - Changed files
  - Safe next validation commands
  - Risks/blockers

Repo: ${repo_real}

===== git status --short =====
PROMPT
        git -C "$repo_real" status --short 2>&1 | sed -n '1,120p' | redact_stream || true
        echo
        echo "===== git log --oneline -5 ====="
        git -C "$repo_real" log --oneline -5 2>&1 | sed -n '1,40p' | redact_stream || true
    } > "$temp_prompt"

    append_file_excerpt "$repo_real" "README.md" "$temp_prompt"
    append_file_excerpt "$repo_real" "AGENTS.md" "$temp_prompt"
    append_file_excerpt "$repo_real" "package.json" "$temp_prompt"
    append_file_excerpt "$repo_real" "pyproject.toml" "$temp_prompt"
    append_file_excerpt "$repo_real" "docs/ROADMAP.md" "$temp_prompt"
    append_file_excerpt "$repo_real" "docs/PHASE_INDEX.md" "$temp_prompt"

    if ollama run "$MODEL" --hidethinking < "$temp_prompt" > "$temp_output" 2>> "$LOG_FILE"; then
        {
            echo "# Gemma Repo Brief"
            echo
            echo "Generated: $(date -Iseconds)"
            echo "Model: ${MODEL}"
            echo "Repo: ${repo_real}"
            echo
            echo "## Current state"
            echo "Gemma was asked to summarize current state from bounded repo excerpts. See advisory details below."
            echo
            echo "## Likely project type"
            echo "Gemma was asked to infer likely project type from supplied files only. See advisory details below."
            echo
            echo "## Changed files"
            echo "Gemma was asked to summarize changed files from git status. See advisory details below."
            echo
            echo "## Safe next validation commands"
            echo "Gemma was asked to suggest safe validation commands only. See advisory details below."
            echo
            echo "## Risks/blockers"
            echo "Gemma was asked to identify risks and blockers from supplied excerpts only. See advisory details below."
            echo
            echo "## Gemma advisory details"
            strip_ansi < "$temp_output" | redact_stream
            echo
            echo "---"
            echo "Log: ${LOG_FILE}"
        } > "$REPORT_FILE"
        log "Report written to: ${REPORT_FILE}"
    else
        strip_ansi < "$temp_output" | redact_stream | tee -a "$LOG_FILE" >/dev/null || true
        rm -f "$temp_prompt" "$temp_output"
        error_exit "Gemma repo brief failed"
    fi

    rm -f "$temp_prompt" "$temp_output"
    log "Log written to: ${LOG_FILE}"
    printf 'Report: %s\nLog: %s\n' "$REPORT_FILE" "$LOG_FILE"
}

main "$@"
