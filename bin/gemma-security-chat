#!/usr/bin/env python3
"""
gemma-security-chat — Rich Terminal UI for Gemma Security Assistant

A beautiful, modern terminal interface for chatting with your local Gemma model
and executing security tools with visual feedback.

Usage:
    gemma-security-chat                    # Interactive chat mode
    gemma-security-chat --one-shot "msg"   # Single query mode
    gemma-security-chat --no-tools         # Chat without tool execution
    gemma-security-chat --history          # Show chat history
    gemma-security-chat --clear            # Clear chat history
    gemma-security-chat --tools            # List available tools

Requirements:
    - rich (pip install rich)
    - ollama running locally
"""

