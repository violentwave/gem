        "  • [bright_green]\"system health\"[/] → health_snapshot\n"
        "  • [bright_green]\"security briefing\"[/] → security_briefing\n"
        "  • [bright_green]\"what's running\"[/] → process_check\n"
        "  • [bright_green]\"any threats\"[/] → threat_lookup",
        border_style="dim",
        padding=(1, 2)
    )
    console.print(examples)


def print_tools_list():
    """Display tools in categorized columns."""
    categories = {}
    for name, info in TOOLS.items():
        cat = info.get("category", "General")
        if cat not in categories:
            categories[cat] = []
        categories[cat].append((name, info))
    
    console.print(Panel(
        "[bright_yellow]Security Tools by Category[/bright_yellow]",
        border_style="bright_yellow",
        padding=(1, 1)
    ))
    
    for cat, tools in sorted(categories.items()):
        console.print(f"\n[bright_magenta bold]{cat}[/]")
        for name, info in tools:
            sudo_badge = "[red][sudo][/]" if info["needs_sudo"] else ""
            console.print(f"  {info.get('icon', '🔧')} [bright_cyan]{name}[/] — {info['description']} {sudo_badge}")


# ── Core Functions ───────────────────────────────────────────────────────────

def ensure_dirs():
    for d in [HISTORY_DIR, REPORT_DIR, LOG_DIR]:
        d.mkdir(parents=True, exist_ok=True)


def load_history() -> List[Dict]:
    history_file = HISTORY_DIR / "current_session.json"
    if history_file.exists():
        try:
            with open(history_file) as f:
                return json.load(f)
        except (json.JSONDecodeError, IOError):
            return []
    return []


def save_history(messages: List[Dict]):
    history_file = HISTORY_DIR / "current_session.json"
    trimmed = messages[-MAX_HISTORY:] if len(messages) > MAX_HISTORY else messages
    try:
        with open(history_file, "w") as f:
            json.dump(trimmed, f, indent=2)
    except IOError:
        pass


def call_ollama(messages: List[Dict]) -> str:
    import urllib.request
    import urllib.error

    url = f"{OLLAMA_HOST}/api/chat"
    data = json.dumps({
        "model": MODEL,
        "messages": messages,
        "stream": False,
        "options": {
            "temperature": 0.3,
            "num_ctx": 8192,
        }
    }).encode("utf-8")

    req = urllib.request.Request(url, data=data, headers={"Content-Type": "application/json"}, method="POST")

    try:
        with urllib.request.urlopen(req, timeout=120) as resp:
            result = json.loads(resp.read().decode("utf-8"))
            return result.get("message", {}).get("content", "")
    except Exception as e:
        return f"Error: {e}"


def parse_tool_call(response: str) -> Tuple[Optional[str], str]:
    tool_pattern = re.compile(r'^TOOL:\s*(\w+)\s*$', re.MULTILINE)
    match = tool_pattern.search(response)
    if match:
        tool_name = match.group(1)
        cleaned = tool_pattern.sub('', response).strip()
        return tool_name, cleaned
    return None, response


def run_tool(tool_name: str) -> Tuple[bool, str]:
    if tool_name not in TOOLS:
        return False, f"Unknown tool: {tool_name}"

    tool = TOOLS[tool_name]
    command = tool["command"]
    timeout = tool["timeout"]
    needs_sudo = tool["needs_sudo"]

    if needs_sudo:
        try:
            result = subprocess.run(["sudo", "-n", "true"], capture_output=True, timeout=5)
            if result.returncode != 0:
                return False, "This tool requires sudo. Run 'sudo -v' first."
        except Exception as e:
            return False, f"Cannot verify sudo: {e}"

    try:
        result = subprocess.run(command, capture_output=True, text=True, timeout=timeout)
        output = result.stdout
        if result.stderr:
            output += f"\n[stderr]: {result.stderr}"
        if len(output) > 8000:
            output = output[:4000] + "\n... [output truncated] ...\n" + output[-4000:]
        return True, output
    except subprocess.TimeoutExpired:
        return False, f"Tool timed out after {timeout}s"
    except FileNotFoundError as e:
        return False, f"Command not found: {e.filename}"
    except Exception as e:
        return False, f"Error: {e}"


def save_chat_report(messages: List[Dict]):
    timestamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    report_file = REPORT_DIR / f"gemma-chat-report-{timestamp}.md"
    
    lines = ["# Gemma Security Chat Report", "", f"**Date:** {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}", f"**Model:** {MODEL}", ""]
    
    for msg in messages:
        if msg["role"] == "system":
            continue
        elif msg["role"] == "user":
            lines.extend([f"## User", f"{msg['content']}", ""])
        elif msg["role"] == "assistant":
            lines.extend([f"## Gemma", f"{msg['content']}", ""])
        elif msg["role"] == "tool":
            lines.extend([f"## Tool Output", f"```\n{msg['content']}\n```", ""])
    
    try:
        with open(report_file, "w") as f:
            f.write("\n".join(lines))
        console.print(f"[bright_green]✅ Report saved:[/] {report_file}")
    except IOError as e:
        console.print(f"[bright_red]❌ Could not save:[/] {e}")


# ── Interactive Chat ─────────────────────────────────────────────────────────

def interactive_chat(no_tools: bool = False):
    ensure_dirs()
    messages = load_history()
    
    if not messages or messages[0].get("role") != "system":
        messages = [{"role": "system", "content": SYSTEM_PROMPT}]
        save_history(messages)

    print_banner()

    while True:
        try:
            user_input = console.input("[bright_cyan bold]❯ [/]").strip()
        except (EOFError, KeyboardInterrupt):
            console.print("\n[dim]Goodbye! 👋[/]")
            break

        if not user_input:
            continue

        # Commands
        if user_input.lower() in ["/quit", "/exit", "/q"]:
            console.print("[dim]Goodbye! 👋[/]")
            break
        elif user_input.lower() in ["/help", "/h"]:
            print_help()
            continue
        elif user_input.lower() == "/tools":
            print_tools_list()
            continue
        elif user_input.lower() == "/clear":
            messages = [{"role": "system", "content": SYSTEM_PROMPT}]
            save_history(messages)
            console.print("[bright_green]✅ Chat history cleared[/]")
            continue
        elif user_input.lower() == "/history":
            console.print("\n[bright_magenta]Recent History[/]")
            for msg in messages[-10:]:
                if msg["role"] == "user":
                    console.print(f"  [bright_cyan]You:[/] {msg['content'][:60]}...")
                elif msg["role"] == "assistant":
                    console.print(f"  [bright_green]Gemma:[/] {msg['content'][:60]}...")
            continue
        elif user_input.lower() == "/save":
            save_chat_report(messages)
            continue

        # Display user message
        print_user_message(user_input)
        messages.append({"role": "user", "content": user_input})

        # Call Gemma
        with print_thinking():
            response = call_ollama(messages)

        tool_name, cleaned_response = parse_tool_call(response)

        if tool_name and not no_tools:
            # Tool suggested
            tool = TOOLS.get(tool_name, {})
            print_tool_suggestion(tool_name, tool.get("description", ""), tool.get("needs_sudo", False))
            
            # Ask for confirmation
            try:
                confirm = console.input("[bright_yellow]Run this tool? [y/N]: [/]").strip().lower()
            except (EOFError, KeyboardInterrupt):
                confirm = "n"

            if confirm in ["y", "yes"]:
                with print_running_tool(tool_name):
                    success, output = run_tool(tool_name)
                
                print_tool_output(tool_name, output, success)
                
                if success:
                    with print_analyzing():
                        analysis_prompt = (
                            f"The tool '{tool_name}' has been executed. "
                            f"Here is the output:\n\n```\n{output[:4000]}\n```\n\n"
                            f"Please analyze these results. Flag anything suspicious."
                        )
                        messages.append({"role": "assistant", "content": f"I'll run {tool_name}. {cleaned_response}"})
                        messages.append({"role": "user", "content": analysis_prompt})
                        analysis = call_ollama(messages)
                        messages.pop()  # Remove analysis prompt
                        messages.pop()  # Remove tool suggestion
                    
                    print_gemma_message(analysis)
                    messages.append({"role": "assistant", "content": analysis})
                else:
                    console.print(f"[bright_red]❌ Tool failed:[/] {output}")
                    messages.append({"role": "assistant", "content": f"Tool {tool_name} failed: {output}"})
            else:
                console.print("[dim]🚫 Tool execution cancelled[/]")
                messages.append({"role": "assistant", "content": f"User declined {tool_name}. {cleaned_response}"})
        else:
            # Normal response
            print_gemma_message(response)
            messages.append({"role": "assistant", "content": response})

        save_history(messages)
        print_divider()


def one_shot_chat(message: str, no_tools: bool = False):
    ensure_dirs()
    messages = [
        {"role": "system", "content": SYSTEM_PROMPT},
        {"role": "user", "content": message}
    ]

    print_banner()
    print_user_message(message)

    with print_thinking():
        response = call_ollama(messages)
    
    tool_name, cleaned_response = parse_tool_call(response)

    if tool_name and not no_tools:
        tool = TOOLS.get(tool_name, {})
        print_tool_suggestion(tool_name, tool.get("description", ""), tool.get("needs_sudo", False))
        
        try:
            confirm = console.input("[bright_yellow]Run this tool? [y/N]: [/]").strip().lower()
        except (EOFError, KeyboardInterrupt):
            confirm = "n"

        if confirm in ["y", "yes"]:
            with print_running_tool(tool_name):
                success, output = run_tool(tool_name)
            
            print_tool_output(tool_name, output, success)
            
            if success:
                with print_analyzing():
                    analysis_prompt = (
                        f"Tool '{tool_name}' executed. Output:\n```\n{output[:4000]}\n```\n"
                        f"Analyze and provide recommendations."
                    )
                    messages.extend([
                        {"role": "assistant", "content": f"I'll run {tool_name}. {cleaned_response}"},
                        {"role": "user", "content": analysis_prompt}
                    ])
                    analysis = call_ollama(messages)
                
                print_gemma_message(analysis)
            else:
                console.print(f"[bright_red]❌ Failed:[/] {output}")
        else:
            console.print("[dim]🚫 Cancelled[/]")
    else:
        print_gemma_message(response)


def show_history():
    messages = load_history()
    console.print(f"\n[bright_magenta]Chat History ({len(messages)} messages)[/]")
    console.print(Rule(style="bright_black"))
    for i, msg in enumerate(messages):
        if msg["role"] == "system":
            continue
        content = msg["content"][:80].replace("\n", " ")
        style = "bright_cyan" if msg["role"] == "user" else "bright_green"
        console.print(f"{i:3d}. [{style}]{msg['role']:10s}[/] {content}...")


def clear_history():
    history_file = HISTORY_DIR / "current_session.json"
    if history_file.exists():
        history_file.unlink()
    console.print("[bright_green]✅ Chat history cleared[/]")


# ── Main ─────────────────────────────────────────────────────────────────────

def main():
    args = sys.argv[1:]

    if "--help" in args or "-h" in args:
        console.print(__doc__)
        sys.exit(0)

    if "--history" in args:
        show_history()
        sys.exit(0)

    if "--clear" in args:
        clear_history()
        sys.exit(0)

    if "--tools" in args:
        print_tools_list()
        sys.exit(0)

    no_tools = "--no-tools" in args

    if "--one-shot" in args:
        idx = args.index("--one-shot")
        if idx + 1 < len(args):
            one_shot_chat(args[idx + 1], no_tools)
        else:
            console.print("[bright_red]Error:[/] --one-shot requires a message")
            sys.exit(1)
    else:
        interactive_chat(no_tools)


if __name__ == "__main__":
    main()
