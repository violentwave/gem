- clamav_scan: Scan /tmp directory for malware with ClamAV
- audit_log: Check today's security audit logs
- security_summary: Quick overview of all security services

Current date: {datetime.now().strftime('%Y-%m-%d')}
"""

# ── UI Helper Functions ──────────────────────────────────────────────────────

def print_banner():
    """Print beautiful ASCII art banner."""
    banner_text = """
    ╔══════════════════════════════════════════════════════════════╗
    ║                                                              ║
    ║   🔒  Gemma Security Assistant  🔒                           ║
    ║                                                              ║
    ║   Local AI-powered security analysis for Bazzite            ║
    ║                                                              ║
    ╚══════════════════════════════════════════════════════════════╝
    """
    console.print(Panel(
        Align.center(Text(banner_text, style="bright_cyan")),
        border_style="bright_magenta",
        padding=(1, 2),
        title="[bright_yellow]Terminal Interface[/bright_yellow]",
        subtitle=f"[dim]{MODEL}[/dim]"
    ))
    
    # Quick stats bar
    stats = Table.grid(expand=True)
    stats.add_column(justify="center", ratio=1)
    stats.add_column(justify="center", ratio=1)
    stats.add_column(justify="center", ratio=1)
    stats.add_row(
        f"[bright_green]{len(TOOLS)}[/bright_green] tools available",
        f"[bright_blue]Advisory only[/bright_blue] — you decide",
        f"[bright_yellow]Type /help for commands[/bright_yellow]"
    )
    console.print(stats)
    console.print()


def print_user_message(content: str):
    """Display user message in a styled panel."""
    console.print(Panel(
        Markdown(content),
        border_style="bright_cyan",
        title="[bright_cyan]You[/bright_cyan]",
        title_align="left",
        padding=(1, 2)
    ))


def print_gemma_message(content: str):
    """Display Gemma response with markdown rendering."""
    # Strip TOOL: lines for display
    display_content = re.sub(r'^TOOL:\s*\w+\s*$', '', content, flags=re.MULTILINE).strip()
    
    if display_content:
        console.print(Panel(
            Markdown(display_content),
            border_style="bright_green",
            title="[bright_green]Gemma[/bright_green]",
            title_align="left",
            padding=(1, 2)
        ))


def print_tool_suggestion(tool_name: str, description: str, needs_sudo: bool):
    """Display tool suggestion with styling."""
    tool = TOOLS.get(tool_name, {})
    icon = tool.get("icon", "🔧")
    category = tool.get("category", "General")
    
    sudo_badge = "[bright_red bold] ⚠ REQUIRES SUDO[/bright_red bold]" if needs_sudo else "[bright_green] ✓ No sudo needed[/bright_green]"
    
    content = Text()
    content.append(f"{icon} ", style="")
    content.append(f"{tool_name}", style="bright_yellow bold")
    content.append(f"  [{category}]\n", style="dim")
    content.append(f"{description}\n", style="")
    content.append(f"\n{sudo_badge}", style="")
    
    console.print(Panel(
        content,
        border_style="bright_yellow",
        title="[bright_yellow]🔧 Tool Suggested[/bright_yellow]",
        title_align="left",
        padding=(1, 2)
    ))


def print_tool_output(tool_name: str, output: str, success: bool):
    """Display tool execution results."""
    status_icon = "✅" if success else "❌"
    status_color = "bright_green" if success else "bright_red"
    
    # Truncate output for display
    display_output = output[:3000] + "\n... [output truncated] ..." if len(output) > 3000 else output
    
    console.print(Panel(
        Syntax(display_output, "bash", theme="monokai", line_numbers=False),
        border_style=status_color,
        title=f"[{status_color}]{status_icon} {tool_name}[/]",
        title_align="left",
        padding=(1, 1)
    ))


def print_thinking():
    """Show thinking indicator."""
    return console.status("[bright_blue]Gemma is thinking...[/bright_blue]", spinner="dots")


def print_running_tool(tool_name: str):
    """Show tool execution spinner."""
    return console.status(f"[bright_yellow]Running {tool_name}...[/bright_yellow]", spinner="earth")


def print_analyzing():
    """Show analysis indicator."""
    return console.status("[bright_green]Gemma is analyzing results...[/bright_green]", spinner="dots2")


def print_divider():
    """Print a decorative divider."""
    console.print(Rule(style="bright_black"))


