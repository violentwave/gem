def normalize_plain_command(text):
    """Return an obvious slash command for exact no-slash shortcuts."""
    raw = text.strip()
    normalized = re.sub(r"\s+", " ", raw.lower())
    if not normalized or raw.startswith("/"):
        return None
    exact = {
        "reports latest": "/reports latest",
        "reports": "/reports",
        "dashboard": "/dashboard",
        "status": "/dashboard",
        "voice status": "/voice",
        "voice": "/voice",
        "settings": "/settings",
        "clear": "/clear",
        "quit": "/quit",
        "exit": "/quit",
    }
    if normalized in exact:
        return exact[normalized]
    if normalized.startswith("memory search "):
        query = raw.split(None, 2)[2].strip()
        if query:
            return f"/memory search {query}"
    return None

def route_chat_intent(text):
    """Deterministically route natural-language chat before model fallback."""
    raw = text.strip()
    normalized = re.sub(r"\s+", " ", raw.lower())
    words = set(re.findall(r"[a-z0-9][a-z0-9_-]*", normalized))

    def result(intent, confidence, action, reason):
        return {
            "intent": intent,
            "confidence": confidence,
            "action": action,
            "reason": reason,
        }

    if not normalized:
        return result("general_chat", 0.0, "call_gemma", "empty input")

    security_phrases = (
        "check firewall", "change firewall", "scan rootkit", "run clamav",
        "run clamscan", "run lynis", "start audit", "modify ssh",
        "restart ssh", "change usbguard",
    )
    if any(phrase in normalized for phrase in security_phrases):
        return result(
            "security_confirm_required",
            0.95,
            "show_confirmation_required",
            "security-sensitive tool request requires explicit confirmation outside chat routing",
        )
    if ("run" in words or "scan" in words or "check" in words) and (words & SECURITY_CONFIRM_TERMS):
        return result(
            "security_confirm_required",
            0.88,
            "show_confirmation_required",
            "security-sensitive verb and target detected",
        )

    if normalized in {"help", "what can you do", "commands"}:
        return result("help", 0.95, "show_help", "help request")
    if normalized in {"settings", "preferences", "configuration"}:
        return result("settings", 0.92, "show_settings", "settings request")
    if normalized in {"voice", "voice status", "audio status", "speech status"} or normalized.startswith("voice "):
        return result("voice_status", 0.93, "show_voice_status", "voice status request")
    if normalized in {"dashboard", "status", "show dashboard", "show status", "system status"}:
        return result("dashboard", 0.94, "show_dashboard", "dashboard/status request")
    if any(phrase in normalized for phrase in ("show latest report", "latest report", "most recent report", "open latest report")):
        return result("reports_latest", 0.94, "show_latest_report", "latest report request")
    if any(phrase in normalized for phrase in ("list reports", "show reports", "recent reports", "reports list")) or normalized == "reports":
        return result("reports_list", 0.92, "show_reports_list", "reports list request")

    if any(term in normalized for term in MEMORY_TERMS):
        return result("memory_auto", 0.88, "retrieve_memory_then_gemma", "memory/decision recall request")
    if normalized.startswith(("search memory for ", "memory search ", "find in memory ")):
        return result("memory_auto", 0.94, "retrieve_memory_then_gemma", "explicit memory search request")

    return result("general_chat", 0.52, "call_gemma", "no deterministic route matched")

def _safe_addstr(win, y, x, text, attr=0):
    height, width = win.getmaxyx()
    if y < 0 or y >= height or x >= width:
        return
    if x < 0:
        text = text[abs(x):]
        x = 0
    text = str(text).replace("\n", " ")
    max_len = max(0, width - x - 1)
    if max_len:
        try:
            win.addstr(y, x, text[:max_len], attr)
        except curses.error:
            pass

def _load_json(path):
    try:
        if path.is_file():
            return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}
    return {}

def _ollama_status(host=OLLAMA_HOST):
    try:
        req = urllib.request.Request(f"{host}/api/tags", method="GET")
        with urllib.request.urlopen(req, timeout=1.5) as resp:
            data = json.loads(resp.read())
        return f"online:{len(data.get('models', []))}"
    except Exception:
        return "offline"

def _helper_count():
    try:
        import importlib.machinery
        import importlib.util
        loader = importlib.machinery.SourceFileLoader("gemma_ui", str(BIN_DIR / "gemma-ui"))
        spec = importlib.util.spec_from_loader(loader.name, loader)
        gemma_ui = importlib.util.module_from_spec(spec)
        loader.exec_module(gemma_ui)
        detected = gemma_ui.detect_helpers()
        available = sum(1 for v in detected.values() if v)
        return f"{available}/{len(gemma_ui.HELPERS)}"
    except Exception:
        available = 0
        for name in HELPERS:
            if (BIN_DIR / name).is_file() or shutil.which(name):
                available += 1
        return f"{available}/{len(HELPERS)}"

def _voice_status():
    if shutil.which("pw-record") and shutil.which("whisper-cli") and ((BIN_DIR / "gemma-voice-chat").is_file() or shutil.which("gemma-voice-chat")):
        return "ready"
    return "manual"

def _memory_status():
    if (BIN_DIR / "gemma-memory-search").is_file() or shutil.which("gemma-memory-search"):
        return "ready"
    if (BIN_DIR / "gemma-knowledge-search").is_file() or shutil.which("gemma-knowledge-search"):
        return "fallback"
    return "missing"

def _call_ollama_stream(prompt_text, out_queue, model=MODEL, host=OLLAMA_HOST, timeout=120):
    try:
        try:
            req = urllib.request.Request(f"{host}/api/tags", method="GET")
            with urllib.request.urlopen(req, timeout=1.5) as resp:
                data = json.loads(resp.read())
                models = [m.get("name") for m in data.get("models", [])]
                if model not in models and f"{model}:latest" not in models and model.replace(":latest", "") not in models:
                    out_queue.put(("error", f"Model '{model}' not found. Check 'ollama ps' and 'gemma-bazzite-health'."))
                    return
        except Exception:
            out_queue.put(("error", f"Ollama unreachable at {host} (timeout={timeout}s). Check 'ollama ps' and 'gemma-bazzite-health'."))
            return

        req_data = json.dumps({
            "model": model,
            "prompt": prompt_text,
            "stream": True
        }).encode("utf-8")
        req = urllib.request.Request(
            f"{host}/api/generate",
            data=req_data,
            method="POST",
            headers={"Content-Type": "application/json"}
        )
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            for line in resp:
                if line:
                    data = json.loads(line)
                    out_queue.put(("chunk", data.get("response", "")))
                    if data.get("done"):
                        out_queue.put(("done", ""))
                        break
    except Exception as e:
        out_queue.put(("error", f"Timeout or error connecting to Ollama at {host} (timeout={timeout}s): {e}. Suggestion: check 'ollama ps' and 'gemma-bazzite-health'."))

def _wrap_lines(text, prefix="", width=60):
    lines = text.split("\n")
    wrapped = []
    in_code_block = False
    
    for i, line in enumerate(lines):
        if line.strip().startswith("```"):
            in_code_block = not in_code_block
            
        curr_prefix = prefix if i == 0 else ("│ " + " " * max(0, len(prefix) - 2) if prefix.startswith("│") else "")
        if not curr_prefix and prefix.startswith("│"):
            curr_prefix = "│ "
            
        if not line.strip():
            wrapped.append(curr_prefix.rstrip() if prefix.startswith("│") else "")
            continue
            
        stripped = line.lstrip()
        indent_spaces = len(line) - len(stripped)
        
        sub_indent = "  " if stripped.startswith(("- ", "* ")) or (stripped and stripped[0].isdigit() and ". " in stripped[:4]) else ""
        
        if in_code_block:
             indent_spaces += 2
             
        init_ind = curr_prefix + " " * indent_spaces
        sub_ind = curr_prefix + " " * indent_spaces + sub_indent
        
        w = textwrap.wrap(
            stripped, 
            width=width, 
            initial_indent=init_ind, 
            subsequent_indent=sub_ind,
            drop_whitespace=True
        )
        wrapped.extend(w)
        
    return wrapped

def _run_helper_stream(cmd_args, out_queue):
    try:
        raw_lines = []
        process = subprocess.Popen(
            cmd_args,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            bufsize=1
        )
        for line in process.stdout:
            raw_lines.append(line)
            out_queue.put(("chunk", line))
        process.wait()
        out_queue.put(("debug", "$ " + " ".join(cmd_args) + "\n" + "".join(raw_lines)))
        out_queue.put(("done", ""))
    except Exception as e:
        out_queue.put(("error", f"Failed to run {' '.join(cmd_args)}: {e}"))

def _suggest_security_action(text):
    normalized = text.lower()
    if "firewall" in normalized or "firewalld" in normalized:
        return "firewall_status"
    if "usb" in normalized or "usbguard" in normalized:
        return "usb_devices"
    if "process" in normalized or "running" in normalized or "connection" in normalized:
        return "process_check"
    if "system" in normalized or "host" in normalized or "info" in normalized:
        return "system_info"
    if "security" in normalized or "status" in normalized:
        return "security_summary"
    if any(term in normalized for term in ("clamav", "clamscan", "lynis", "rootkit", "audit", "auditd", "ssh", "systemd", "rpm-ostree")):
        return "manual_workflow_required"
    return "security_summary"

def _helper_available(name):
    return (BIN_DIR / name).is_file() or shutil.which(name)

def _looks_like_exact_policy_path_question(text):
    normalized = text.lower()
    words = set(re.findall(r"[a-z0-9][a-z0-9_-]*", normalized))
    return bool(words & EXACT_POLICY_PATH_TERMS) or any(
        phrase in normalized for phrase in ("where should", "where do", "what path", "which path")
    )

def _parse_keyed_output(output):
    parsed = {}
    for line in output.splitlines():
        if ":" not in line:
            continue
        key, value = line.split(":", 1)
        key = re.sub(r"^[\s>*#`\-]+", "", key).strip()
        key = re.sub(r"\*\*|`", "", key).strip().lower().replace(" ", "_")
        if key:
            parsed[key] = value.strip().strip("`*")
    return parsed

def _clean_source_list(value, limit=3):
    if not value or value.lower() in {"none", "n/a"}:
        return []
    cleaned = re.sub(r"\([^)]*\)", "", value)
    parts = [p.strip(" ,;") for p in re.split(r"[,;]", cleaned)]
    return [p for p in parts if p][:limit]

def _memory_confidence(parsed):
    for key in ("confidence", "recommendation_confidence"):
        value = parsed.get(key, "").strip()
        if value:
            return value.strip("`")
    match = re.search(r"\bconfidence=([a-z0-9_.-]+)", parsed.get("answerability_status", ""), re.IGNORECASE)
    if match:
        return match.group(1)
    return "unknown"

def _memory_direct_source_count(parsed):
    status = parsed.get("answerability_status", "")
    total = 0
    found = False
    for key in ("ruvector_direct", "stage3a_direct"):
        match = re.search(rf"\b{key}=(\d+)", status, re.IGNORECASE)
        if match:
            found = True
            total += int(match.group(1))
    return total if found else None

def _memory_search_insufficient(raw_output, returncode):
    if returncode != 0:
        return True
    parsed = _parse_keyed_output(raw_output)
    recommendation = parsed.get("final_recommendation", "").lower()
    if recommendation in {"insufficient_evidence", "ruvector_unavailable_use_stage3a", "stop_human_review_required"}:
        return True
    fallback_status = parsed.get("fallback_status", "").lower()
    if fallback_status and "stage3a" in fallback_status and "baseline" not in fallback_status:
        return True
    confidence = _memory_confidence(parsed).lower()
    if confidence in {"low", "weak", "unknown"}:
        return True
    direct_count = _memory_direct_source_count(parsed)
    if direct_count == 0:
        return True
    return False

def _expanded_memory_query(query):
    normalized = re.sub(r"\s+", " ", query.lower()).strip()
    policy_terms = (
        "what did we decide about ruvector",
        "ruvector promotion decision",
        "is ruvector default",
        "stage 3a fallback",
        "stage three a fallback",
    )
    if any(term in normalized for term in policy_terms):
        return query + " " + " ".join(RUVECTOR_POLICY_EXPANSION_TERMS)
    return query

def _memory_sources_from_output(raw_output):
    parsed = _parse_keyed_output(raw_output)
    sources = _clean_source_list(parsed.get("ruvector_top_sources", ""))
    if not sources:
        sources = _clean_source_list(parsed.get("ruvector_sources", ""))
    if not sources:
        sources = _clean_source_list(parsed.get("stage3a_top_sources", ""))
    if not sources:
        sources = _clean_source_list(parsed.get("stage_3a_sources", ""))
    if not sources:
        source_lines = []
        for line in raw_output.splitlines():
            match = re.match(r"source:\s*(.+)", line.strip(), re.IGNORECASE)
            if match:
                source_lines.append(match.group(1))
        sources = _clean_source_list(", ".join(source_lines))
    return sources

def _source_family_label(source_label, parsed):
    fallback_status = parsed.get("fallback_status", "").lower()
    recommendation = parsed.get("final_recommendation", "").lower()
    if (
        "RuVector" in source_label
        and "Stage 3A" in source_label
        and ("stage3a" in fallback_status or "stage3a" in recommendation or "fallback" in fallback_status)
    ):
        return "fallback"
    if "RuVector" in source_label:
        return "RuVector"
    if "Stage 3A" in source_label:
        return "Stage 3A"
    return "fallback"

def _compact_memory_panel(query, raw_output, source_label, status_note, route_confidence=0.88):
    parsed = _parse_keyed_output(raw_output)
    sources = _memory_sources_from_output(raw_output)
    source_family = _source_family_label(source_label, parsed)
    confidence = _memory_confidence(parsed)
    if confidence == "unknown":
        confidence = f"{route_confidence:.2f}"
    panel = [
        f"│ Routed: memory_auto · {source_family} · read-only · confidence {confidence}",
        "│ Sources:",
    ]
    if sources:
        panel.extend(f"│   - {source}" for source in sources[:3])
    else:
        panel.append("│   - not available")
    panel.append("│ Answer:")
    return panel

def _format_report_size(size):
    if size < 1024:
        return f"{size} B"
    if size < 1024 * 1024:
        return f"{size / 1024:.1f} KB"
    return f"{size / (1024 * 1024):.1f} MB"

def _sanitize_report_preview(text):
    home = re.escape(str(HOME))
    text = re.sub(home + r"/", "~/", text)
    text = re.sub(r"/var/home/[^\s)]+/", "~/", text)
    text = re.sub(r"/home/[^\s)]+/", "~/", text)
    text = re.sub(r"\s+", " ", text).strip()
    return text

def _report_excerpt(path, max_chars=240):
    try:
        content = path.read_text(encoding="utf-8", errors="replace")
    except Exception as exc:
        return f"Preview unavailable: {exc}"
    lines = []
    for raw_line in content.splitlines():
        line = _sanitize_report_preview(raw_line)
        if line:
            lines.append(line)
        if len(" ".join(lines)) >= max_chars:
            break
    excerpt = " ".join(lines).strip()
    if not excerpt:
        return "(empty report)"
    if len(excerpt) > max_chars:
        excerpt = excerpt[: max_chars - 3].rstrip() + "..."
    return excerpt

def _report_preview_lines(path, width, max_lines=3):
    excerpt = _report_excerpt(path)
    if not excerpt:
        return ["(empty report)"]
    return textwrap.wrap(excerpt, width=max(24, width), break_long_words=False)[:max_lines]

def _report_cards(files, include_preview=True, limit=5, width=88):
    import datetime
    cards = []
    for path, mtime, size in files[:limit]:
        dt = datetime.datetime.fromtimestamp(mtime).strftime("%Y-%m-%d %H:%M:%S")
        cards.extend([
            f"│ Report: {path.name}",
            f"│   modified: {dt}",
            f"│   size: {_format_report_size(size)}",
        ])
        if include_preview:
            preview_width = max(24, width - len("│   preview: "))
            preview_lines = _report_preview_lines(path, preview_width, max_lines=3)
            for idx, line in enumerate(preview_lines):
                prefix = "│   preview: " if idx == 0 else "│            "
                cards.append(f"{prefix}{line}")
        cards.append("│")
    return cards

def _run_command_capture(cmd_args, timeout):
    try:
        result = subprocess.run(cmd_args, capture_output=True, text=True, timeout=timeout)
        raw = (result.stdout or "")
        if result.stderr:
            raw += ("\n" if raw else "") + result.stderr
        return result.returncode, raw
    except subprocess.TimeoutExpired:
        return 124, f"{cmd_args[0]} timed out after {timeout}s."
    except Exception as exc:
        return 1, f"Failed to run {' '.join(cmd_args)}: {exc}"

def _build_memory_prompt(query, context):
    clipped = context.strip()[:9000]
    return "\n".join([
        "You are Gemma running locally through Ollama on a Bazzite/Fedora Atomic desktop.",
        "Answer the user's question using the read-only retrieved context below.",
        "Do not claim to have changed files, executed security tools, ingested memory, trained, or updated indexes.",
        "If the context contains a Known Project Policy section, treat it as high-priority project policy evidence.",
        "Keep the answer concise and human-readable.",
        "",
        f"User question: {query}",
        "",
        "READ-ONLY RETRIEVED CONTEXT:",
        clipped if clipped else "No retrieved context was available.",
    ])

def _known_project_policy_context(query):
    expanded = _expanded_memory_query(query)
    if expanded == query:
        return ""
    return "\n".join([
        "## Known Project Policy: RuVector / Stage 3A",
        "- RuVector remains a supervised prototype / supervised-secondary memory source, not the production default.",
        "- Stage 3A deterministic retrieval remains the canonical fallback.",
        "- RuVector promotion to default was denied until explicit future quality gates pass.",
        "- Relevant policy terms: " + "; ".join(RUVECTOR_POLICY_EXPANSION_TERMS),
    ])

def _run_memory_auto_worker(query, out_queue, model, host):
    raw_sections = []
    source_label = "Stage 3A"
    status_note = "fallback search"
    context = ""
    expanded_query = _expanded_memory_query(query)
    policy_context = _known_project_policy_context(query)

    if _helper_available("gemma-memory-search"):
        rc, raw = _run_command_capture(["gemma-memory-search", expanded_query], timeout=75)
        raw_sections.append(f"$ gemma-memory-search {expanded_query}\n" + raw)
        context = raw
        source_label = "RuVector"
        status_note = "read-only semantic search"
        needs_stage3a = _memory_search_insufficient(raw, rc) or _looks_like_exact_policy_path_question(query)
    else:
        needs_stage3a = True
        raw = "gemma-memory-search unavailable; using Stage 3A fallback."
        raw_sections.append(raw)
        context = raw

    if needs_stage3a:
        if _helper_available("gemma-knowledge-rag"):
            rc2, raw2 = _run_command_capture(["gemma-knowledge-rag", expanded_query], timeout=210)
            raw_sections.append(f"$ gemma-knowledge-rag {expanded_query}\n" + raw2)
            context += "\n\n" + raw2
            source_label = f"{source_label} + Stage 3A" if source_label != "Stage 3A" else "Stage 3A"
            status_note = "Stage 3A read-only support"
        elif _helper_available("gemma-knowledge-search"):
            rc2, raw2 = _run_command_capture(["gemma-knowledge-search", expanded_query], timeout=45)
            raw_sections.append(f"$ gemma-knowledge-search {expanded_query}\n" + raw2)
            context += "\n\n" + raw2
            source_label = f"{source_label} + Stage 3A" if source_label != "Stage 3A" else "Stage 3A"
            status_note = "Stage 3A read-only search support"

    if policy_context:
        context = policy_context + "\n\n" + context

    raw_debug = "\n\n".join(raw_sections)
    out_queue.put(("debug", raw_debug))
    out_queue.put(("append_lines", _compact_memory_panel(query, raw_debug, source_label, status_note)))
    out_queue.put(("start_stream", "│ Answer: "))
    _call_ollama_stream(_build_memory_prompt(query, context), out_queue, model=model, host=host, timeout=120)

class GemmaTui:
    def __init__(self, stdscr):
        self.stdscr = stdscr
        self.mode = "welcome"
        self.input_text = ""
        self.cursor_pos = 0
        self.scroll = 0
        self.lines = []
        self.status = "Ready"
        self.running = True
        self.config = _load_json(CONFIG_FILE)
        
        import os
        host_env = os.environ.get("OLLAMA_HOST")
        if host_env:
            self.ollama_host = host_env
        else:
            h = self.config.get("ollama", {}).get("host", "127.0.0.1")
            p = self.config.get("ollama", {}).get("port", 11434)
            self.ollama_host = f"http://{h}:{p}" if "http" not in str(h) else str(h)
        self.model = self.config.get("ollama", {}).get("model", MODEL)
        
        self.is_generating = False
        self.gen_queue = queue.Queue()
        self.current_response = ""
        self.last_debug_output = "No routed helper output yet."
        self.pending_action = None
        
        self._reset_welcome()

    def _reset_welcome(self):
        self.mode = "welcome"
        self.lines = [
            "╭─ Welcome to Gemma Local Agent",
            "│",
            "│  Ask naturally. I route memory, reports, dashboard, voice status,",
            "│  and confirmation-required safety checks for you.",
            "│",
            "│  Try:",
            "│    what did we decide about ruvector?",
            "│    show latest report",
            "│    list reports",
            "│    dashboard",
            "│    voice status",
            "│    check firewall",
            "│",
            "│  Shortcuts still work: /debug last, /clear, /quit",
            "│",
            "╰─ This prototype does not execute security tools.",
        ]
        self.scroll = 0

    def init_colors(self):
        self.has_colors = curses.has_colors()
        if self.has_colors:
            curses.start_color()
            curses.use_default_colors()
            bg = -1
            curses.init_pair(1, curses.COLOR_CYAN, bg)
            curses.init_pair(2, curses.COLOR_GREEN, bg)
            curses.init_pair(3, curses.COLOR_YELLOW, bg)
            curses.init_pair(4, curses.COLOR_RED, bg)
            curses.init_pair(5, curses.COLOR_BLUE, bg)

    def style(self, name):
        if not hasattr(self, 'has_colors'):
            self.has_colors = False
            
        if name == "header":
            return curses.color_pair(1) | curses.A_BOLD if self.has_colors else curses.A_BOLD | curses.A_UNDERLINE
        elif name == "title":
            return curses.color_pair(1) | curses.A_BOLD if self.has_colors else curses.A_BOLD
        elif name == "active_tab":
            return curses.color_pair(1) | curses.A_BOLD if self.has_colors else curses.A_BOLD
        elif name == "inactive_tab":
            return curses.A_DIM
        elif name == "ok":
            return curses.color_pair(2) if self.has_colors else 0
        elif name == "warn":
            return curses.color_pair(3) if self.has_colors else 0
        elif name == "error":
            return curses.color_pair(4) if self.has_colors else curses.A_BOLD
        elif name == "muted":
            return curses.A_DIM
        elif name == "user":
            return curses.color_pair(1) | curses.A_BOLD if self.has_colors else curses.A_BOLD
        elif name == "assistant":
            return curses.color_pair(2) if self.has_colors else 0
        elif name == "footer":
            return curses.color_pair(1) | curses.A_DIM if self.has_colors else curses.A_DIM
        elif name == "input":
            return curses.color_pair(1) | curses.A_BOLD if self.has_colors else curses.A_BOLD
        elif name == "frame":
            return curses.color_pair(5) if self.has_colors else curses.A_DIM
        return 0

    def run(self):
        self.init_colors()
        curses.curs_set(1)
        self.stdscr.timeout(50) # 50ms timeout for responsive streaming
        self.stdscr.keypad(True)
        while self.running:
            self._process_queue()
            self.draw()
            ch = self.stdscr.getch()
            if ch != curses.ERR:
                self.handle_key(ch)

    def _process_queue(self):
        while not self.gen_queue.empty():
            msg_type, content = self.gen_queue.get_nowait()
            if msg_type == "chunk":
                self.current_response += content
                self._update_streaming_response()
            elif msg_type == "error":
                self.current_response += f"\n[Error: {content}]"
                self._update_streaming_response()
                self.is_generating = False
                self.status = "Ready"
            elif msg_type == "done":
                self.is_generating = False
                self.status = "Ready"
            elif msg_type == "debug":
                self.last_debug_output = content or "No helper output captured."
            elif msg_type == "append_lines":
                self.lines.extend(content)
                self.lines.append("│")
                self.scroll = max(0, len(self.lines) - 1)
            elif msg_type == "start_stream":
                self.current_response = ""
                self.stream_start_idx = len(self.lines)
                self.stream_prefix = content or "│ Gemma: "
                self.lines.append(f"{self.stream_prefix}thinking...")
                self.scroll = max(0, len(self.lines) - 1)

    def _update_streaming_response(self):
        if not hasattr(self, 'stream_start_idx'):
            return
            
        _, width = self.stdscr.getmaxyx()
        max_width = max(20, width - 4)
        prefix = getattr(self, 'stream_prefix', "│ Gemma: ")
        wrapped = _wrap_lines(self.current_response, prefix=prefix, width=max_width)
        self.lines = self.lines[:self.stream_start_idx] + wrapped
        self.scroll = max(0, len(self.lines) - 1)

    def draw(self):
        self.stdscr.erase()
        height, width = self.stdscr.getmaxyx()
        if height < 10 or width < 50:
            _safe_addstr(self.stdscr, 0, 0, "Terminal too small for gemma-ui-tui (min 50x10)", self.style("warn"))
            self.stdscr.refresh()
            return
        self.draw_header(width)
        self.draw_tabs(width)
        self.draw_body(height, width)
        self.draw_footer(height, width)
        self.stdscr.refresh()

    def draw_header(self, width):
        model = self.model
        if len(model) > 18:
            model = model[:15] + "..."
        header = f" ◈ Gemma Local Agent │ model:{model} │ ollama:{_ollama_status(self.ollama_host)} │ mem:{_memory_status()} │ voice:{_voice_status()} │ tools:{_helper_count()} "
        _safe_addstr(self.stdscr, 0, 0, header.ljust(width), self.style("header"))

    def draw_tabs(self, width):
        x = 0
        for mode, label, key in MODES:
            tab = f" [{key.upper()}] {label} "
            attr = self.style("active_tab") if mode == self.mode else self.style("inactive_tab")
            _safe_addstr(self.stdscr, 1, x, tab, attr)
            x += len(tab) + 1
            if x >= width - 10:
                break
        _safe_addstr(self.stdscr, 2, 0, "─" * (width - 1), self.style("muted"))

    def draw_body(self, height, width):
        top = 3
        bottom = height - 3
        visible = max(1, bottom - top)
        max_scroll = max(0, len(self.lines) - visible)
        self.scroll = min(self.scroll, max_scroll)
        start = self.scroll
        end = start + visible
        for row, line in enumerate(self.lines[start:end], top):
            attr = 0
            if line.startswith("╭─") or line.startswith("╰─") or line.startswith("├─"):
                attr = self.style("frame")
            elif line.startswith("│"):
                if " You: " in line or " Gemma: " in line or " Search: " in line or " Reports: " in line or " Stage3A: " in line or " Routed: " in line:
                    for prefix_str, style_name in [(" You: ", "user"), (" Gemma: ", "assistant"), (" Search: ", "title"), (" Reports: ", "title"), (" Stage3A: ", "title"), (" Routed: ", "title")]:
                        if prefix_str in line:
                            parts = line.split(":", 1)
                            _safe_addstr(self.stdscr, row, 0, parts[0] + ":", self.style(style_name))
                            if len(parts) > 1:
                                _safe_addstr(self.stdscr, row, len(parts[0]) + 1, parts[1], 0)
                            break
                    continue
                elif "OK" in line or "ready" in line or "online" in line:
                    attr = self.style("ok")
                elif "MISSING" in line or "WARN" in line or "offline" in line or "fallback" in line:
                    attr = self.style("warn")
                elif "Error" in line:
                    attr = self.style("error")
                else:
                    attr = 0
            elif line.startswith("#"):
                attr = self.style("title")
            _safe_addstr(self.stdscr, row, 0, line, attr)
            
        if len(self.lines) > visible:
            marker = f" {start + 1}-{min(end, len(self.lines))}/{len(self.lines)} "
            _safe_addstr(self.stdscr, bottom - 1, max(0, width - len(marker) - 1), marker, self.style("muted"))

    def draw_footer(self, height, width):
        hint = f" {self.status} │ natural chat routes automatically │ /debug last /help /clear /quit "
        _safe_addstr(self.stdscr, height - 2, 0, hint.ljust(width), self.style("footer"))
        
        prompt = f" ❯ {self.input_text}"
        _safe_addstr(self.stdscr, height - 1, 0, prompt, self.style("input"))
        try:
            self.stdscr.move(height - 1, min(len(" ❯ ") + self.cursor_pos, width - 2))
        except curses.error:
            pass

    def handle_key(self, ch):
        if ch in (curses.KEY_RESIZE,):
            return
        if ch == 3: # Ctrl+C
            raise KeyboardInterrupt
        if ch == 21: # Ctrl+U
            self.input_text = ""
            self.cursor_pos = 0
            return
        if self.is_generating and ch in (10, 13):
            # Ignore enter while generating
            return
            
        if ch in (10, 13):
            text = self.input_text.strip()
            self.input_text = ""
            self.cursor_pos = 0
            if text:
                self.handle_command(text)
            return
        if ch in (27,):
            self._reset_welcome()
            return
        if ch in (curses.KEY_BACKSPACE, 127, 8):
            if self.cursor_pos > 0:
                self.input_text = self.input_text[:self.cursor_pos - 1] + self.input_text[self.cursor_pos:]
                self.cursor_pos -= 1
            return
        if ch == curses.KEY_DC: # Delete
            if self.cursor_pos < len(self.input_text):
                self.input_text = self.input_text[:self.cursor_pos] + self.input_text[self.cursor_pos + 1:]
            return
        if ch == curses.KEY_LEFT:
            self.cursor_pos = max(0, self.cursor_pos - 1)
            return
        if ch == curses.KEY_RIGHT:
            self.cursor_pos = min(len(self.input_text), self.cursor_pos + 1)
            return
        if ch in (curses.KEY_UP, 16): # Up arrow or Ctrl+P
            self.scroll = max(0, self.scroll - 1)
            return
        if ch in (curses.KEY_DOWN, 14): # Down arrow or Ctrl+N
            self.scroll += 1
            return
        if ch == curses.KEY_PPAGE:
            self.scroll = max(0, self.scroll - 10)
            return
        if ch == curses.KEY_NPAGE:
            self.scroll += 10
            return
        if 0 <= ch < 256:
            char = chr(ch)
            if char.isprintable():
                self.input_text = self.input_text[:self.cursor_pos] + char + self.input_text[self.cursor_pos:]
                self.cursor_pos += 1

    def handle_command(self, text):
        if not text.startswith("/"):
            if self.pending_action and text.strip().lower() in {"yes", "y", "no", "n"}:
                self._handle_pending_confirmation(text)
                return
            normalized_command = normalize_plain_command(text)
            if normalized_command:
                self.handle_command(normalized_command)
                return
            self._handle_chat_input(text)
            return
            
        self.status = "Ready"
        cmd = text.lower().strip()
        if cmd in ("/quit", "/q", "/exit"):
            self.running = False
        elif cmd in ("/menu", "/mode", "/back", "/help", "/?", "/commands"):
            self.show_menu()
        elif cmd in ("/general", "/g"):
            self.show_general()
        elif cmd in ("/dashboard", "/status"):
            self.show_dashboard()
        elif cmd == "/memory" or cmd in ("/m",):
            self.show_memory()
        elif cmd.startswith("/memory "):
            self._handle_memory(text)
        elif cmd == "/reports" or cmd in ("/r",):
            self._handle_reports_list()
        elif cmd.startswith("/reports latest"):
            self._handle_reports_latest()
        elif cmd in ("/voice", "/v"):
            self.show_voice()
        elif cmd in ("/settings", "/t", "/theme", "/ascii", "/compact"):
            self.show_settings(cmd)
        elif cmd == "/debug last":
            self._show_debug_last()
        elif cmd == "/clear":
            self.lines = [f"╭─ {self.mode.title()}", "│", "│  Transcript cleared.", "╰─"]
            self.scroll = 0
        else:
            self.lines.extend(["│", f"│  WARN Unknown command: {text}", "│  Try /commands or /menu."])
            self.scroll = max(0, len(self.lines) - 1)

    def _append_chat_header(self, text, route, chip_extra="read-only"):
        _, width = self.stdscr.getmaxyx()
        max_width = max(20, width - 4)
        self.lines.append("├──────────────────────────────────────────────────")
        self.lines.extend(_wrap_lines(text, prefix="│ You: ", width=max_width))
        self.lines.append(
            f"│ Routed: {route['intent']} · {chip_extra} · confidence {route['confidence']:.2f}"
        )
        self.lines.append("│")

    def _handle_chat_input(self, text):
        route = route_chat_intent(text)
        intent = route["intent"]

        if intent == "general_chat":
            if self.mode != "general":
                self.mode = "general"
                self.lines = ["╭─ Chat", "│"]
            self._append_chat_header(text, route, "Gemma")
            self.is_generating = True
            self.status = "Thinking..."
            self.current_response = ""
            self.stream_start_idx = len(self.lines)
            self.stream_prefix = "│ Gemma: "
            self.lines.append("│ Gemma: thinking...")
            self.scroll = max(0, len(self.lines) - 1)
            self.draw()
            threading.Thread(target=_call_ollama_stream, args=(text, self.gen_queue, self.model, self.ollama_host, 120), daemon=True).start()
            return

        if intent == "memory_auto":
            self.mode = "memory"
            if not self.lines or self.lines[0] != "╭─ Chat":
                self.lines = ["╭─ Chat", "│"]
            _, width = self.stdscr.getmaxyx()
            max_width = max(20, width - 4)
            self.lines.append("├──────────────────────────────────────────────────")
            self.lines.extend(_wrap_lines(text, prefix="│ You: ", width=max_width))
            self.lines.append("│")
            self.is_generating = True
            self.status = "Retrieving memory..."
            self.current_response = ""
            if hasattr(self, "stream_start_idx"):
                delattr(self, "stream_start_idx")
            self.scroll = max(0, len(self.lines) - 1)
            self.draw()
            threading.Thread(
                target=_run_memory_auto_worker,
                args=(text, self.gen_queue, self.model, self.ollama_host),
                daemon=True,
            ).start()
            return

        if intent == "reports_latest":
            self._handle_reports_latest(user_text=text, route=route)
        elif intent == "reports_list":
            self._handle_reports_list(user_text=text, route=route)
        elif intent == "dashboard":
            self.show_dashboard(user_text=text, route=route)
        elif intent == "voice_status":
            self.show_voice(user_text=text, route=route)
        elif intent == "settings":
            self.show_settings("settings", user_text=text, route=route)
        elif intent == "help":
            self.show_menu(user_text=text, route=route)
        elif intent == "security_confirm_required":
            self._show_security_confirmation_required(text, route)
        self.scroll = max(0, len(self.lines) - 1)

    def _show_debug_last(self):
        self.mode = "debug"
        _, width = self.stdscr.getmaxyx()
        max_width = max(20, width - 4)
        self.lines = [
            "╭─ Debug Last Routed Action",
            "│",
            "│  Raw helper output is hidden during normal chat.",
            "│",
        ]
        self.lines.extend(_wrap_lines(self.last_debug_output, prefix="│ ", width=max_width))
        self.lines.append("╰─")
        self.scroll = 0

    def _show_security_confirmation_required(self, text, route):
        self.mode = "security"
        action_name = _suggest_security_action(text)
        action = SECURITY_ACTIONS.get(action_name)
        self.pending_action = None
        self.lines = ["╭─ Confirmation Required", "│"]
        self._append_chat_header(text, route, "confirmation required")
        if action is None:
            self.lines.extend([
                "│ Security-sensitive request detected.",
                "│",
                f"│ Suggested workflow: {action_name}",
                "│ Risk: SUDO / MANUAL REVIEW",
                "│ Status: manual workflow required. Nothing was executed.",
                "│",
                "╰─ Use the reviewed security workflow outside chat-first routing.",
            ])
            return
        self.pending_action = {"name": action_name, **action}
        self.lines.extend([
            "│ Security-sensitive request detected.",
            "│",
            f"│ Suggested tool: {action_name}",
            f"│ Purpose: {action['description']}",
            f"│ Risk: {action['risk']}",
            "│ Executes read-only only; no writes, no sudo.",
            "│",
            "│ Proceed? Type yes or no.",
            "│",
            "╰─ No security tool was executed yet.",
        ])

    def _handle_pending_confirmation(self, text):
        answer = text.strip().lower()
        action = self.pending_action
        self.pending_action = None
        if answer not in {"yes", "y"}:
            self.lines.extend(["│", "│ Security action cancelled. Nothing was executed.", "│"])
            self.scroll = max(0, len(self.lines) - 1)
            return
        if not action:
            self.lines.extend(["│", "│ No pending action.", "│"])
            self.scroll = max(0, len(self.lines) - 1)
            return
        if action.get("sudo"):
            self.lines.extend(["│", "│ Manual workflow required. Sudo tools are not run from chat routing.", "│"])
            self.scroll = max(0, len(self.lines) - 1)
            return
        self.lines.append("├──────────────────────────────────────────────────")
        self.lines.append(f"│ You: {text.strip()}")
        self.lines.append(f"│ Running confirmed read-only tool: {action['name']}")
        self.lines.append("│")
        self.is_generating = True
        self.status = f"Running {action['name']}..."
        self.current_response = ""
        self.stream_start_idx = len(self.lines)
        self.stream_prefix = f"│ {action['name']}: "
        self.lines.append(f"│ {action['name']}: running...")
        self.scroll = max(0, len(self.lines) - 1)
        self.draw()
        threading.Thread(target=_run_helper_stream, args=(action["command"], self.gen_queue), daemon=True).start()

    def _handle_memory(self, text):
        parts = text.split(None, 2)
        if len(parts) < 2:
            return
        subcmd = parts[1].lower()
        query = parts[2] if len(parts) > 2 else ""
        
        if subcmd == "status":
            self.show_memory()
            return
            
        if subcmd in ("ask", "compare"):
            self.lines.extend(["│", f"│  Memory {subcmd} is reserved for future implementation.", "│"])
            self.scroll = max(0, len(self.lines) - 1)
            return
            
        if subcmd == "search":
            cmd_args = ["gemma-memory-search", query]
            prefix_name = "Search"
        elif subcmd == "stage3a":
            if shutil.which("gemma-knowledge-rag") or (BIN_DIR / "gemma-knowledge-rag").is_file():
                cmd_args = ["gemma-knowledge-rag", query]
            else:
                cmd_args = ["gemma-knowledge-search", query]
            prefix_name = "Stage3A"
        else:
            self.lines.extend(["│", f"│  Unknown memory command: {subcmd}", "│"])
            self.scroll = max(0, len(self.lines) - 1)
            return
            
        if not query:
            self.lines.extend(["│", "│  Missing query.", "│"])
            self.scroll = max(0, len(self.lines) - 1)
            return
            
        self.mode = "memory"
        _, width = self.stdscr.getmaxyx()
        max_width = max(20, width - 4)
        
        self.lines.append("├──────────────────────────────────────────────────")
        self.lines.extend(_wrap_lines(text, prefix="│ You: ", width=max_width))
        self.lines.append("│")
        
        self.is_generating = True
        self.status = f"Running {cmd_args[0]}..."
        self.current_response = ""
        self.stream_start_idx = len(self.lines)
        self.stream_prefix = f"│ {prefix_name}: "
        self.lines.append(f"│ {prefix_name}: running...")
        self.scroll = max(0, len(self.lines) - 1)
        self.draw()
        
        threading.Thread(target=_run_helper_stream, args=(cmd_args, self.gen_queue), daemon=True).start()

    def _handle_reports_list(self, user_text=None, route=None):
        self.mode = "reports"
        if user_text and route:
            self.lines = ["╭─ Reports", "│"]
            self._append_chat_header(user_text, route, "read-only")
        else:
            self.lines.append("├──────────────────────────────────────────────────")
            self.lines.append("│ You: /reports")
            self.lines.append("│")
        
        if not REPORT_DIR.is_dir():
            self.lines.extend(["│ Reports: Directory not found.", "│"])
            self.scroll = max(0, len(self.lines) - 1)
            return
            
        try:
            files = [(f, f.stat().st_mtime, f.stat().st_size) for f in REPORT_DIR.iterdir() if f.is_file()]
            files.sort(key=lambda x: x[1], reverse=True)
            _, width = self.stdscr.getmaxyx()
            max_width = max(40, width - 4)

            self.lines.append("│ Reports: Recent manual security reports")
            self.lines.append("│")
            if not files:
                self.lines.append("│   (No reports found)")
                self.last_debug_output = "No reports found."
            else:
                self.lines.extend(_report_cards(files, include_preview=True, limit=5, width=max_width))
                raw_parts = []
                for path, _, _ in files[:5]:
                    try:
                        raw_parts.append(f"$ report {path.name}\n" + path.read_text(encoding="utf-8", errors="replace"))
                    except Exception as exc:
                        raw_parts.append(f"$ report {path.name}\nPreview unavailable: {exc}")
                self.last_debug_output = "\n\n".join(raw_parts)
            self.lines.append("│")
        except Exception as e:
            self.lines.extend([f"│ Reports: Error reading directory: {e}", "│"])
            
        self.scroll = max(0, len(self.lines) - 1)

    def _handle_reports_latest(self, user_text=None, route=None):
        self.mode = "reports"
        if user_text and route:
            self.lines = ["╭─ Reports", "│"]
            self._append_chat_header(user_text, route, "read-only")
        else:
            self.lines.append("├──────────────────────────────────────────────────")
            self.lines.append("│ You: /reports latest")
            self.lines.append("│")
        
        if not REPORT_DIR.is_dir():
            self.lines.extend(["│ Reports: Directory not found.", "│"])
            self.scroll = max(0, len(self.lines) - 1)
            return
            
        try:
            files = [(f, f.stat().st_mtime, f.stat().st_size) for f in REPORT_DIR.iterdir() if f.is_file()]
            files.sort(key=lambda x: x[1], reverse=True)
            _, width = self.stdscr.getmaxyx()
            max_width = max(40, width - 4)

            if not files:
                self.lines.extend(["│ Reports: No reports found.", "│"])
                self.last_debug_output = "No reports found."
            else:
                self.lines.append("│ Reports: Latest manual security report")
                self.lines.append("│")
                self.lines.extend(_report_cards(files, include_preview=True, limit=1, width=max_width))
                latest = files[0][0]
                try:
                    self.last_debug_output = f"$ report {latest.name}\n" + latest.read_text(encoding="utf-8", errors="replace")
                except Exception as exc:
                    self.last_debug_output = f"$ report {latest.name}\nPreview unavailable: {exc}"
                
        except Exception as e:
            self.lines.extend([f"│ Reports: Error reading file: {e}", "│"])
            
        self.scroll = max(0, len(self.lines) - 1)

    def show_menu(self, user_text=None, route=None):
        self.mode = "welcome"
        self.lines = [
            "╭─ Menu",
            "│",
        ]
        if user_text and route:
            self._append_chat_header(user_text, route, "read-only")
        self.lines.extend([
            "│  [g] /general     General Chat              [SAFE]",
            "│  [s] /security    Security Console          [CONFIRM]",
            "│  [m] /memory      Memory / RuVector         [SAFE]",
            "│  [o] /repo        Repo                      [SAFE]",
            "│  [r] /reports     Reports                   [SAFE]",
            "│  [v] /voice       Voice                     [SAFE]",
            "│  [h] /health      Health                    [SAFE]",
            "│  [t] /settings    Settings                  [SAFE]",
            "│      /dashboard   Dashboard                 [SAFE]",
            "│      /debug last  Raw last routed helper output",
            "│  [q] /quit        Quit                      [SAFE]",
            "│",
            "╰─ Security tools are not executed from this TUI.",
        ])
        self.scroll = 0

    def show_general(self):
        self.mode = "general"
        self.lines = [
            "╭─ General",
            "│",
            "│  General chat is now represented inside the persistent TUI shell.",
            "│  Type a message and press Enter to call the local model.",
            "│",
            "╰─ Stream responses are non-blocking.",
        ]
        self.scroll = 0

    def show_dashboard(self, user_text=None, route=None):
        self.mode = "dashboard"
        self.lines = [
            "╭─ Dashboard",
            "│",
        ]
        if user_text and route:
            self._append_chat_header(user_text, route, "read-only")
        self.lines.extend([
            f"│  Ollama:    {_ollama_status(self.ollama_host)}",
            f"│  Model:     {self.model}",
            f"│  Tools:     {_helper_count()}",
            "│  Memory:    RuVector supervised secondary, Stage 3A fallback",
            f"│  Voice:     {_voice_status()}",
            "│  Safety:    advisory-only, confirmations preserved",
            "│  Static export: optional",
            "│",
            "╰─ No security scans. No tool execution.",
        ])
        self.scroll = 0

    def show_memory(self):
        self.mode = "memory"
        rv = 'OK' if shutil.which('gemma-memory-search') or (BIN_DIR / 'gemma-memory-search').is_file() else 'MISSING'
        s3a = 'OK' if shutil.which('gemma-knowledge-rag') or (BIN_DIR / 'gemma-knowledge-rag').is_file() else 'MISSING'
        
        self.lines = [
            "╭─ Memory",
            "│",
            f"│  RuVector role:    supervised secondary ({rv})",
            f"│  Stage 3A:         fallback ({s3a})",
            "│",
            "│  Commands:",
            "│    /memory search <q>",
            "│    /memory ask <q>",
            "│    /memory stage3a <q>",
            "│    /memory compare <q>",
            "│",
            "╰─ Do not run long RAG until explicitly implemented.",
        ]
        self.scroll = 0

    def show_voice(self, user_text=None, route=None):
        self.mode = "voice"
        rec = 'OK' if shutil.which('pw-record') else 'MISSING'
        stt = 'OK' if shutil.which('whisper-cli') else 'MISSING'
        tts = 'OK' if shutil.which('piper') or shutil.which('espeak') else 'MISSING'
        
        self.lines = [
            "╭─ Voice",
            "│",
        ]
        if user_text and route:
            self._append_chat_header(user_text, route, "read-only")
        self.lines.extend([
            f"│  recorder: {rec}",
            f"│  STT:      {stt}",
            f"│  TTS:      {tts}",
            "│  mode:     push-to-talk only",
            "│",
            "╰─ Do not record audio.",
        ])
        self.scroll = 0

    def show_settings(self, cmd, user_text=None, route=None):
        self.mode = "settings"
        ui = self.config.get("ui", {})
        self.lines = [
            "╭─ Settings",
            "│",
        ]
        if user_text and route:
            self._append_chat_header(user_text, route, "read-only")
        self.lines.extend([
            f"│  layout:          {ui.get('layout', 'app_shell')}",
            f"│  density:         {ui.get('density', 'normal')}",
            f"│  use_unicode:     {ui.get('use_unicode', True)}",
            f"│  high_contrast:   {ui.get('high_contrast', False)}",
            f"│  current model:   {self.model}",
            f"│  Ollama host:     {self.ollama_host}",
            "│",
            "╰─ Changing persistent settings remains in gemma-ui print-loop.",
        ])
        self.scroll = 0

def _run_check(check_model=False):
    import os
    print("gemma-ui-tui check")
    
    # 1. curses
    try:
        import curses
        print("curses: OK")
    except ImportError:
        print("curses: FAIL")
        return 1
        
    # 2. colors
    term = os.environ.get("TERM", "")
    if "color" in term or "xterm" in term:
        print("colors: OK")
    else:
        print("colors: monochrome")
        
    # 3. config
    config = _load_json(CONFIG_FILE)
    print("config: OK" if config else "config: OK (using defaults)")
    
    # 4. ollama host & model
    host_env = os.environ.get("OLLAMA_HOST")
    if host_env:
        ollama_host = host_env
    else:
        h = config.get("ollama", {}).get("host", "127.0.0.1")
        p = config.get("ollama", {}).get("port", 11434)
        ollama_host = f"http://{h}:{p}" if "http" not in str(h) else str(h)
        
    model = config.get("ollama", {}).get("model", MODEL)
    
    status = _ollama_status(ollama_host)
    print(f"ollama: {status.split(':')[0]}")
    
    # 5. model present/missing
    model_status = "missing"
    if "online" in status:
        try:
            req = urllib.request.Request(f"{ollama_host}/api/tags", method="GET")
            with urllib.request.urlopen(req, timeout=1.5) as resp:
                data = json.loads(resp.read())
                models = [m.get("name") for m in data.get("models", [])]
                if model in models or f"{model}:latest" in models or model.replace(":latest", "") in models:
                    model_status = "present"
        except Exception:
            pass
            
    print(f"model: {model} {model_status}")
    
    # 6. helpers
    print(f"helpers: {_helper_count()}")
    
    # 7. terminal
    print(f"terminal: {term}")
    
    if check_model and "online" in status and model_status == "present":
        print("\n--- model check ---")
        try:
            req_data = json.dumps({
                "model": model,
                "prompt": "Reply with exactly: ok",
                "stream": False
            }).encode("utf-8")
            req = urllib.request.Request(
                f"{ollama_host}/api/generate",
                data=req_data,
                method="POST",
                headers={"Content-Type": "application/json"}
            )
            with urllib.request.urlopen(req, timeout=120) as resp:
                data = json.loads(resp.read())
                response = data.get("response", "").strip().lower()
                print(f"response: {response}")
                if "ok" in response:
                    print("model check: PASS")
                else:
                    print("model check: WARN (unexpected response)")
        except Exception as e:
            print(f"model check: FAIL ({e})")
            
    if "offline" in status or model_status == "missing":
        print("result: FAIL")
        return 1
    print("result: PASS")
    return 0

def main():
    import sys
    if len(sys.argv) > 1:
        if sys.argv[1] == "--check":
            return _run_check(check_model=False)
        elif sys.argv[1] == "--check-model":
            return _run_check(check_model=True)
        elif sys.argv[1] in ("--help", "-h"):
            print("gemma-ui-tui [options]")
            print("Options:")
            print("  --check        Run a non-interactive health check")
            print("  --check-model  Run health check and test model generation")
            print("  --version      Show version")
            print("  --help, -h     Show this help message")
            return 0
        elif sys.argv[1] in ("--version", "-v"):
            print("gemma-ui-tui v1.5.6-experimental")
            return 0
            
    try:
        curses.wrapper(lambda stdscr: GemmaTui(stdscr).run())
    except KeyboardInterrupt:
        return 0
    except Exception as e:
        import traceback
        print(f"gemma-ui-tui encountered an error: {e}")
        traceback.print_exc()
        return 1
    return 0

if __name__ == "__main__":
    raise SystemExit(main())
