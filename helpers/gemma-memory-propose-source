#!/usr/bin/env python3
"""Repo-local memory source proposal helper.

Creates proposal JSON for memory source classification.

Manual-run only. No ingestion, no indexing.

Usage:
    gemma-memory-propose-source --source PATH --purpose "why needed" --expected-value "benefit"
    gemma-memory-propose-source --source PATH --purpose "..." --expected-value "..." --write-report
"""

from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import sys
from pathlib import Path
from typing import Any


HOME = Path.home()
TIMESTAMP = dt.datetime.now().strftime("%Y%m%d-%H%M%S")
PROPOSAL_ID = f"proposal-{TIMESTAMP}"
REPORT_DIR = HOME / "offload/security-reports/manual"
REPORT_PATH = REPORT_DIR / f"gemma-memory-proposal-{TIMESTAMP}.md"

APPROVED_ROOTS = {
    "docs/phase9",
    "docs/workflows/memory",
}

DENIED_BROAD_ROOTS = {
    ".config",
    ".local/share",
    ".local/bin",
    "cache",
    "offload",
}

DENIED_PATTERNS = {
    ".env",
    ".env.",
    "secret",
    "token",
    "credential",
    "password",
    "key",
    ".git",
    "__pycache__",
    "node_modules",
}


def classify_source(source: str, explicit_class: str | None = None) -> tuple[str, str]:
    """Classify source as A/B/C/D and return (class, reason)."""
    
    if explicit_class:
        if explicit_class.upper() in {"A", "B", "C", "D"}:
            return explicit_class.upper(), f"explicit class: {explicit_class}"
        return "D", f"invalid explicit class: {explicit_class}"
    
    source_path = Path(source)
    
    if source_path.is_absolute():
        resolved = source_path
    else:
        resolved = Path.cwd() / source_path
    
    resolved_str = str(resolved)
    parts = resolved.parts
    
    first_part = parts[0] if parts else ""
    
    if source_path.is_absolute():
        if first_part.startswith("."):
            if first_part in {".config", ".local", ".cache"}:
                return "D", f"broad root denied: {first_part}"
            if first_part == ".local" and len(parts) > 1:
                second = parts[1]
                if second == "share":
                    return "D", "broad root ~/.local/share denied"
        
        for root in DENIED_BROAD_ROOTS:
            if root in parts:
                return "D", f"contains denied broad root: {root}"
    
    for pattern in DENIED_PATTERNS:
        if pattern.lower() in str(source).lower():
            return "D", f"contains denied pattern: {pattern}"
    
    # Known approved paths are Class A
    if str(source).startswith("docs/phase9") or str(source).startswith("docs/workflows/memory"):
        return "A", "approved Phase 9 docs scope"
    
    if ".local/share/bazzite-security/gemma-knowledge/docs" in str(source):
        return "A", "approved knowledge docs path"
    
    # Repo-relative but not in known approved list -> needs explicit approval (Class C)
    if not source_path.is_absolute() and not str(source).startswith("/"):
        return "C", "repo-relative path, requires explicit approval"
    
    return "C", "narrow scope, requires approval"


def create_proposal(
    source: str,
    purpose: str,
    expected_value: str,
    submitted_by: str = "human",
    source_class: str | None = None,
    write_report: bool = False,
) -> dict[str, Any]:
    """Create proposal JSON."""
    
    source_class, scope_reason = classify_source(source, source_class)
    
    approved_roots_only = source_class in {"A", "B"}
    
    contains_runtime = False
    if any(x in source.lower() for x in ["log", "cache", "state", "tmp", "temp"]):
        contains_runtime = True
    
    requires_denied_scan = source_class != "B"
    
    if source_class == "D":
        human_approval_status = "denied"
        rejection_reason = f"Class D rejected: {scope_reason}"
    else:
        human_approval_status = "pending"
        rejection_reason = None
    
    proposal = {
        "proposal_id": PROPOSAL_ID,
        "submitted_at": dt.datetime.now().isoformat(),
        "submitted_by": submitted_by,
        "source_path": source,
        "source_class": source_class,
        "purpose": purpose,
        "expected_value": expected_value,
        "scope_reason": scope_reason,
        "approved_roots_only": approved_roots_only,
        "contains_runtime_state": contains_runtime,
        "requires_denied_scan": requires_denied_scan,
        "human_approval_status": human_approval_status,
        "excluded_paths": [],
        "estimated_file_count": None,
        "estimated_chunk_count": None,
        "related_eval_cases": [],
        "notes": rejection_reason or "",
    }
    
    if write_report:
        write_proposal_report(proposal)
    
    return proposal


def write_proposal_report(proposal: dict[str, Any]) -> None:
    """Write proposal as markdown report."""
    REPORT_DIR.mkdir(parents=True, exist_ok=True)
    
    lines = [
        "# Memory Source Proposal",
        "",
        f"**Proposal ID:** {proposal['proposal_id']}",
        f"**Submitted:** {proposal['submitted_at']}",
        f"**By:** {proposal['submitted_by']}",
        "",
        "---",
        "",
        "## Source",
        "",
        f"- **Path:** `{proposal['source_path']}`",
        f"- **Class:** `{proposal['source_class']}`",
        f"- **Scope Reason:** {proposal['scope_reason']}",
        "",
        "## Rationale",
        "",
        f"- **Purpose:** {proposal['purpose']}",
        f"- **Expected Value:** {proposal['expected_value']}",
        "",
        "## Status",
        "",
        f"- **Human Approval:** `{proposal['human_approval_status']}`",
        f"- **Approved Roots Only:** `{proposal['approved_roots_only']}`",
        f"- **Contains Runtime State:** `{proposal['contains_runtime_state']}`",
        f"- **Requires Denied Scan:** `{proposal['requires_denied_scan']}`",
        "",
        "## Notes",
        "",
        proposal.get("notes", "None"),
        "",
        f"*Report: {REPORT_PATH}*",
    ]
    
    with REPORT_PATH.open("w", encoding="utf-8") as f:
        f.write("\n".join(lines))
    
    print(f"Report written to: {REPORT_PATH}")


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Memory source proposal helper (no ingestion)",
    )
    parser.add_argument(
        "--source", required=True,
        help="Proposed source path",
    )
    parser.add_argument(
        "--purpose", required=True,
        help="Why this source is needed",
    )
    parser.add_argument(
        "--expected-value", required=True,
        help="Expected retrieval/eval benefit",
    )
    parser.add_argument(
        "--submitted-by", default="human",
        help="Submitter identity",
    )
    parser.add_argument(
        "--source-class",
        help="Explicit source class (A/B/C/D/auto)",
    )
    parser.add_argument(
        "--write-report",
        action="store_true",
        help="Write proposal report to ~/offload/security-reports/manual/",
    )
    
    args = parser.parse_args()
    
    proposal = create_proposal(
        source=args.source,
        purpose=args.purpose,
        expected_value=args.expected_value,
        submitted_by=args.submitted_by,
        source_class=args.source_class,
        write_report=args.write_report,
    )
    
    print(json.dumps(proposal, indent=2))
    
    if proposal["human_approval_status"] == "denied":
        return 1
    
    return 0


if __name__ == "__main__":
    sys.exit(main())