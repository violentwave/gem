#!/usr/bin/env python3
"""Repo-local memory rollback plan helper.

Creates rollback/reset plan from an ingestion manifest plan.

Manual-run only. No execution, no file deletion, no RuVector mutation.

Usage:
    gemma-memory-rollback-plan --manifest-json PATH
    gemma-memory-rollback-plan --manifest-json PATH --write-report
"""

from __future__ import annotations

import argparse
import datetime as dt
import json
import sys
from pathlib import Path
from typing import Any


HOME = Path.home()
TIMESTAMP = dt.datetime.now().strftime("%Y%m%d-%H%M%S")
REPORT_DIR = HOME / "offload/security-reports/manual"
REPORT_PATH = REPORT_DIR / f"gemma-memory-rollback-plan-{TIMESTAMP}.md"


def create_rollback_plan(
    manifest_json: dict[str, Any],
    reset_owner: str = "human",
    write_report: bool = False,
) -> dict[str, Any]:
    """Create rollback/reset plan from manifest."""
    
    now = dt.datetime.now().isoformat()
    manifest_id = manifest_json.get("manifest_id", "unknown")
    rollback_plan_id = f"rollback-{manifest_id}"
    
    # Build rollback plan
    rollback = {
        "rollback_plan_id": rollback_plan_id,
        "manifest_id": manifest_id,
        "previous_state_identifier": "pre-ingestion backup or manifest backup",
        "proposed_new_state_identifier": "restore to previous state",
        "affected_source_scope": manifest_json.get("input_source", "unknown"),
        "reset_owner": reset_owner,
        "revert_steps": [
            "1. Identify previous approved manifest state",
            "2. List files to be removed from storage_path",
            "3. Create backup of new state before removal",
            "4. Remove indexed memory entries for input_source",
            "5. Remove related vector data if applicable",
            "6. Restore previous manifest to active state",
            "7. Verify all files removed from RuVector storage",
        ],
        "validation_after_reset": [
            "./scripts/check-memory-known-answers.sh",
            "./scripts/check-gemma-memory-quality.sh",
            "gemma-evals-status",
            "gemma-evals-check",
            "gemma-examples-check",
        ],
        "stage3a_fallback_confirmation": "Stage 3A deterministic retrieval preserved as canonical fallback",
        "trigger_conditions": [
            "denied source slipped through review",
            "retrieval quality regression",
            "known-answer regression",
            "manifest mismatch",
            "stale-memory review failure",
            "human chooses to revert experimental ingestion",
        ],
        "executable": False,
        "notes": "Planning artifact only. Human owner must review and execute manually.",
    }
    
    if write_report:
        write_rollback_report(rollback, manifest_json)
    
    return rollback


def write_rollback_report(
    rollback: dict[str, Any],
    manifest: dict[str, Any],
) -> None:
    """Write rollback plan as markdown report."""
    REPORT_DIR.mkdir(parents=True, exist_ok=True)
    
    lines = [
        "# Memory Rollback Plan",
        "",
        f"**Generated:** {dt.datetime.now().isoformat()}",
        f"**Rollback Plan ID:** {rollback['rollback_plan_id']}",
        f"**Manifest ID:** {rollback['manifest_id']}",
        "",
        "---",
        "",
        "## Scope",
        "",
        f"- **Affected Source:** `{rollback['affected_source_scope']}`",
        f"- **Reset Owner:** `{rollback['reset_owner']}`",
        "",
        "## State",
        "",
        f"- **Previous:** {rollback['previous_state_identifier']}",
        f"- **Proposed:** {rollback['proposed_new_state_identifier']}",
        "",
        "## Revert Steps",
        "",
    ]
    for step in rollback["revert_steps"]:
        lines.append(f"- {step}")
    
    lines.extend([
        "",
        "## Validation After Reset",
        "",
    ])
    for cmd in rollback["validation_after_reset"]:
        lines.append(f"- `{cmd}`")
    
    lines.extend([
        "",
        f"## Stage 3A Fallback",
        "",
        rollback["stage3a_fallback_confirmation"],
        "",
        "## Trigger Conditions",
        "",
    ])
    for condition in rollback["trigger_conditions"]:
        lines.append(f"- {condition}")
    
    lines.extend([
        "",
        "## Executable",
        "",
        f"`{rollback['executable']}`",
        "",
        "## Notes",
        "",
        rollback["notes"],
        "",
        f"*Report: {REPORT_PATH}*",
    ])
    
    with REPORT_PATH.open("w", encoding="utf-8") as f:
        f.write("\n".join(lines))
    
    print(f"Report written to: {REPORT_PATH}")


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Memory rollback plan helper (no execution)",
    )
    parser.add_argument(
        "--manifest-json", required=True,
        help="Path to manifest JSON file",
    )
    parser.add_argument(
        "--reset-owner",
        default="human",
        help="Reset owner identity",
    )
    parser.add_argument(
        "--write-report",
        action="store_true",
        help="Write rollback report to ~/offload/security-reports/manual/",
    )
    
    args = parser.parse_args()
    
    # Load manifest JSON
    manifest_path = Path(args.manifest_json)
    if not manifest_path.exists():
        print(f"ERROR: manifest JSON not found: {manifest_path}", file=sys.stderr)
        return 1
    
    try:
        manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as e:
        print(f"ERROR: invalid manifest JSON: {e}", file=sys.stderr)
        return 1
    
    # Create rollback plan
    rollback = create_rollback_plan(
        manifest_json=manifest,
        reset_owner=args.reset_owner,
        write_report=args.write_report,
    )
    
    print(json.dumps(rollback, indent=2))
    
    return 0


if __name__ == "__main__":
    sys.exit(main())