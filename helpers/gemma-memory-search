        for result in ruv_results:
            lines.append(
                f"| {result['rank']} | {float(result['similarity']):.4f} | "
                f"{md_cell(result['source'])} | {md_cell(result['family'])} | "
                f"{md_cell(result.get('answerability', 'unrelated_or_unclear'))} | {md_cell(result['sourceType'])} | "
                f"{md_cell(excerpt(str(result.get('text', '')), 180))} |"
            )
        lines.append("")

    lines.extend([
