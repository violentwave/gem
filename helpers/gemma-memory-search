    ])

    with report_path.open("w", encoding="utf-8") as handle:
        handle.write("\n".join(lines))
    log(f"Report written to: {report_path}")
    return report_path


def print_terminal_summary(query: str, ruvector_results: list[dict[str, Any]] | None, comparison: dict[str, Any], report_path: Path) -> None:
    print("gemma-memory-search")
    print(f"query: {query}")
    print(f"ruvector_top_sources: {format_source_list(ruvector_results or [])}")
    print(f"stage3a_top_sources: {format_source_list(comparison['stage3a_results'])}")
    print(f"exact_overlap: {comparison['exact_overlap_percent']:.1f}%")
    print(f"source_family_equivalence: {comparison['source_family_equivalence_percent']:.1f}%")
    print(f"answerability_status: ruvector_direct={comparison['direct_evidence_count_ruvector']} stage3a_direct={comparison['direct_evidence_count_stage3a']} confidence={comparison['recommendation_confidence']}")
    print(f"final_recommendation: {comparison['recommendation']}")
    print(f"fallback_status: {comparison['fallback_status']}")
    print(f"report_path: {report_path}")
    print(f"log_path: {LOG_FILE}")


def main() -> int:
    LOG_FILE.parent.mkdir(parents=True, exist_ok=True)
    log("=== gemma-memory-search ===")

    if len(sys.argv) != 2 or not sys.argv[1].strip():
        print('Usage: gemma-memory-search "query"', file=sys.stderr)
        log("ERROR: Invalid arguments")
        return 1

    query = sys.argv[1].strip()
    log(f"Query: {query}")

    ruvector_error = None
    ruvector_results: list[dict[str, Any]] | None = None
    index_data = load_ruvector_index()
    if index_data is None:
        ruvector_error = "RuVector index not available. Cannot perform semantic search."
        log(ruvector_error)
    else:
        ruvector_results = ruvector_search(query, index_data)
        if not ruvector_results:
            ruvector_error = "RuVector search returned no results or embedding was unavailable."
        log(f"RuVector returned {len(ruvector_results or [])} results")

    stage3a_output, stage3a_error = stage3a_search(query)
    comparison = compare_results(query, ruvector_results, ruvector_error, stage3a_output, stage3a_error)
    report_path = write_report(query, ruvector_results, stage3a_output, comparison, ruvector_error)
    print_terminal_summary(query, ruvector_results, comparison, report_path)
    return 0


if __name__ == "__main__":
    sys.exit(main())
