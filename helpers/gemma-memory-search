#!/usr/bin/env python3
"""Repo-tracked sanitized template for gemma-memory-search.

Installs to ~/.local/bin via scripts/install-gemma-memory-helpers.sh.
No sudo required. Stage 3A fallback and supervised RuVector boundary are preserved.

Supervised RuVector semantic search with Stage 3A fallback comparison.

RuVector is the PRIMARY supervised retrieval source.
Stage 3A is the DETERMINISTIC FALLBACK / comparison baseline.

Usage: gemma-memory-search "query"
Report:  ~/offload/security-reports/manual/gemma-memory-search-YYYYMMDD-HHMMSS.md
"""

from __future__ import annotations

import datetime as dt
import json
import re
import subprocess
import sys
import urllib.error
import urllib.request
from pathlib import Path
from typing import Any


HOME = Path.home()
TIMESTAMP = dt.datetime.now().strftime("%Y%m%d-%H%M%S")

RUVECTOR_INDEX = (
    HOME / ".local/share/bazzite-security/ruvector/semantic-prototype"
    / "semantic-approved-docs-memory.json"
)
STAGE3A_CMD = "gemma-knowledge-search"
REPORT_DIR = HOME / "offload/security-reports/manual"
LOG_FILE = HOME / f".local/state/bazzite-security/logs/gemma-memory-search-{TIMESTAMP}.log"

OLLAMA_URL = "http://127.0.0.1:11434/api/embeddings"
EMBEDDING_MODEL = "nomic-embed-text"
EMBEDDING_MODEL_TAG = "nomic-embed-text:latest"
EMBEDDING_DIM = 768
OLLAMA_TIMEOUT = 30

TOP_N = 5
SIMILARITY_CUTOFF = 0.0

SOURCE_FAMILIES = {
    "FINAL_POLICY.md": "policy",
    "OPERATIONS.md": "operational",
    "PATHS.md": "operational",
    "RUNBOOK.md": "operational",
    "OPENCODE_GEMMA_NOTES.md": "advisory/opencode",
    "GEMMA_LOCAL_AGENT.md": "advisory/opencode",
    "chunks.jsonl": "stage3a",
}

RECOMMENDATIONS = {
    "use_ruvector_context",
    "use_ruvector_primary_with_stage3a_support",
    "use_stage3a_context",
    "ruvector_unavailable_use_stage3a",
    "stop_human_review_required",
    "insufficient_evidence",
}


def log(message: str = "") -> None:
    line = f"{dt.datetime.now().strftime('%Y-%m-%d %H:%M:%S')} {message}"
    LOG_FILE.parent.mkdir(parents=True, exist_ok=True)
    with LOG_FILE.open("a", encoding="utf-8") as handle:
        handle.write(line + "\n")


def normalize_source(source: str) -> str:
    source = source.strip()
    if "chunks.jsonl" in source or source.lower() == "stage3a-chunk":
        return "chunks.jsonl"
    md_match = re.search(r"([A-Z0-9_]+\.md)", source)
    if md_match:
        return md_match.group(1)
    return Path(source).name if source else "unknown"


def source_family(source: str, source_type: str = "") -> str:
    normalized = normalize_source(source)
    if source_type == "stage3a-chunk":
        return "stage3a"
    return SOURCE_FAMILIES.get(normalized, "unknown")


def terms(text: str) -> set[str]:
    stop = {
        "about", "after", "also", "and", "are", "but", "for", "from", "has",
        "have", "into", "not", "only", "should", "that", "the", "this", "use",
        "using", "what", "when", "where", "which", "with", "would",
    }
    return {
        term for term in re.findall(r"[a-z0-9][a-z0-9_.-]*", text.lower())
        if len(term) > 2 and term not in stop
    }


def excerpt(text: str, limit: int = 300) -> str:
    compact = re.sub(r"\s+", " ", text).strip()
    return compact[:limit] + ("..." if len(compact) > limit else "")


def md_cell(value: object) -> str:
    return str(value).replace("|", "\\|").replace("\n", " ")


def cosine_similarity(vec_a: list[float], vec_b: list[float]) -> float:
    if len(vec_a) != len(vec_b):
        return 0.0
    dot = sum(a * b for a, b in zip(vec_a, vec_b))
    norm_a = sum(a * a for a in vec_a) ** 0.5
    norm_b = sum(b * b for b in vec_b) ** 0.5
    if norm_a == 0.0 or norm_b == 0.0:
        return 0.0
    return dot / (norm_a * norm_b)


def get_embedding(text: str) -> list[float] | None:
    payload = json.dumps({"model": EMBEDDING_MODEL, "prompt": text}).encode("utf-8")
    req = urllib.request.Request(
        OLLAMA_URL,
        data=payload,
        headers={"Content-Type": "application/json", "Content-Length": str(len(payload))},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=OLLAMA_TIMEOUT) as resp:
            parsed = json.loads(resp.read().decode("utf-8"))
    except TimeoutError:
        log("Ollama embedding request timed out")
        return None
    except urllib.error.URLError as exc:
        log(f"Ollama connection error: {exc}")
        return None
    except Exception as exc:
        log(f"Embedding error: {exc}")
        return None

    embedding = parsed.get("embedding")
    if not isinstance(embedding, list) or len(embedding) != EMBEDDING_DIM:
        observed = len(embedding) if isinstance(embedding, list) else "N/A"
        log(f"Unexpected embedding dimensions: {observed}")
        return None
    return embedding


def load_ruvector_index() -> dict[str, Any] | None:
    if not RUVECTOR_INDEX.is_file():
        log(f"RuVector index not found: {RUVECTOR_INDEX}")
        return None
    try:
        with RUVECTOR_INDEX.open("r", encoding="utf-8") as handle:
            data = json.load(handle)
    except Exception as exc:
        log(f"Failed to load RuVector index: {exc}")
        return None
    log(f"RuVector index loaded: {data.get('chunkCount', 0)} chunks, model={data.get('model', 'unknown')}")
    return data


def ruvector_search(query: str, index_data: dict[str, Any], top_k: int = TOP_N) -> list[dict[str, Any]]:
    embedding = get_embedding(query)
    if embedding is None:
        return []

    results = []
    for chunk in index_data.get("chunks", []):
        chunk_embedding = chunk.get("embedding")
        if not isinstance(chunk_embedding, list) or len(chunk_embedding) != EMBEDDING_DIM:
            continue
        similarity = cosine_similarity(embedding, chunk_embedding)
        if similarity <= SIMILARITY_CUTOFF:
            continue
        source = str(chunk.get("filename", "unknown"))
        source_type = str(chunk.get("sourceType", "unknown"))
        results.append({
            "rank": len(results) + 1,
            "id": chunk.get("id", "unknown"),
            "filename": source,
            "source": normalize_source(source),
            "sourceType": source_type,
            "family": source_family(source, source_type),
            "text": str(chunk.get("text", "")),
            "similarity": similarity,
        })
    results.sort(key=lambda r: -float(r["similarity"]))
    for rank, result in enumerate(results[:top_k], start=1):
        result["rank"] = rank
    return results[:top_k]


def stage3a_search(query: str) -> tuple[str, str | None]:
    try:
        result = subprocess.run(
            [STAGE3A_CMD, query],
            capture_output=True,
            text=True,
            timeout=30,
        )
    except subprocess.TimeoutExpired:
        log("Stage 3A search timed out")
        return "Stage 3A search timed out after 30s.", "timeout"
    except Exception as exc:
        log(f"Stage 3A error: {exc}")
        return f"Stage 3A error: {exc}", str(exc)

    log(f"Stage 3A exit code: {result.returncode}")
    if result.returncode != 0:
        return f"Stage 3A error: {result.stderr}", result.stderr.strip() or "non-zero exit"
    return result.stdout, None


def parse_stage3a_results(output: str) -> tuple[list[dict[str, Any]], str]:
    results: list[dict[str, Any]] = []
    current: dict[str, Any] | None = None
    field_re = re.compile(r"^(score|source|heading|excerpt):\s*(.*)$")

    for raw_line in output.splitlines():
        line = raw_line.rstrip()
        result_match = re.match(r"^## Result\s+(\d+)", line)
        if result_match:
            if current:
                results.append(current)
            current = {"rank": int(result_match.group(1)), "parse_complete": False}
            continue
        if current is None:
            continue
        field_match = field_re.match(line)
        if not field_match:
            continue
        key, value = field_match.groups()
        if key == "score":
            try:
                current[key] = float(value)
            except ValueError:
                current[key] = value
        else:
            current[key] = value

    if current:
        results.append(current)

    for result in results:
        source = str(result.get("source", "unknown"))
        result["source"] = normalize_source(source)
        result["source_raw"] = source
        result["sourceType"] = "stage3a-output"
        result["family"] = source_family(source)
        result["text"] = str(result.get("excerpt", ""))
        required = {"rank", "score", "source", "heading", "excerpt"}
        result["parse_complete"] = required.issubset(result)

    if results and all(bool(result.get("parse_complete")) for result in results):
        return results[:TOP_N], "complete"
    if results:
        return results[:TOP_N], "partial"
    return [], "partial"


def query_intent_family(query: str) -> str:
    query_terms = terms(query)
    if query_terms & {"where", "path", "paths", "logs", "reports", "generated", "written", "stored", "run", "command", "workflow"}:
        return "operational"
    if query_terms & {"gemma", "opencode", "unattended", "implementation", "agent", "wrapper", "advisory"}:
        return "advisory/opencode"
    if query_terms & {"firewall", "firewalld", "ufw", "package", "manager", "production", "status", "policy", "ruvector", "default"}:
        return "policy"
    return "unknown"


def answerability_hints(query: str) -> dict[str, Any]:
    query_terms = terms(query)
    hint_sets = [
        {
            "intent": "firewall_security_policy",
            "triggers": {"firewall", "firewalld", "ufw", "security", "host"},
            "expected": {"firewalld", "firewall", "policy", "ufw", "host", "security"},
            "direct": {"firewalld", "host firewall", "not ufw", "default firewall", "firewall management"},
        },
        {
            "intent": "path_report_log",
            "triggers": {"path", "paths", "report", "reports", "log", "logs", "directory", "generated", "written"},
            "expected": {"report", "reports", "log", "logs", "path", "directory", "offload", "local", "state", "security-reports"},
            "direct": {"~/offload", "security-reports", "~/.local/state", "bazzite-security/logs", "reports go", "logs go"},
        },
        {
            "intent": "opencode_gemma_boundary",
            "triggers": {"gemma", "opencode", "unattended", "implementation", "agent", "wrapper"},
            "expected": {"unattended", "opencode", "implementation", "advisory", "wrapper", "reliable", "gemma", "agent"},
            "direct": {"do not use", "unattended opencode", "implementation work", "advisory", "wrappers", "not reliable"},
        },
        {
            "intent": "production_status",
            "triggers": {"ruvector", "production", "status", "approved", "default", "secondary", "primary", "supervised", "fallback"},
            "expected": {"prototype", "production", "approved", "default", "secondary", "primary", "supervised", "fallback", "status", "ruvector"},
            "direct": {"prototype-only", "prototype only", "not approved", "approved_secondary", "approved secondary", "production default", "not production", "supervised secondary", "canonical fallback", "stage 3a remains"},
        },
    ]
    for hint in hint_sets:
        if query_terms & hint["triggers"]:
            return hint
    return {
        "intent": "general",
        "triggers": set(),
        "expected": query_terms,
        "direct": set(),
    }


def is_generic_header_only(text: str) -> bool:
    compact = re.sub(r"\s+", " ", text).strip()
    if not compact:
        return False
    if len(compact) <= 90 and re.match(r"^#{1,4}\s+", compact):
        return True
    if len(compact) <= 90 and re.match(r"^_?Last updated:", compact, re.IGNORECASE):
        return True
    if len(compact) <= 80 and compact.count(" ") <= 5:
        return True
    return False


def classify_answerability(query: str, result: dict[str, Any]) -> dict[str, Any]:
    hints = answerability_hints(query)
    text = str(result.get("text", ""))
    if result.get("heading"):
        text = f"{result.get('heading')} {text}"
    text_lc = text.lower()
    text_terms = terms(text)
    expected_terms = set(hints["expected"])
    direct_terms = set(hints["direct"])
    expected_hits = sorted(expected_terms & text_terms)
    direct_hits = sorted(term for term in direct_terms if term in text_lc)
    generic_header = is_generic_header_only(str(result.get("text", "")))
    too_short = len(re.sub(r"\s+", " ", str(result.get("text", ""))).strip()) < 45
    query_hits = sorted(terms(query) & text_terms)

    if generic_header:
        answerability = "generic_header_only"
    elif direct_hits and len(expected_hits) >= 1 and not too_short:
        answerability = "direct_answer"
    elif len(expected_hits) >= 3 and not too_short:
        answerability = "direct_answer"
    elif len(expected_hits) >= 1 or len(query_hits) >= 2:
        answerability = "supporting_context" if not too_short else "weak_context"
    elif result.get("family") in {"policy", "operational", "advisory/opencode", "stage3a"}:
        answerability = "weak_context"
    else:
        answerability = "unrelated_or_unclear"

    if hints["intent"] == "production_status" and answerability == "direct_answer" and not direct_hits:
        answerability = "supporting_context"
    if hints["intent"] == "production_status" and generic_header:
        answerability = "generic_header_only"

    result["answerability"] = answerability
    result["expected_term_hits"] = expected_hits
    result["direct_term_hits"] = direct_hits
    result["query_term_hits"] = query_hits
    result["generic_header_only"] = generic_header
    result["answerability_intent"] = hints["intent"]
    return result


def classify_result_set_answerability(query: str, results: list[dict[str, Any]]) -> dict[str, Any]:
    for result in results:
        classify_answerability(query, result)
    direct = [result for result in results if result.get("answerability") == "direct_answer"]
    supporting = [result for result in results if result.get("answerability") == "supporting_context"]
    weak = [result for result in results if result.get("answerability") in {"weak_context", "generic_header_only"}]
    useful = direct + supporting
    useful_sources = {str(result.get("source", "unknown")) for result in useful}
    return {
        "direct_count": len(direct),
        "supporting_count": len(supporting),
        "weak_count": len(weak),
        "useful_count": len(useful),
        "useful_source_count": len(useful_sources),
        "has_direct": bool(direct),
        "has_multiple_supporting": len(useful) >= 2 and len(useful_sources) >= 2,
        "classes": [str(result.get("answerability", "unrelated_or_unclear")) for result in results],
    }


def result_sources(results: list[dict[str, Any]]) -> set[str]:
    return {str(result.get("source", "unknown")) for result in results if result.get("source")}


def result_families(results: list[dict[str, Any]]) -> set[str]:
    return {str(result.get("family", "unknown")) for result in results if result.get("family")}


def exact_overlap_percent(ruvector_results: list[dict[str, Any]], stage3a_results: list[dict[str, Any]]) -> float:
    ruvector_sources = result_sources(ruvector_results)
    stage3a_sources = result_sources(stage3a_results)
    union = ruvector_sources | stage3a_sources
    if not union:
        return 0.0
    return (len(ruvector_sources & stage3a_sources) / len(union)) * 100.0


def content_equivalent(left: str, right: str, query: str) -> bool:
    query_terms = terms(query)
    left_terms = terms(left)
    right_terms = terms(right)
    if query_terms and (len(query_terms & left_terms) >= 2 and len(query_terms & right_terms) >= 2):
        return True
    shared = left_terms & right_terms
    return len(shared) >= 4


def source_family_equivalence_percent(
    ruvector_results: list[dict[str, Any]],
    stage3a_results: list[dict[str, Any]],
    query: str,
) -> tuple[float, list[str]]:
    denominator = max(len(ruvector_results), len(stage3a_results), 1)
    matched = 0
    labels: list[str] = []
    used_stage_indexes: set[int] = set()

    for ruv_result in ruvector_results:
        match_label = "no_equivalent_match"
        for index, stage_result in enumerate(stage3a_results):
            if index in used_stage_indexes:
                continue
            same_source = ruv_result.get("source") == stage_result.get("source")
            same_family = ruv_result.get("family") == stage_result.get("family")
            same_content = content_equivalent(
                str(ruv_result.get("text", "")),
                str(stage_result.get("text", "")),
                query,
            )
            if same_source:
                match_label = "exact_match"
            elif same_family:
                match_label = "family_equivalent"
            elif same_content:
                match_label = "content_equivalent"
            if match_label != "no_equivalent_match":
                used_stage_indexes.add(index)
                matched += 1
                break
        labels.append(match_label)

    return (matched / denominator) * 100.0, labels


def has_obvious_contradiction(ruvector_results: list[dict[str, Any]], stage3a_results: list[dict[str, Any]]) -> tuple[bool, str]:
    combined_ruv = " ".join(str(result.get("text", "")).lower() for result in ruvector_results)
    combined_stage = " ".join(str(result.get("text", "")).lower() for result in stage3a_results)
    contradiction_pairs = [
        ("use ufw", "not ufw"),
        ("use apt", "not apt"),
        ("use apt-get", "forbidden recommendations: apt"),
        ("unattended opencode implementation", "do not use gemma e4b for unattended opencode implementation"),
        ("production default", "not approved"),
    ]
    for positive, negative in contradiction_pairs:
        ruv_positive = positive in combined_ruv
        stage_positive = positive in combined_stage
        ruv_negative = negative in combined_ruv
        stage_negative = negative in combined_stage
        if (ruv_positive and stage_negative) or (stage_positive and ruv_negative):
            return True, f"Potential contradiction detected: '{positive}' vs '{negative}'"
    return False, "No obvious factual contradiction detected by conservative string checks."


def source_authority_notes(
    query: str,
    ruvector_results: list[dict[str, Any]],
    stage3a_results: list[dict[str, Any]],
) -> tuple[str, bool, bool]:
    intent = query_intent_family(query)
    ruv_families = result_families(ruvector_results)
    stage_families = result_families(stage3a_results)
    ruv_has_intent = intent != "unknown" and intent in ruv_families
    stage_has_intent = intent != "unknown" and intent in stage_families

    if intent == "operational" and stage_has_intent:
        return "Stage 3A has clearer operational/path authority for this query.", ruv_has_intent, True
    if intent in {"policy", "advisory/opencode"} and ruv_has_intent:
        return f"RuVector has {intent} source authority for this query.", True, stage_has_intent
    if ruv_has_intent and stage_has_intent:
        return f"Both systems have {intent} source authority.", True, True
    if ruvector_results and stage3a_results:
        return "Both systems returned non-empty context; authority depends on human query intent.", False, False
    if ruvector_results:
        return "Only RuVector returned usable context.", True, False
    if stage3a_results:
        return "Only Stage 3A returned usable context.", False, True
    return "Neither system returned usable context.", False, False


def compare_results(
    query: str,
    ruvector_results: list[dict[str, Any]] | None,
    ruvector_error: str | None,
    stage3a_output: str,
    stage3a_error: str | None,
) -> dict[str, Any]:
    ruv_results = ruvector_results or []
    stage_results, parse_status = parse_stage3a_results(stage3a_output)
    ruv_answerability = classify_result_set_answerability(query, ruv_results)
    stage_answerability = classify_result_set_answerability(query, stage_results)
    exact_overlap = exact_overlap_percent(ruv_results, stage_results)
    family_equivalence, labels = source_family_equivalence_percent(ruv_results, stage_results, query)
    contradiction, contradiction_note = has_obvious_contradiction(ruv_results, stage_results)
    authority_note, ruv_authority, stage_authority = source_authority_notes(query, ruv_results, stage_results)

    downgrade_reason = "none"

    if ruvector_error:
        recommendation = "ruvector_unavailable_use_stage3a"
        fallback_status = "active_stage3a_fallback_after_ruvector_error"
    elif contradiction:
        recommendation = "stop_human_review_required"
        fallback_status = "stage3a_available_but_human_review_required"
    elif query_intent_family(query) == "operational" and stage_answerability["has_direct"] and not ruv_answerability["has_direct"]:
        recommendation = "use_stage3a_context"
        fallback_status = "stage3a_comparison_preferred_for_operational_path_specificity"
        downgrade_reason = "Stage 3A has more direct operational/path answer evidence."
    elif stage_answerability["has_direct"] and not ruv_answerability["has_direct"]:
        recommendation = "use_stage3a_context"
        fallback_status = "stage3a_has_more_direct_answer_evidence"
        downgrade_reason = "Stage 3A has direct answer evidence while RuVector does not."
    elif ruv_answerability["has_direct"] or ruv_answerability["has_multiple_supporting"]:
        recommendation = "use_ruvector_context"
        fallback_status = "stage3a_available_as_comparison_baseline"
    elif query_intent_family(query) == "policy" and answerability_hints(query)["intent"] == "production_status":
        recommendation = "insufficient_evidence"
        fallback_status = "status_query_lacks_direct_production_status_evidence"
        downgrade_reason = "Production/status query lacks direct prototype/production/default/approved status terms in retrieved excerpts."
    elif ruv_results and stage_results and stage_answerability["supporting_count"] > 0:
        recommendation = "use_ruvector_primary_with_stage3a_support"
        fallback_status = "stage3a_supports_non_contradictory_context"
        downgrade_reason = "RuVector lacks direct answer evidence but Stage 3A provides useful support."
    elif ruv_results and stage_results:
        recommendation = "insufficient_evidence"
        fallback_status = "both_systems_weak_or_unclear"
        downgrade_reason = "Both systems returned weak or generic context without direct answer evidence."
    elif stage_results:
        recommendation = "ruvector_unavailable_use_stage3a"
        fallback_status = "stage3a_fallback_available"
    else:
        recommendation = "insufficient_evidence"
        fallback_status = "no_clear_context_from_ruvector_or_stage3a"

    if recommendation not in RECOMMENDATIONS:
        recommendation = "insufficient_evidence"

    if contradiction:
        confidence = "blocked"
    elif recommendation in {"insufficient_evidence", "ruvector_unavailable_use_stage3a"} and not stage_answerability["has_direct"]:
        confidence = "low"
    elif recommendation == "use_ruvector_context" and ruv_answerability["has_direct"]:
        confidence = "high"
    elif recommendation == "use_stage3a_context" and stage_answerability["has_direct"]:
        confidence = "high"
    elif recommendation == "use_ruvector_context" and ruv_answerability["has_multiple_supporting"]:
        confidence = "medium"
    elif recommendation == "use_ruvector_primary_with_stage3a_support":
        confidence = "medium"
    else:
        confidence = "low"

    return {
        "stage3a_results": stage_results,
        "stage3a_parse_status": parse_status,
        "stage3a_error": stage3a_error,
        "ruvector_source_set": sorted(result_sources(ruv_results)),
        "stage3a_source_set": sorted(result_sources(stage_results)),
        "ruvector_families": sorted(result_families(ruv_results)),
        "stage3a_families": sorted(result_families(stage_results)),
        "exact_overlap_percent": exact_overlap,
        "source_family_equivalence_percent": family_equivalence,
        "equivalence_labels": labels,
        "query_intent_family": query_intent_family(query),
        "authority_note": authority_note,
        "ruvector_has_source_authority": ruv_authority,
        "stage3a_has_clearer_operational_authority": stage_authority and query_intent_family(query) == "operational",
        "contradiction_detected": contradiction,
        "contradiction_note": contradiction_note,
        "ruvector_answerability": ruv_answerability,
        "stage3a_answerability": stage_answerability,
        "answerability_intent": answerability_hints(query)["intent"],
        "direct_evidence_count_ruvector": ruv_answerability["direct_count"],
        "direct_evidence_count_stage3a": stage_answerability["direct_count"],
        "recommendation_confidence": confidence,
        "downgrade_reason": downgrade_reason,
        "recommendation": recommendation,
        "fallback_status": fallback_status,
    }


def format_source_list(results: list[dict[str, Any]]) -> str:
    if not results:
        return "none"
    seen: list[str] = []
    for result in results:
        item = f"{result.get('source', 'unknown')} ({result.get('family', 'unknown')})"
        if item not in seen:
            seen.append(item)
    return "; ".join(seen)


def write_report(
    query: str,
    ruvector_results: list[dict[str, Any]] | None,
    stage3a_output: str,
    comparison: dict[str, Any],
    ruvector_error: str | None = None,
) -> Path:
    REPORT_DIR.mkdir(parents=True, exist_ok=True)
    report_path = REPORT_DIR / f"gemma-memory-search-{TIMESTAMP}.md"
    ruv_results = ruvector_results or []
    stage_results = comparison["stage3a_results"]

    lines = [
        "# gemma-memory-search Report",
        "",
