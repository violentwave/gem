        f"**Fallback Status:** `{comparison['fallback_status']}`",
        "",
        "---",
        "",
        "## RuVector Result Summary (PRIMARY - Supervised Retrieval)",
        "",
    ]

    if ruvector_error:
        lines.extend([f"**Status:** ERROR - {ruvector_error}", ""])
    elif not ruv_results:
        lines.extend(["**Status:** No RuVector results found", ""])
    else:
        lines.extend([
            f"**Status:** {len(ruv_results)} results found",
            f"**Model:** {EMBEDDING_MODEL_TAG} ({EMBEDDING_DIM}d)",
            f"**Index:** `{RUVECTOR_INDEX}`",
