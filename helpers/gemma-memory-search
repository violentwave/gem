                f"{md_cell(result.get('answerability', 'unrelated_or_unclear'))} | "
                f"{md_cell(excerpt(str(result.get('heading', '')), 120))} | "
                f"{md_cell(excerpt(str(result.get('excerpt', '')), 180))} |"
            )
        lines.append("")
    else:
        lines.extend(["No Stage 3A results parsed; raw output preserved below.", ""])

    lines.extend([
        "<details>",
        "<summary>Raw Stage 3A output</summary>",
        "",
        "```",
        stage3a_output,
        "```",
        "</details>",
        "",
        "---",
        "",
        "## Source-Family Classifications",
        "",
        "| Family | Sources | Authority |",
        "|--------|---------|-----------|",
        "| Policy | FINAL_POLICY.md | Highest for what should happen / policy questions |",
        "| Operational | OPERATIONS.md, PATHS.md, RUNBOOK.md | Highest for how-to, path, report, and log questions |",
        "| Advisory/OpenCode | OPENCODE_GEMMA_NOTES.md, GEMMA_LOCAL_AGENT.md | Highest for Gemma/OpenCode role and boundary questions |",
        "| Stage 3A | chunks.jsonl, stage3a-chunk | Deterministic fallback evidence |",
        "| Unknown | unmapped source | Requires review if important |",
