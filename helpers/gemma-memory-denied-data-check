#!/usr/bin/env python3
"""Repo-local denied-data check helper.

Scans proposed source paths for denied data patterns.

Manual-run only. No ingestion, no indexing.

Usage:
    gemma-memory-denied-data-check --source PATH
    gemma-memory-denied-data-check --source PATH --scan-content --write-report
"""

from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import re
import sys
from pathlib import Path
from typing import Any


HOME = Path.home()
TIMESTAMP = dt.datetime.now().strftime("%Y%m%d-%H%M%S")
REPORT_DIR = HOME / "offload/security-reports/manual"
REPORT_PATH = REPORT_DIR / f"gemma-memory-denied-data-check-{TIMESTAMP}.md"

MAX_FILE_SIZE = 1024 * 1024

DENIED_FILE_PATTERNS = {
    ".env",
    ".env.",
    "*secret*",
    "*token*",
    "*credential*",
    "*password*",
    "*key*",
    ".git",
    "__pycache__",
    "node_modules",
    ".DS_Store",
    "Thumbs.db",
}

DENIED_BROAD_ROOTS = {
    ".config",
    ".local/share",
    ".local/bin",
    "cache",
    "offload",
    ".cache",
}

DENIED_CONTENT_TERMS = {
    "api_key",
    "api_secret",
    "bearer",
    "authorization",
    "x-api-key",
    "private key",
    "password",
    "token",
    "secret",
    "aws_access",
    "aws_secret",
    "gh_token",
    "github_token",
}

DENIED_EXTENSIONS = {
    ".log",
    ".sqlite",
    ".db",
    ".sql",
    ".bak",
    ".tar",
    ".gz",
    ".zip",
    ".7z",
    ".rar",
    ".bin",
    ".exe",
    ".so",
    ".dll",
    ".dylib",
}


def is_denied_root(path: Path) -> tuple[bool, str]:
    """Check if path is a denied broad root."""
    parts = path.parts
    
    if path.is_absolute():
        if str(path).startswith("/var/home/lch/projects/"):
            return False, ""
        
        first_part = parts[0] if parts else ""
        if first_part.startswith("."):
            if first_part in {".config", ".local", ".cache"}:
                return True, f"broad denied: {first_part}"
    
    for root in DENIED_BROAD_ROOTS:
        if root in parts:
            return True, f"denied broad root: {root}"
    return False, ""


def is_denied_file(path: Path) -> tuple[bool, str]:
    """Check if file matches denied pattern."""
    name = path.name
    stem = path.stem
    ext = path.suffix.lower()
    
    for pattern in DENIED_FILE_PATTERNS:
        if "*" in pattern:
            if pattern.replace("*", "") in name.lower():
                return True, f"denied pattern: {pattern}"
        else:
            if pattern.lower() == name.lower():
                return True, f"denied filename: {pattern}"
            if pattern.lower() == stem.lower():
                return True, f"denied stem: {pattern}"
    
    if ext in DENIED_EXTENSIONS:
        return True, f"denied extension: {ext}"
    
    return False, ""


def scan_path(path: Path, scan_content: bool = False) -> dict[str, Any]:
    """Scan a path for denied data."""
    result = {
        "source_path": str(path),
        "scanned_at": dt.datetime.now().isoformat(),
        "mode": "content" if scan_content else "path_only",
        "included_file_count": 0,
        "excluded_file_count": 0,
        "matched_deny_rules": [],
        "status": "PASS",
        "explanation": "",
        "class_recommendation": None,
    }
    
    is_denied, reason = is_denied_root(path.absolute())
    if is_denied:
        result["status"] = "REJECT"
        result["matched_deny_rules"].append(reason)
        result["explanation"] = f"Path is denied broad root: {reason}"
        result["class_recommendation"] = "D"
        return result
    
    if path.is_file():
        is_denied_fn, reason = is_denied_file(path)
        if is_denied_fn:
            result["excluded_file_count"] = 1
            result["matched_deny_rules"].append(reason)
        else:
            result["included_file_count"] = 1
            
            if scan_content:
                if path.stat().st_size > MAX_FILE_SIZE:
                    result["excluded_file_count"] += 1
                    result["matched_deny_rules"].append(f"file too large: {path.stat().st_size} bytes")
                else:
                    try:
                        content = path.read_text(encoding="utf-8", errors="ignore")
                        for term in DENIED_CONTENT_TERMS:
                            if term in content.lower():
                                result["matched_deny_rules"].append(f"denied content term: {term}")
                                result["status"] = "REJECT"
                                result["explanation"] = f"Found denied content: {term}"
                                result["class_recommendation"] = "D"
                                break
                    except Exception as e:
                        result["excluded_file_count"] += 1
                        result["matched_deny_rules"].append(f"read error: {e}")
    
    elif path.is_dir():
        try:
            for item in path.rglob("*"):
                if item.is_symlink():
                    target = item.resolve()
                    try:
                        if not str(target).startswith(str(path.absolute())):
                            result["excluded_file_count"] += 1
                            result["matched_deny_rules"].append("symlink escapes root")
                            continue
                    except Exception:
                        pass
                
                if not item.is_file():
                    continue
                
                is_denied_fn, reason = is_denied_file(item)
                if is_denied_fn:
                    result["excluded_file_count"] += 1
                    result["matched_deny_rules"].append(f"{item}: {reason}")
                    continue
                
                if scan_content:
                    if item.stat().st_size > MAX_FILE_SIZE:
                        result["excluded_file_count"] += 1
                        result["matched_deny_rules"].append(f"{item.name}: too large")
                        continue
                    
                    try:
                        content = item.read_text(encoding="utf-8", errors="ignore")
                        for term in DENIED_CONTENT_TERMS:
                            if term in content.lower():
                                result["matched_deny_rules"].append(f"{item.name}: denied term '{term}'")
                                result["status"] = "REJECT"
                                result["explanation"] = f"Found denied content in {item.name}: {term}"
                                result["class_recommendation"] = "D"
                                break
                    except Exception:
                        result["excluded_file_count"] += 1
                else:
                    result["included_file_count"] += 1
        except PermissionError as e:
            result["excluded_file_count"] += 1
            result["matched_deny_rules"].append(f"permission denied: {e}")
    
    if result["status"] != "REJECT":
        if result["matched_deny_rules"]:
            result["explanation"] = f"Found {len(result['matched_deny_rules'])} denied patterns"
            result["class_recommendation"] = "D"
        else:
            result["explanation"] = "No denied patterns found"
            result["class_recommendation"] = "A"
    
    return result


def write_report(result: dict[str, Any]) -> None:
    """Write scan result as markdown report."""
    REPORT_DIR.mkdir(parents=True, exist_ok=True)
    
    lines = [
        "# Memory Denied-Data Check",
        "",
        f"**Timestamp:** {result['scanned_at']}",
        f"**Source:** `{result['source_path']}`",
        f"**Mode:** {result['mode']}",
        "",
        "---",
        "",
        "## Summary",
        "",
        f"- **Status:** `{result['status']}`",
        f"- **Included Files:** {result['included_file_count']}",
        f"- **Excluded Files:** {result['excluded_file_count']}",
        f"- **Class Recommendation:** `{result.get('class_recommendation', 'unknown')}`",
        "",
        "## Denied Rules Matched",
        "",
    ]
    
    if result["matched_deny_rules"]:
        for rule in result["matched_deny_rules"]:
            lines.append(f"- {rule}")
    else:
        lines.append("None")
    
    lines.extend([
        "",
        "## Explanation",
        "",
        result["explanation"] or "None",
        "",
        f"*Report: {REPORT_PATH}*",
    ])
    
    with REPORT_PATH.open("w", encoding="utf-8") as f:
        f.write("\n".join(lines))
    
    print(f"Report written to: {REPORT_PATH}")


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Memory denied-data check helper (no ingestion)",
    )
    parser.add_argument(
        "--source", required=True,
        help="Source path to scan",
    )
    parser.add_argument(
        "--scan-content",
        action="store_true",
        help="Scan file content for denied terms (default: path-only)",
    )
    parser.add_argument(
        "--write-report",
        action="store_true",
        help="Write scan report to ~/offload/security-reports/manual/",
    )
    
    args = parser.parse_args()
    
    source_path = Path(args.source)
    
    if not source_path.exists():
        print(f"ERROR: path does not exist: {source_path}", file=sys.stderr)
        return 1
    
    result = scan_path(source_path, args.scan_content)
    
    if args.write_report:
        write_report(result)
    
    print(json.dumps(result, indent=2))
    
    if result["status"] == "REJECT":
        return 1
    
    return 0


if __name__ == "__main__":
    sys.exit(main())